@inherits LayoutComponentBase

<ThemeProvider Class="helix-app-layout">
    <header class="helix-demo-header">
        <h1>HelixUI Demo</h1>
        <span style="color: var(--helix-color-text-muted); font-size: var(--helix-text-sm);">WASM</span>
        <ThemeToggle />
    </header>

    <nav class="helix-demo-nav">
        <NavMenu />
    </nav>

    <main class="helix-demo-main">
        @Body
    </main>

    <HelixToastContainer Position="ToastPosition.TopRight" />
</ThemeProvider>

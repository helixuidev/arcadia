@page "/theme"

<PageTitle>HelixUI Demo — Theme</PageTitle>

<h1>Theme System</h1>
<p style="color: var(--helix-color-text-muted); margin-bottom: var(--helix-spacing-lg);">
    Toggle between light and dark themes using the button in the header.
</p>

<h2>Color Palette</h2>
<div class="helix-demo-swatch-grid">
    <div class="helix-demo-swatch" style="background: var(--helix-color-primary);">Primary</div>
    <div class="helix-demo-swatch" style="background: var(--helix-color-secondary); color: var(--helix-color-on-secondary);">Secondary</div>
    <div class="helix-demo-swatch" style="background: var(--helix-color-danger); color: var(--helix-color-on-danger);">Danger</div>
    <div class="helix-demo-swatch" style="background: var(--helix-color-warning); color: var(--helix-color-on-warning);">Warning</div>
    <div class="helix-demo-swatch" style="background: var(--helix-color-success); color: var(--helix-color-on-success);">Success</div>
    <div class="helix-demo-swatch" style="background: var(--helix-color-info); color: var(--helix-color-on-info);">Info</div>
</div>

<h2>Surfaces</h2>
<div class="helix-demo-swatch-grid">
    <div class="helix-demo-surface" style="background: var(--helix-color-surface); border: 1px solid var(--helix-color-border);">Surface</div>
    <div class="helix-demo-surface" style="background: var(--helix-color-surface-raised); border: 1px solid var(--helix-color-border); box-shadow: var(--helix-shadow-md);">Raised</div>
    <div class="helix-demo-surface" style="background: var(--helix-color-surface-sunken); border: 1px solid var(--helix-color-border);">Sunken</div>
</div>

<h2>Typography</h2>
<div style="margin-bottom: var(--helix-spacing-lg);">
    <p style="font-size: var(--helix-text-xs);">Text XS (12px)</p>
    <p style="font-size: var(--helix-text-sm);">Text SM (14px)</p>
    <p style="font-size: var(--helix-text-base);">Text Base (16px)</p>
    <p style="font-size: var(--helix-text-lg);">Text LG (18px)</p>
    <p style="font-size: var(--helix-text-xl);">Text XL (20px)</p>
    <p style="font-size: var(--helix-text-2xl);">Text 2XL (24px)</p>
</div>

<h2>Elevation</h2>
<div class="helix-demo-swatch-grid">
    <div class="helix-demo-elevation" style="box-shadow: var(--helix-shadow-xs);">XS</div>
    <div class="helix-demo-elevation" style="box-shadow: var(--helix-shadow-sm);">SM</div>
    <div class="helix-demo-elevation" style="box-shadow: var(--helix-shadow-md);">MD</div>
    <div class="helix-demo-elevation" style="box-shadow: var(--helix-shadow-lg);">LG</div>
    <div class="helix-demo-elevation" style="box-shadow: var(--helix-shadow-xl);">XL</div>
</div>

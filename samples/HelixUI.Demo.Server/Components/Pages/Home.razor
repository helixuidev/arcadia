@page "/"

<PageTitle>HelixUI Demo — Home</PageTitle>

<h1>Welcome to HelixUI</h1>
<p style="color: var(--helix-color-text-muted); margin-bottom: var(--helix-spacing-lg);">
    A commercial Blazor component library for enterprise .NET developers.
</p>

<div class="helix-demo-card-grid">
    <div class="helix-demo-card">
        <h2>Core</h2>
        <p>Base classes, utilities, and accessibility helpers.</p>
    </div>
    <div class="helix-demo-card">
        <h2>Theme</h2>
        <p>Design tokens, light/dark themes, density modes.</p>
        <a href="/theme" class="helix-demo-link">View Demo</a>
    </div>
    <div class="helix-demo-card">
        <h2>Notifications</h2>
        <p>Toast notifications and notification center.</p>
        <a href="/notifications" class="helix-demo-link">View Demo</a>
    </div>
    <div class="helix-demo-card">
        <h2>FormBuilder</h2>
        <p>Schema-driven forms with validation and conditional fields.</p>
        <a href="/forms" class="helix-demo-link">View Demo</a>
    </div>
</div>

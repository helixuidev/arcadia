                <div class="gallery__showcase-title">Team Communication — Vibrant Palette</div>
                <div class="gallery__chart-container" style="display:flex;justify-content:center;">
                    <ArcadiaChordChart Data="@_teamNodes" Links="@_teamLinks"
                                      Height="420" Width="420" Title="Team Communication"
                                      Palette="ChartPalette.Vibrant" AnimateOnLoad="true" />
                </div>
            </div>
        }

        @if (_tab == "advanced")
        {
            <div class="gallery__section-header">
                <h1>Advanced Features</h1>
                <p>Bubble charts, full-circle gauges, and more specialized visualizations.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Bubble Chart — Scatter with Size Dimension</div>
                <div class="gallery__chart-container">
                    <ArcadiaScatterChart TItem="BubblePoint" Data="@_bubbleData"
                                       XField="@(d => d.X)" YField="@(d => d.Y)"
                                       SizeField="@(d => d.Size)"
                                       Height="400" Width="0" Color="primary" PointSize="4"
                                       Title="Market Cap vs Revenue (bubble = employees)" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Full-Circle Gauges</div>
                <div class="gallery__gauge-row">
                    <ArcadiaGaugeChart Value="68" Min="0" Max="100" Label="Progress" Width="180" Height="180"
                                     FullCircle="true" AnimateOnLoad="true" />
                    <ArcadiaGaugeChart Value="3.8" Min="0" Max="5" Label="Rating" Width="180" Height="180"
                                     FullCircle="true" ValueFormatString="0.0" AnimateOnLoad="true" />
                    <ArcadiaGaugeChart Value="850" Min="0" Max="1000" Label="Score" Width="180" Height="180"
                                     FullCircle="true" Thresholds="@_scoreThresholds" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Heatmap with Cell Values</div>
                <div class="gallery__chart-container">
                    <ArcadiaHeatmap TItem="HeatmapPoint" Data="@_heatmapData"
                                  XField="@(d => d.Day)" YField="@(d => d.Hour)"
                                  ValueField="@(d => d.Count)"
                                  ShowValues="true" Height="320" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase-row">
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Pie — Exploded Padding</div>
                    <div class="gallery__chart-container">
                        <ArcadiaPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="300" Width="340" PaddingAngle="3" />
                    </div>
                </div>
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Donut — Name + Value Labels</div>
                    <div class="gallery__chart-container">
                        <ArcadiaPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="300" Width="340" InnerRadius="60"
                                       LabelFormat="PieLabelFormat.Name" />
                    </div>
                </div>
            </div>
        }

        @* ─── FORMS ─── *@

        @if (_tab == "fields")
        {
            <div class="gallery__section-header">
                <h1>Field Types</h1>
                <p>21 field types with labels, validation, helper text, and full accessibility. Each field is a standalone component with two-way binding.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Text Inputs</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <TextField Label="Full Name" Value="@_textVal" ValueChanged="v => _textVal = v" Placeholder="Jane Doe" HelperText="Enter your legal name" Required="true" />
                    <PasswordField Label="Password" Value="@_passVal" ValueChanged="v => _passVal = v" Placeholder="Enter password" ShowStrength="true" />
                    <TextAreaField Label="Bio" Value="@_bioVal" ValueChanged="v => _bioVal = v" Placeholder="Tell us about yourself..." Rows="3" />
                    <MaskedField Label="Phone" Value="@_maskedVal" ValueChanged="v => _maskedVal = v" Mask="(###) ###-####" HelperText="US format" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Selection & Choice</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <SelectField Label="Country" Value="@_selectVal" ValueChanged="v => _selectVal = v" Placeholder="Choose one..." Options="@_countries" />
                    <RadioGroupField Label="Priority" Value="@_radioVal" ValueChanged="v => _radioVal = v" Options="@_priorities" />
                    <CheckboxField Label="I agree to the terms and conditions" Value="@_checkVal" ValueChanged="v => _checkVal = v" />
                    <SwitchField Label="Enable dark mode" Value="@_switchVal" ValueChanged="v => _switchVal = v" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Date, Time & Numeric</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <DateField Label="Start Date" Value="@_dateVal" ValueChanged="v => _dateVal = v" />
                    <NumberField Label="Quantity" Value="@_numVal" ValueChanged="v => _numVal = v" Min="0" Max="100" />
                    <SliderField Label="Volume" Value="@_sliderVal" ValueChanged="v => _sliderVal = v" Min="0" Max="100" Step="5" />
                    <RatingField Label="Satisfaction" Value="@_ratingVal" ValueChanged="v => _ratingVal = v" MaxRating="5" />
                    <ColorField Label="Brand Color" Value="@_colorVal" ValueChanged="v => _colorVal = v" />
                </div>
            </div>
        }

        @if (_tab == "schema")
        {
            <div class="gallery__section-header">
                <h1>Schema-Driven Form</h1>
                <p>Define a FormSchema object and the ArcadiaFormBuilder renders it dynamically. Includes validation, conditional fields, and sections.</p>
                <div class="gallery__hint">💡 Select "Phone" as contact method to see conditional field appear</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Contact Form — Rendered from Schema</div>
                <div style="max-width: 540px;">
                    <ArcadiaFormBuilder Schema="@_contactSchema" State="@_contactState"
                                      OnValidSubmit="HandleFormSubmit" OnInvalidSubmit="HandleFormError" />
                </div>
            </div>
        }

        @if (_tab == "wizard")
        {
            <div class="gallery__section-header">
                <h1>Wizard / Multi-Step</h1>
                <p>Step-by-step form with progress bar. Navigate with Previous/Next. Review before submit.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Onboarding Wizard</div>
                <div style="max-width: 560px;">
                    <ArcadiaWizard @bind-CurrentStep="_wizardStep" OnComplete="HandleWizardDone">
                        <ArcadiaWizardStep Title="Personal" Description="Tell us about yourself.">
                            <div style="display: flex; flex-direction: column; gap: 16px;">
                                <TextField Label="Full Name" Value="@_wName" ValueChanged="v => _wName = v" Required="true" Placeholder="Jane Doe" />
                                <TextField Label="Email" Value="@_wEmail" ValueChanged="v => _wEmail = v" Required="true" Placeholder="jane@example.com" />
                            </div>
                        </ArcadiaWizardStep>
                        <ArcadiaWizardStep Title="Preferences" Description="Customize your experience.">
                            <div style="display: flex; flex-direction: column; gap: 16px;">
                                <RatingField Label="How would you rate our product?" Value="@_wRating" ValueChanged="v => _wRating = v" />
                                <SliderField Label="Email frequency" Value="@_wFreq" ValueChanged="v => _wFreq = v" Min="0" Max="10" />
                            </div>
                        </ArcadiaWizardStep>
                        <ArcadiaWizardStep Title="Review" Description="Confirm and submit.">
                            <div style="font-size: 0.9rem; display: flex; flex-direction: column; gap: 6px;">
                                <div><strong>Name:</strong> @_wName</div>
                                <div><strong>Email:</strong> @_wEmail</div>
                                <div><strong>Rating:</strong> @_wRating / 5</div>
                                <div><strong>Frequency:</strong> @_wFreq</div>
                            </div>
                        </ArcadiaWizardStep>
                    </ArcadiaWizard>
                </div>
            </div>
        }

        @* ─── DATAGRID: moved to /datagrid/basics, /editing, /advanced, /enterprise ─── *@

        @* ─── UI COMPONENTS ─── *@

        @if (_tab == "ui")
        {
            <div class="gallery__section-header">
                <h1>UI Components</h1>
                <p>Essential infrastructure: dialogs, tabs, tooltips, cards, badges, and more. All accessible, themeable, zero JavaScript.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Dialog / Modal</div>
                <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                    <button class="gallery__toast-btn" @onclick="() => _showDialog = true">Open Dialog</button>
                </div>
                <ArcadiaDialog @bind-Visible="_showDialog" Title="Confirm Action" Width="440px">
                    <ChildContent>
                        <p style="color: #9490b3; margin: 0;">Are you sure you want to proceed? This action cannot be undone.</p>
                    </ChildContent>
                    <FooterTemplate>
                        <button style="padding: 8px 20px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: transparent; color: #e2e0f0; cursor: pointer;" @onclick="() => _showDialog = false">Cancel</button>
                        <button style="padding: 8px 20px; border-radius: 8px; border: none; background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; cursor: pointer; font-weight: 500;" @onclick="HandleDialogConfirm">Confirm</button>
                    </FooterTemplate>
                </ArcadiaDialog>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Tabs</div>
                <ArcadiaTabs>
                    <ArcadiaTabPanel Title="Overview">
                        <div style="padding: 16px 0; color: #9490b3;">This is the overview panel. Tabs use arrow key navigation and ARIA tablist/tabpanel roles.</div>
                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="Features">
                        <div style="padding: 16px 0; color: #9490b3;">Feature details go here. Each panel is lazily rendered — only the active panel is in the DOM.</div>
                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="API Reference">
                        <div style="padding: 16px 0; color: #9490b3;">API documentation content. Parameters, events, and code examples.</div>
                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="Disabled" Disabled="true">
                        <div>This panel is disabled.</div>
                    </ArcadiaTabPanel>
                </ArcadiaTabs>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Tooltip</div>
                <div style="display: flex; gap: 32px; align-items: center; padding: 24px 0;">
                    <ArcadiaTooltip Text="Tooltip on top (default)" Position="top">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0; cursor: pointer;">Top</button>
                    </ArcadiaTooltip>
                    <ArcadiaTooltip Text="Tooltip on the right" Position="right">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0; cursor: pointer;">Right</button>
                    </ArcadiaTooltip>
                    <ArcadiaTooltip Text="Tooltip on the bottom" Position="bottom">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0; cursor: pointer;">Bottom</button>
                    </ArcadiaTooltip>
                    <ArcadiaTooltip Text="Tooltip on the left" Position="left">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0; cursor: pointer;">Left</button>
                    </ArcadiaTooltip>
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Card</div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <ArcadiaCard Title="Revenue Report" Subtitle="Q4 2026">
                        <p style="color: #9490b3; margin: 0;">Total revenue increased by 23% compared to the previous quarter, driven by enterprise subscriptions.</p>
                    </ArcadiaCard>
                    <ArcadiaCard Title="Clickable Card" Clickable="true" OnClick="HandleCardClick">
                        <p style="color: #9490b3; margin: 0;">This card has a hover effect and fires an OnClick event. Try clicking it.</p>
                    </ArcadiaCard>
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Badge & Avatar</div>
                <div style="display: flex; gap: 32px; align-items: center; padding: 16px 0;">
                    <ArcadiaBadge Content="3" Color="primary">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0;">Inbox</button>
                    </ArcadiaBadge>
                    <ArcadiaBadge Content="99+" Color="danger">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0;">Alerts</button>
                    </ArcadiaBadge>
                    <ArcadiaBadge Dot="true" Color="success">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0;">Online</button>
                    </ArcadiaBadge>
                    <span style="margin-left: 16px;"></span>
                    <ArcadiaAvatar Name="Alice Chen" Size="lg" Color="primary" />
                    <ArcadiaAvatar Name="Bob Martinez" Size="md" Color="success" />
                    <ArcadiaAvatar Name="Carol Kim" Size="sm" Color="warning" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Accordion</div>
                <ArcadiaAccordion>
                    <ArcadiaAccordionItem Title="What is Arcadia Controls?">
                        <p style="color: #9490b3; margin: 0;">Arcadia Controls is a commercial Blazor component library with charts, DataGrid, forms, and UI components. Pure C# rendering with zero JavaScript.</p>
                    </ArcadiaAccordionItem>
                    <ArcadiaAccordionItem Title="How do I install it?">
                        <p style="color: #9490b3; margin: 0;">Run <code style="color: #c084fc;">dotnet add package Arcadia.Charts</code> and add the CSS link to your App.razor.</p>
                    </ArcadiaAccordionItem>
                    <ArcadiaAccordionItem Title="Is it free?">
                        <p style="color: #9490b3; margin: 0;">Community Edition includes 4 chart types for free. Pro ($299/dev/year) adds all 16 charts, DataGrid, Form Builder, and more.</p>
                    </ArcadiaAccordionItem>
                </ArcadiaAccordion>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Breadcrumb</div>

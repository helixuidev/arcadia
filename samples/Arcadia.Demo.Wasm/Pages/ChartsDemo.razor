                        <ArcadiaMenuItem Divider="true" />
                        <ArcadiaMenuItem Text="Delete" OnClick='() => ToastService.ShowWarning("Delete clicked")' />
                    </ChildContent>
                </ArcadiaMenu>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Drawer / Sheet</div>
                <button class="gallery__toast-btn" @onclick="() => _showDrawer = true">Open Drawer</button>

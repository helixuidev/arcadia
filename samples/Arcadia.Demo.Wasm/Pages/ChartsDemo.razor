                    <ArcadiaBreadcrumbItem Href="/">Home</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem Href="/docs">Documentation</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem Href="/docs/charts">Charts</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem>Line Chart</ArcadiaBreadcrumbItem>
                </ArcadiaBreadcrumb>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">TreeView</div>
                <ArcadiaTreeView Items="@_treeItems" OnItemClick="item => ToastService.ShowInfo(item.Text)" />
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Dropdown Menu</div>
                <ArcadiaMenu>
                    <Trigger>
                        <button style="padding:8px 16px;border-radius:8px;border:1px solid rgba(139,92,246,0.2);background:rgba(139,92,246,0.06);color:#e2e0f0;cursor:pointer;">Actions ▾</button>

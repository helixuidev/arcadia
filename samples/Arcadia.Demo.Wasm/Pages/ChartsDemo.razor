                    <p style="color:#9490b3;">Drawer content goes here. Slides in from the right.</p>
                </ArcadiaDrawer>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Skeleton Loading</div>
                <div style="display:flex;gap:16px;align-items:center;">
                    <ArcadiaSkeleton Variant="circular" Width="48px" Height="48px" />
                    <div>
                        <ArcadiaSkeleton Variant="text" Width="200px" Height="16px" />
                        <ArcadiaSkeleton Variant="text" Width="140px" Height="12px" />
                    </div>
                </div>
                <div style="margin-top:16px;">
                    <ArcadiaSkeleton Variant="rectangular" Width="100%" Height="120px" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Date Picker</div>

@page "/"

<PageTitle>HelixUI Demo — Home</PageTitle>

<h1>Welcome to HelixUI</h1>
<p style="color: var(--arcadia-color-text-muted); margin-bottom: var(--arcadia-spacing-lg);">
    A commercial Blazor component library for enterprise .NET developers.
</p>

<div class="arcadia-demo-card-grid">
    <div class="arcadia-demo-card">
        <h2>Core</h2>
        <p>Base classes, utilities, and accessibility helpers.</p>
    </div>
    <div class="arcadia-demo-card">
        <h2>Theme</h2>
        <p>Design tokens, light/dark themes, density modes.</p>
        <a href="/theme" class="arcadia-demo-link">View Demo</a>
    </div>
    <div class="arcadia-demo-card">
        <h2>Notifications</h2>
        <p>Toast notifications and notification center.</p>
        <a href="/notifications" class="arcadia-demo-link">View Demo</a>
    </div>
</div>

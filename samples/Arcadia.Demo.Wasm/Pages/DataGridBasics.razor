        <div class="gallery__cta">
            <a href="https://arcadiaui.com" class="gallery__admin-link" target="_blank">arcadiaui.com &#8594;</a>
        </div>
    </div>

    <div class="gallery__content">

        <div class="gallery__section-header">
            <h1>DataGrid — Basics</h1>
            <p>Core grid features: rendering, sorting, filtering, pagination, toolbar, and column formatting.</p>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Default Grid</div>
            <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Minimal setup — just data and columns, no sorting or filtering.</p>
            <ArcadiaDataGrid TItem="Employee" Data="@_employees" Sortable="false" PageSize="0">
                <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                <ArcadiaColumn TItem="Employee" Property="Name" />
                <ArcadiaColumn TItem="Employee" Property="Department" />
                <ArcadiaColumn TItem="Employee" Property="Role" />
                <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
            </ArcadiaDataGrid>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Sorting</div>
            <div class="gallery__hint">Shift+Click column headers for multi-sort</div>
            <ArcadiaDataGrid TItem="Employee" Data="@_employees" Sortable="true" PageSize="0">
                <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                <ArcadiaColumn TItem="Employee" Property="Name" />
                <ArcadiaColumn TItem="Employee" Property="Department" />
                <ArcadiaColumn TItem="Employee" Property="Role" />
                <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
            </ArcadiaDataGrid>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Column Filtering</div>
            <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Type-aware filters: text contains, numeric range, date range, boolean toggle.</p>
            <ArcadiaDataGrid TItem="Employee" Data="@_employees" Filterable="true" PageSize="0">
                <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                <ArcadiaColumn TItem="Employee" Property="Name" />
                <ArcadiaColumn TItem="Employee" Property="Department" />
                <ArcadiaColumn TItem="Employee" Property="Role" />
                <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
            </ArcadiaDataGrid>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Pagination</div>
            <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">50 rows with configurable page sizes.</p>
            <ArcadiaDataGrid TItem="Order" Data="@_orders" Sortable="true" PageSize="10" PageSizeOptions="@(new[]{5,10,25,50})">
                <ArcadiaColumn TItem="Order" Property="OrderId" Title="Order #" Width="90px" />
                <ArcadiaColumn TItem="Order" Property="Customer" />
                <ArcadiaColumn TItem="Order" Property="Product" />
                <ArcadiaColumn TItem="Order" Property="Amount" Format="C2" Align="right" />
                <ArcadiaColumn TItem="Order" Property="Date" Format="d" />
                <ArcadiaColumn TItem="Order" Property="Status" />
            </ArcadiaDataGrid>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Toolbar &amp; Quick Search</div>
            <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Built-in toolbar with search, column picker, and export buttons.</p>
            <ArcadiaDataGrid TItem="Employee" Data="@_employees" ShowToolbar="true" Sortable="true" PageSize="0">
                <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                <ArcadiaColumn TItem="Employee" Property="Name" />
                <ArcadiaColumn TItem="Employee" Property="Department" />
                <ArcadiaColumn TItem="Employee" Property="Role" />
                <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
            </ArcadiaDataGrid>
        </div>

        <div class="gallery__showcase">
            <div class="gallery__showcase-title">Column Formatting</div>
            <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Currency, percentage, date, and alignment formatting on financial data.</p>
            <ArcadiaDataGrid TItem="FinancialRow" Data="@_financialData" Sortable="true" PageSize="0" Striped="true">
                <ArcadiaColumn TItem="FinancialRow" Property="Ticker" Title="Ticker" Width="100px" />
                <ArcadiaColumn TItem="FinancialRow" Property="Price" Title="Price" Format="C2" Align="right" Width="120px" />
                <ArcadiaColumn TItem="FinancialRow" Property="Change" Title="Change" Format="F2" Align="right" Width="100px" />
                <ArcadiaColumn TItem="FinancialRow" Property="ChangePct" Title="Change %" Format="P1" Align="right" Width="110px" />
                <ArcadiaColumn TItem="FinancialRow" Property="Volume" Title="Volume" Format="N0" Align="right" Width="120px" />
                <ArcadiaColumn TItem="FinancialRow" Property="TradeDate" Title="Trade Date" Format="d" />
            </ArcadiaDataGrid>
        </div>

    </div>
</div>


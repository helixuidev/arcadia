@page "/test/datagrid"
@layout Arcadia.Demo.Server.Components.Layout.FullScreenLayout
@using Arcadia.DataGrid.Components
@using Arcadia.DataGrid.Core

<div style="padding: 24px; max-width: 1100px; margin: 0 auto;">
    <h2 style="color: white; margin-bottom: 16px;">ArcadiaDataGrid — Full Feature Demo</h2>

    <div style="margin-bottom: 12px; display:flex; gap: 12px; align-items:center;">
        <label style="color:#9490b3; font-size:0.8rem;">Theme:</label>
        @foreach (var t in _themes)
        {
            var theme = t;
            <button style="@($"padding:4px 12px;border-radius:6px;border:1px solid {(theme.Key == _theme ? "#8b5cf6" : "#2d2a3e")};background:{(theme.Key == _theme ? "rgba(139,92,246,0.15)" : "transparent")};color:{(theme.Key == _theme ? "#c084fc" : "#9490b3")};cursor:pointer;font-size:0.75rem;font-family:inherit;")"
                    @onclick="@(() => _theme = theme.Key)">@theme.Value</button>
        }
        <label style="color:#9490b3; font-size:0.8rem; margin-left:12px;">Density:</label>
        @foreach (var d in _densities)
        {
            var density = d;
            <button style="@($"padding:4px 10px;border-radius:6px;border:1px solid {(density.Key == _density ? "#8b5cf6" : "#2d2a3e")};background:{(density.Key == _density ? "rgba(139,92,246,0.15)" : "transparent")};color:{(density.Key == _density ? "#c084fc" : "#9490b3")};cursor:pointer;font-size:0.75rem;font-family:inherit;")"
                    @onclick="@(() => _density = density.Key)">@density.Value</button>
        }
    </div>

    <ArcadiaDataGrid TItem="Employee" Data="@_employees" PageSize="10"
                      Striped="true" Hoverable="true"
                      Filterable="true" Selectable="true" MultiSelect="true"
                      ShowRowSelector="true"
                      SelectedItemsChanged="@(items => _selectedCount = items.Count)"
                      GroupBy="@_groupBy"
                      Class="@($"{_theme} {_density}")"
                      Height="500px">
        <DetailTemplate Context="emp">
            <div style="display:flex;gap:24px;color:#9490b3;font-size:0.85rem;">
                <div><strong style="color:#c084fc;">Email:</strong> @(emp.Name.Split(' ')[0].ToLower())@("@arcadia.com")</div>
                <div><strong style="color:#c084fc;">Years:</strong> @((int)((DateTime.Now - emp.StartDate).TotalDays / 365))</div>
                <div><strong style="color:#c084fc;">Manager:</strong> @(emp.Department) Lead</div>
            </div>
        </DetailTemplate>
        <ChildContent>
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Id)" Title="ID" Width="60px" Align="center" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Name)" Title="Name" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Department)" Title="Department" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Title)" Title="Job Title" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Salary)" Title="Salary" Format="C0" Align="right"
                           Aggregate="AggregateType.Average" Editable="true" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.StartDate)" Title="Start Date" Format="d" />
            <ArcadiaColumn TItem="Employee" Title="Actions">
                <Template Context="emp">
                    <button style="background:#8b5cf6;color:white;border:none;padding:4px 10px;border-radius:4px;cursor:pointer;font-size:0.75rem;"
                            @onclick="@(() => _selected = emp.Name)">View</button>
                </Template>
            </ArcadiaColumn>
        </ChildContent>
    </ArcadiaDataGrid>

    <div style="margin-top: 12px; display:flex; gap: 12px; font-size: 0.85rem; align-items:center;">
        <label style="color:#9490b3;">Group by:</label>
        <select style="background:transparent;border:1px solid #2d2a3e;color:inherit;padding:4px 8px;border-radius:4px;font-size:inherit;"
                @onchange="@((ChangeEventArgs e) => _groupBy = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value?.ToString())">
            <option value="">None</option>
            <option value="Department">Department</option>
        </select>
    </div>
    <div style="margin-top: 8px; display:flex; gap: 16px; font-size: 0.85rem;">
        @if (_selected is not null)
        {
            <span style="color: #c084fc;">Viewed: @_selected</span>
        }
        @if (_selectedCount > 0)
        {
            <span style="color: #22c55e;">@_selectedCount selected</span>
        }
    </div>
    <div style="margin-top: 4px; color: #9490b3; font-size: 0.75rem;">
        Double-click the Salary column to edit inline. Click Export CSV in toolbar. Click arrow to expand detail rows.
    </div>

    <h3 style="color: white; margin-top: 32px; margin-bottom: 12px;">Virtual Scroll — 10,000 Rows</h3>
    <ArcadiaDataGrid TItem="Employee" Data="@_bigData" VirtualizeRows="true" Height="400px"
                      Class="arcadia-grid--midnight">
        <ChildContent>
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Id)" Title="ID" Width="80px" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Name)" Title="Name" Width="1fr" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Department)" Title="Department" Width="1fr" />
            <ArcadiaColumn TItem="Employee" Field="@(e => (object)e.Salary)" Title="Salary" Format="C0" Width="120px" />
        </ChildContent>
    </ArcadiaDataGrid>
</div>

@code {
    string? _selected;
    int _selectedCount;
    string? _groupBy;
    string _theme = "arcadia-grid--obsidian";
    string _density = "";

    Dictionary<string, string> _themes = new()
    {
        { "", "Default" },
        { "arcadia-grid--obsidian", "Obsidian" },
        { "arcadia-grid--vapor", "Vapor" },
        { "arcadia-grid--carbon", "Carbon" },
        { "arcadia-grid--aurora", "Aurora" },
        { "arcadia-grid--slate", "Slate" },
        { "arcadia-grid--midnight", "Midnight" },
    };

    Dictionary<string, string> _densities = new()
    {
        { "", "Default" },
        { "arcadia-grid--compact", "Compact" },
        { "arcadia-grid--relaxed", "Relaxed" },
    };

    record Employee(int Id, string Name, string Department, string Title, double Salary, DateTime StartDate);

    List<Employee> _employees = new();
    List<Employee> _bigData = new();

    protected override void OnInitialized()
    {
        var departments = new[] { "Engineering", "Marketing", "Sales", "HR", "Finance", "Operations", "Design", "Product" };
        var titles = new[] { "Junior", "Mid-Level", "Senior", "Lead", "Principal", "Director", "VP" };
        var firstNames = new[] { "Alice", "Bob", "Carol", "Dave", "Eve", "Frank", "Grace", "Hank", "Iris", "Jack", "Kate", "Leo", "Maya", "Nick", "Olivia", "Pete", "Quinn", "Rose", "Sam", "Tina" };
        var lastNames = new[] { "Smith", "Johnson", "Williams", "Brown", "Jones", "Garcia", "Miller", "Davis", "Rodriguez", "Martinez", "Wilson", "Anderson", "Taylor", "Thomas", "Moore", "White", "Harris", "Clark", "Lewis", "Young" };

        var rng = new Random(42);
        for (var i = 1; i <= 75; i++)
        {
            var dept = departments[rng.Next(departments.Length)];
            var title = titles[rng.Next(titles.Length)];
            var first = firstNames[rng.Next(firstNames.Length)];
            var last = lastNames[rng.Next(lastNames.Length)];
            var salary = 55000 + rng.Next(120000);
            var start = new DateTime(2018, 1, 1).AddDays(rng.Next(2500));
            _employees.Add(new Employee(i, $"{first} {last}", dept, $"{title} {dept}", salary, start));
        }

        // Generate 10K rows for virtual scroll demo
        for (var i = 1; i <= 10000; i++)
        {
            var dept = departments[rng.Next(departments.Length)];
            var first = firstNames[rng.Next(firstNames.Length)];
            var last = lastNames[rng.Next(lastNames.Length)];
            var salary = 45000 + rng.Next(150000);
            _bigData.Add(new Employee(i, $"{first} {last}", dept, "", salary, DateTime.MinValue));
        }
    }
}

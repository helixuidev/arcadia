@page "/charts"
@page "/"
@layout Arcadia.Demo.Server.Components.Layout.FullScreenLayout
@using Arcadia.Charts.Core
@using Arcadia.Charts.Components.Charts
@using Arcadia.Charts.Components.Dashboard
@using Arcadia.FormBuilder.Schema
@using Arcadia.FormBuilder.Components
@using Arcadia.FormBuilder.Components.Fields
@using Arcadia.FormBuilder.Components.Layout
@inject Arcadia.Notifications.ToastService ToastService

<PageTitle>Arcadia Controls — Component Gallery</PageTitle>

<div class="gallery">
    <div class="gallery__sidebar">
        <h2 class="gallery__title">Arcadia Controls</h2>
        <p class="gallery__subtitle">Component Gallery</p>
        <nav class="gallery__nav">
            <div class="gallery__nav-group">Charts</div>
            <button class="gallery__nav-btn @(_tab == "dashboard" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dashboard"'>Dashboard Widgets</button>
            <button class="gallery__nav-btn @(_tab == "line" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "line"'>Line & Area</button>
            <button class="gallery__nav-btn @(_tab == "bar" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "bar"'>Bar</button>
            <button class="gallery__nav-btn @(_tab == "pie" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "pie"'>Pie & Donut</button>
            <button class="gallery__nav-btn @(_tab == "scatter" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "scatter"'>Scatter</button>
            <button class="gallery__nav-btn @(_tab == "candle" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "candle"'>Candlestick</button>
            <button class="gallery__nav-btn @(_tab == "gauge" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "gauge"'>Gauges</button>
            <button class="gallery__nav-btn @(_tab == "radar" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "radar"'>Radar</button>
            <button class="gallery__nav-btn @(_tab == "heatmap" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "heatmap"'>Heatmap</button>
            <button class="gallery__nav-btn @(_tab == "rose" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "rose"'>Rose / Polar</button>
            <button class="gallery__nav-btn @(_tab == "interactive" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "interactive"'>Interactive</button>
            <button class="gallery__nav-btn @(_tab == "streaming" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "streaming"'>Streaming</button>
            <button class="gallery__nav-btn @(_tab == "advanced" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "advanced"'>Advanced</button>

            <div class="gallery__nav-group">Forms</div>
            <button class="gallery__nav-btn @(_tab == "fields" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "fields"'>Field Types</button>
            <button class="gallery__nav-btn @(_tab == "schema" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "schema"'>Schema Form</button>
            <button class="gallery__nav-btn @(_tab == "wizard" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "wizard"'>Wizard</button>

            <div class="gallery__nav-group">Other</div>
            <button class="gallery__nav-btn @(_tab == "toasts" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "toasts"'>Notifications</button>
        </nav>
        <div class="gallery__cta">
            <a href="https://arcadiaui.com" class="gallery__admin-link" target="_blank">arcadiaui.com →</a>
        </div>
    </div>

    <div class="gallery__content">

        @if (_tab == "dashboard")
        {
            <div class="gallery__section-header">
                <h1>Dashboard Widgets</h1>
                <p>Pre-composed widgets that look great out of the box. Drop them into any layout — no chart configuration needed.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">KPI Cards with Sparklines</div>
                <div class="gallery__widget-grid">
                    <HelixKpiCard Title="Monthly Revenue" Value="$142,580" Delta="+12.3%" DeltaType="DeltaType.Increase"
                                  Sparkline="@_revenueSparkline" Footer="vs last month" />
                    <HelixKpiCard Title="Active Users" Value="8,420" Delta="-2.1%" DeltaType="DeltaType.Decrease"
                                  Sparkline="@_usersSparkline" SparklineColor="danger" Footer="vs last week" />
                    <HelixKpiCard Title="Conversion Rate" Value="3.8%" Delta="+0.5%" DeltaType="DeltaType.Increase"
                                  Sparkline="@_conversionSparkline" SparklineColor="success" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Progress Indicators</div>
                <div class="gallery__progress-stack">
                    <HelixProgressBar Value="73" Max="100" Label="Storage Used" Thresholds="@_thresholds" />
                    <HelixProgressBar Value="45" Max="100" Label="CPU Usage" Color="info" />
                    <HelixProgressBar Value="92" Max="100" Label="Memory" Thresholds="@_thresholds" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Inline Sparklines</div>
                <div class="gallery__sparkline-row">
                    <span>Revenue <HelixSparkline Data="@_revenueSparkline" Color="primary" ShowArea="true" /></span>
                    <span>Users <HelixSparkline Data="@_usersSparkline" Color="danger" /></span>
                    <span>Growth <HelixSparkline Data="@_conversionSparkline" Color="success" ShowArea="true" /></span>
                </div>
            </div>
        }

        @if (_tab == "line")
        {
            <div class="gallery__section-header">
                <h1>Line & Area Chart</h1>
                <p>Multi-series with area fill, dashed lines, and trendline overlays. Lines draw themselves on load.</p>
                <div class="gallery__hint">💡 Hover points for values · Click legend to toggle series</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Revenue vs Target — 12 Months</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_lineSeries"
                                    Height="380" Width="0" ShowPoints="true" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Stacked Area</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_stackedSeries"
                                    Height="380" Width="0" Stacked="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Combo — Bar + Line on Same Axes</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_comboSeries"
                                    Height="380" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">With Trendline Overlay</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_trendSeries"
                                    Height="380" Width="0" ShowDataLabels="true" />
                </div>
            </div>
        }

        @if (_tab == "bar")
        {
            <div class="gallery__section-header">
                <h1>Bar Chart</h1>
                <p>Grouped or stacked bars with rounded corners. Bars grow from baseline on load.</p>
                <div class="gallery__hint">💡 Hover bars for tooltips · Click legend to toggle regions</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Quarterly Revenue — Grouped by Region</div>
                <div class="gallery__chart-container">
                    <HelixBarChart TItem="QuarterlySales" Data="@_quarterlySales"
                                   XField="@(d => (object)d.Quarter)" Series="@_barSeries"
                                   Height="380" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Same Data — Stacked</div>
                <div class="gallery__chart-container">
                    <HelixBarChart TItem="QuarterlySales" Data="@_quarterlySales"
                                   XField="@(d => (object)d.Quarter)" Series="@_barSeries"
                                   Height="380" Width="0" Stacked="true" />
                </div>
            </div>
        }

        @if (_tab == "pie")
        {
            <div class="gallery__section-header">
                <h1>Pie & Donut</h1>
                <p>Animated slices with configurable labels. Set InnerRadius for donut mode.</p>
            </div>

            <div class="gallery__showcase-row">
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Pie</div>
                    <div class="gallery__chart-container">
                        <HelixPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="340" Width="380" />
                    </div>
                </div>
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Donut</div>
                    <div class="gallery__chart-container">
                        <HelixPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="340" Width="380" InnerRadius="70" />
                    </div>
                </div>
            </div>
        }

        @if (_tab == "scatter")
        {
            <div class="gallery__section-header">
                <h1>Scatter Chart</h1>
                <p>Plot X/Y data points with staggered pop-in animation. Add SizeField for bubble charts.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Height vs Weight Distribution</div>
                <div class="gallery__chart-container">
                    <HelixScatterChart TItem="DataXY" Data="@_scatterData"
                                       XField="@(d => d.X)" YField="@(d => d.Y)"
                                       Height="400" Width="0" Color="primary" PointSize="6" />
                </div>
            </div>
        }

        @if (_tab == "candle")
        {
            <div class="gallery__section-header">
                <h1>Candlestick</h1>
                <p>Financial OHLC chart with moving average overlay. Green candles = close above open.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">ACME Corp — 30 Day Price</div>
                <div class="gallery__chart-container">
                    <HelixCandlestickChart TItem="StockCandle" Data="@_stockData"
                                            LabelField="@(d => d.Date)"
                                            OpenField="@(d => d.Open)" HighField="@(d => d.High)"
                                            LowField="@(d => d.Low)" CloseField="@(d => d.Close)"
                                            Height="420" Width="0" />
                </div>
            </div>
        }

        @if (_tab == "gauge")
        {
            <div class="gallery__section-header">
                <h1>Gauge Charts</h1>
                <p>Radial gauges with color thresholds. Arc fills with smooth animation on load.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">System Health Monitors</div>
                <div class="gallery__gauge-row">
                    <HelixGaugeChart Value="73" Min="0" Max="100" Label="CPU" Width="180" Height="140" Thresholds="@_gaugeThresholds" />
                    <HelixGaugeChart Value="42" Min="0" Max="100" Label="Memory" Width="180" Height="140" ValueFormatString="0'%'" />
                    <HelixGaugeChart Value="91" Min="0" Max="100" Label="Disk" Width="180" Height="140" Thresholds="@_gaugeThresholds" />
                    <HelixGaugeChart Value="99.9" Min="0" Max="100" Label="Uptime" Width="180" Height="140" ValueFormatString="0.0'%'" />
                </div>
            </div>
        }

        @if (_tab == "radar")
        {
            <div class="gallery__section-header">
                <h1>Radar Chart</h1>
                <p>Multi-dimensional comparison across categories. Polygons draw with line animation.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Team Skills — A vs B</div>
                <div class="gallery__chart-container">
                    <HelixRadarChart TItem="SkillProfile" Data="@_skillData"
                                     LabelField="@(d => d.Skill)" Series="@_radarSeries"
                                     Height="420" Width="0" />
                </div>
            </div>
        }

        @if (_tab == "heatmap")
        {
            <div class="gallery__section-header">
                <h1>Heatmap</h1>
                <p>2D color grid for visualizing density, frequency, or correlation data.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Commit Activity by Day & Hour</div>
                <div class="gallery__chart-container">
                    <HelixHeatmap TItem="HeatmapPoint" Data="@_heatmapData"
                                  XField="@(d => d.Day)" YField="@(d => d.Hour)"
                                  ValueField="@(d => d.Count)"
                                  Height="320" Width="0" />
                </div>
            </div>
        }

        @if (_tab == "rose")
        {
            <div class="gallery__section-header">
                <h1>Rose / Polar Area Chart</h1>
                <p>Equal-angle sectors with radius proportional to value. Ideal for cyclical data like wind direction, time-of-day patterns, or seasonal comparisons.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Wind Speed by Direction</div>
                <div class="gallery__chart-container" style="display: flex; justify-content: center;">
                    <HelixRoseChart TItem="WindData" Data="@_windData"
                                    NameField="@(d => d.Direction)" ValueField="@(d => d.Speed)"
                                    Height="400" Width="400" AnimateOnLoad="true"
                                    Title="Wind Speed by Direction" />
                </div>
            </div>
        }

        @if (_tab == "interactive")
        {
            <div class="gallery__section-header">
                <h1>Interactive Features</h1>
                <p>Crosshair tracking, annotations, and export. Hover any chart to reveal PNG/SVG download buttons in the top-right corner.</p>
                <div class="gallery__hint">💡 Hover the chart to see the crosshair · Export buttons appear top-right on hover</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Crosshair + Annotations</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_interactiveSeries"
                                    Height="380" Width="0" ShowPoints="true" ShowCrosshair="true"
                                    Annotations="@_annotations" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Moving Average Trendline</div>
                <div class="gallery__chart-container">
                    <HelixLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_maTrendSeries"
                                    Height="380" Width="0" ShowPoints="true" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Null Handling — Gap vs Connect vs Zero</div>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;">
                    <div>
                        <div style="font-size: 0.75rem; opacity: 0.6; margin-bottom: 4px; text-align: center;">Gap (default)</div>
                        <HelixLineChart TItem="NullablePoint" Data="@_nullData"
                                        XField="@(d => (object)d.Label)" Series="@_nullSeries"
                                        Height="180" Width="0" NullHandling="NullHandling.Gap" ShowPoints="true" AnimateOnLoad="false" />
                    </div>
                    <div>
                        <div style="font-size: 0.75rem; opacity: 0.6; margin-bottom: 4px; text-align: center;">Connect</div>
                        <HelixLineChart TItem="NullablePoint" Data="@_nullData"
                                        XField="@(d => (object)d.Label)" Series="@_nullSeries"
                                        Height="180" Width="0" NullHandling="NullHandling.Connect" ShowPoints="true" AnimateOnLoad="false" />
                    </div>
                    <div>
                        <div style="font-size: 0.75rem; opacity: 0.6; margin-bottom: 4px; text-align: center;">Zero</div>
                        <HelixLineChart TItem="NullablePoint" Data="@_nullData"
                                        XField="@(d => (object)d.Label)" Series="@_nullSeries"
                                        Height="180" Width="0" NullHandling="NullHandling.Zero" ShowPoints="true" AnimateOnLoad="false" />
                    </div>
                </div>
            </div>
        }

        @if (_tab == "streaming")
        {
            <div class="gallery__section-header">
                <h1>Live / Streaming Data</h1>
                <p>Charts update in real-time via AppendPoint and SlidingWindow APIs. No page reload needed.</p>
                <div class="gallery__hint">💡 Click "Add Point" to push live data · Sliding window keeps the last 20 points</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Sliding Window — Last 20 Data Points</div>
                <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                    <button class="gallery__toast-btn gallery__toast-btn--info" @onclick="AddStreamPoint">Add Point</button>
                    <button class="gallery__toast-btn gallery__toast-btn--success" @onclick="StartAutoStream">Auto Stream</button>
                    <button class="gallery__toast-btn" @onclick="StopAutoStream">Stop</button>
                </div>
                <div class="gallery__chart-container">
                    <HelixLineChart @ref="_streamChart" TItem="StreamPoint" Data="@_streamData"
                                    XField="@(d => (object)d.Time)" Series="@_streamSeries"
                                    Height="340" Width="0" ShowPoints="true" SlidingWindow="20"
                                    AnimateOnLoad="false" ShowCrosshair="true" />
                </div>
            </div>
        }

        @if (_tab == "advanced")
        {
            <div class="gallery__section-header">
                <h1>Advanced Features</h1>
                <p>Bubble charts, full-circle gauges, and more specialized visualizations.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Bubble Chart — Scatter with Size Dimension</div>
                <div class="gallery__chart-container">
                    <HelixScatterChart TItem="BubblePoint" Data="@_bubbleData"
                                       XField="@(d => d.X)" YField="@(d => d.Y)"
                                       SizeField="@(d => d.Size)"
                                       Height="400" Width="0" Color="primary" PointSize="4"
                                       Title="Market Cap vs Revenue (bubble = employees)" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Full-Circle Gauges</div>
                <div class="gallery__gauge-row">
                    <HelixGaugeChart Value="68" Min="0" Max="100" Label="Progress" Width="180" Height="180"
                                     FullCircle="true" AnimateOnLoad="true" />
                    <HelixGaugeChart Value="3.8" Min="0" Max="5" Label="Rating" Width="180" Height="180"
                                     FullCircle="true" ValueFormatString="0.0" AnimateOnLoad="true" />
                    <HelixGaugeChart Value="850" Min="0" Max="1000" Label="Score" Width="180" Height="180"
                                     FullCircle="true" Thresholds="@_scoreThresholds" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Heatmap with Cell Values</div>
                <div class="gallery__chart-container">
                    <HelixHeatmap TItem="HeatmapPoint" Data="@_heatmapData"
                                  XField="@(d => d.Day)" YField="@(d => d.Hour)"
                                  ValueField="@(d => d.Count)"
                                  ShowValues="true" Height="320" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase-row">
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Pie — Exploded Padding</div>
                    <div class="gallery__chart-container">
                        <HelixPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="300" Width="340" PaddingAngle="3" />
                    </div>
                </div>
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Donut — Name + Value Labels</div>
                    <div class="gallery__chart-container">
                        <HelixPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="300" Width="340" InnerRadius="60"
                                       LabelFormat="PieLabelFormat.Name" />
                    </div>
                </div>
            </div>
        }

        @* ─── FORMS ─── *@

        @if (_tab == "fields")
        {
            <div class="gallery__section-header">
                <h1>Field Types</h1>
                <p>21 field types with labels, validation, helper text, and full accessibility. Each field is a standalone component with two-way binding.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Text Inputs</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <TextField Label="Full Name" Value="@_textVal" ValueChanged="v => _textVal = v" Placeholder="Jane Doe" HelperText="Enter your legal name" Required="true" />
                    <PasswordField Label="Password" Value="@_passVal" ValueChanged="v => _passVal = v" Placeholder="Enter password" ShowStrength="true" />
                    <TextAreaField Label="Bio" Value="@_bioVal" ValueChanged="v => _bioVal = v" Placeholder="Tell us about yourself..." Rows="3" />
                    <MaskedField Label="Phone" Value="@_maskedVal" ValueChanged="v => _maskedVal = v" Mask="(###) ###-####" HelperText="US format" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Selection & Choice</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <SelectField Label="Country" Value="@_selectVal" ValueChanged="v => _selectVal = v" Placeholder="Choose one..." Options="@_countries" />
                    <RadioGroupField Label="Priority" Value="@_radioVal" ValueChanged="v => _radioVal = v" Options="@_priorities" />
                    <CheckboxField Label="I agree to the terms and conditions" Value="@_checkVal" ValueChanged="v => _checkVal = v" />
                    <SwitchField Label="Enable dark mode" Value="@_switchVal" ValueChanged="v => _switchVal = v" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Date, Time & Numeric</div>
                <div style="display: flex; flex-direction: column; gap: 20px; max-width: 480px;">
                    <DateField Label="Start Date" Value="@_dateVal" ValueChanged="v => _dateVal = v" />
                    <NumberField Label="Quantity" Value="@_numVal" ValueChanged="v => _numVal = v" Min="0" Max="100" />
                    <SliderField Label="Volume" Value="@_sliderVal" ValueChanged="v => _sliderVal = v" Min="0" Max="100" Step="5" />
                    <RatingField Label="Satisfaction" Value="@_ratingVal" ValueChanged="v => _ratingVal = v" MaxRating="5" />
                    <ColorField Label="Brand Color" Value="@_colorVal" ValueChanged="v => _colorVal = v" />
                </div>
            </div>
        }

        @if (_tab == "schema")
        {
            <div class="gallery__section-header">
                <h1>Schema-Driven Form</h1>
                <p>Define a FormSchema object and the HelixFormBuilder renders it dynamically. Includes validation, conditional fields, and sections.</p>
                <div class="gallery__hint">💡 Select "Phone" as contact method to see conditional field appear</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Contact Form — Rendered from Schema</div>
                <div style="max-width: 540px;">
                    <HelixFormBuilder Schema="@_contactSchema" State="@_contactState"
                                      OnValidSubmit="HandleFormSubmit" OnInvalidSubmit="HandleFormError" />
                </div>
            </div>
        }

        @if (_tab == "wizard")
        {
            <div class="gallery__section-header">
                <h1>Wizard / Multi-Step</h1>
                <p>Step-by-step form with progress bar. Navigate with Previous/Next. Review before submit.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Onboarding Wizard</div>
                <div style="max-width: 560px;">
                    <HelixWizard @bind-CurrentStep="_wizardStep" OnComplete="HandleWizardDone">
                        <HelixWizardStep Title="Personal" Description="Tell us about yourself.">
                            <div style="display: flex; flex-direction: column; gap: 16px;">
                                <TextField Label="Full Name" Value="@_wName" ValueChanged="v => _wName = v" Required="true" Placeholder="Jane Doe" />
                                <TextField Label="Email" Value="@_wEmail" ValueChanged="v => _wEmail = v" Required="true" Placeholder="jane@example.com" />
                            </div>
                        </HelixWizardStep>
                        <HelixWizardStep Title="Preferences" Description="Customize your experience.">
                            <div style="display: flex; flex-direction: column; gap: 16px;">
                                <RatingField Label="How would you rate our product?" Value="@_wRating" ValueChanged="v => _wRating = v" />
                                <SliderField Label="Email frequency" Value="@_wFreq" ValueChanged="v => _wFreq = v" Min="0" Max="10" />
                            </div>
                        </HelixWizardStep>
                        <HelixWizardStep Title="Review" Description="Confirm and submit.">
                            <div style="font-size: 0.9rem; display: flex; flex-direction: column; gap: 6px;">
                                <div><strong>Name:</strong> @_wName</div>
                                <div><strong>Email:</strong> @_wEmail</div>
                                <div><strong>Rating:</strong> @_wRating / 5</div>
                                <div><strong>Frequency:</strong> @_wFreq</div>
                            </div>
                        </HelixWizardStep>
                    </HelixWizard>
                </div>
            </div>
        }

        @* ─── NOTIFICATIONS ─── *@

        @if (_tab == "toasts")
        {
            <div class="gallery__section-header">
                <h1>Toast Notifications</h1>
                <p>Fire-and-forget toasts with auto-dismiss, stacking, and severity levels.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Trigger Toasts</div>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    <button class="gallery__toast-btn gallery__toast-btn--info" @onclick='() => ToastService.ShowInfo("This is an informational message.")'>Info</button>
                    <button class="gallery__toast-btn gallery__toast-btn--success" @onclick='() => ToastService.ShowSuccess("Operation completed successfully.")'>Success</button>
                    <button class="gallery__toast-btn gallery__toast-btn--warning" @onclick='() => ToastService.ShowWarning("Please review before proceeding.")'>Warning</button>
                    <button class="gallery__toast-btn gallery__toast-btn--error" @onclick='() => ToastService.ShowError("Something went wrong.")'>Error</button>
                    <button class="gallery__toast-btn" @onclick='() => ToastService.ShowSuccess("Your changes have been saved.", "Saved!")'>With Title</button>
                    <button class="gallery__toast-btn" @onclick="ToastService.DismissAll">Dismiss All</button>
                </div>
            </div>
        }

    </div>
</div>

@code {
    string _tab = "dashboard";


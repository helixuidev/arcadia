                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Department uses a dropdown select for constrained editing.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" OnRowEdit="HandleRowEdit" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Name" Editable="true" />
                    <ArcadiaColumn TItem="Employee" Property="Department" Editable="true">
                        <EditTemplate Context="item">
                            <select style="background: #1a1833; color: #e2e0f0; border: 1px solid rgba(139,92,246,0.3); border-radius: 6px; padding: 4px 8px; width: 100%;">
                                @foreach (var dept in new[] { "Engineering", "Design", "Marketing", "Sales" })
                                {
                                    <option value="@dept" selected="@(item.Department == dept)">@dept</option>
                                }
                            </select>
                        </EditTemplate>
                    </ArcadiaColumn>
                    <ArcadiaColumn TItem="Employee" Property="Role" Editable="true" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Batch Editing</div>
                <div class="gallery__hint">Edit multiple cells, then Save or Discard all changes at once.</div>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" BatchEdit="true" ShowToolbar="true" OnBatchCommit="HandleBatchCommit" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" Editable="true" />
                    <ArcadiaColumn TItem="Employee" Property="Department" Editable="true" />
                    <ArcadiaColumn TItem="Employee" Property="Role" Editable="true" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" Editable="true" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Single Row Selection</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Click a row to select it. Details appear below.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" SelectionMode="DataGridSelectionMode.SingleRow" PageSize="0"
                                 SelectedItems="@_selectedEmployeeSet" SelectedItemsChanged="HandleSingleSelect">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
                @if (_selectedEmployee is not null)
                {
                    <div style="margin-top: 12px; padding: 12px 16px; border-radius: 8px; background: rgba(139,92,246,0.06); border: 1px solid rgba(139,92,246,0.15); color: #c4c0e0; font-size: 0.8125rem;">
                        Selected: <strong style="color: #e2e0f0;">@_selectedEmployee.Name</strong> — @_selectedEmployee.Role in @_selectedEmployee.Department (@_selectedEmployee.Salary.ToString("C0"))
                    </div>
                }
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Multi-Row Selection</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Checkbox selection with row count display.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" SelectionMode="DataGridSelectionMode.Multiple" ShowRowSelector="true" PageSize="0"
                                 SelectedItems="@_selectedEmployees" SelectedItemsChanged="@(items => { _selectedEmployees = items; StateHasChanged(); })">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
                <div style="margin-top: 8px; color: #8a86a8; font-size: 0.8125rem;">
                    @(_selectedEmployees?.Count ?? 0) row(s) selected
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Row Numbers</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Auto-generated row numbers alongside a row selector column.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" ShowRowSelector="true" ShowRowNumbers="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
                </ArcadiaDataGrid>
            </div>
        }

        @* ─── DATAGRID: ADVANCED ─── *@

        @if (_tab == "dg-advanced")
        {
            <div class="gallery__section-header">
                <h1>DataGrid — Advanced</h1>
                <p>Grouping, embedded charts, master-detail, virtual scrolling, and frozen columns.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Grouping</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Rows grouped by Department with collapsible group headers.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" GroupBy="Department" Sortable="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Computed Grouping</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Group by a computed expression: salary above $120k = "Senior", below = "Standard".</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" GroupByField="@(e => (object)(e.Salary > 120000 ? "Senior ($120k+)" : "Standard"))" Sortable="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Charts in Grid Cells</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Sparklines, delta indicators, and progress bars embedded in grid columns.</p>
                <ArcadiaDataGrid TItem="ProductMetric" Data="@_productMetrics" Striped="true" PageSize="0">
                    <ArcadiaColumn TItem="ProductMetric" Field="@(p => p.Product)" Title="Product" />
                    <ArcadiaColumn TItem="ProductMetric" Field="@(p => p.Revenue)" Title="Revenue" Format="C0" Align="right" />
                    <ArcadiaColumn TItem="ProductMetric" Title="Trend (6mo)">
                        <Template Context="item">
                            <ArcadiaSparkline Data="@item.Trend" Width="100" Height="24" Color="@(item.Delta >= 0 ? "success" : "danger")" ShowArea="true" />
                        </Template>
                    </ArcadiaColumn>
                    <ArcadiaColumn TItem="ProductMetric" Title="Change">
                        <Template Context="item">
                            <ArcadiaDeltaIndicator Value="@($"{item.Delta:+0.0;-0.0}%")" Type="@(item.Delta >= 0 ? DeltaType.Increase : DeltaType.Decrease)" />
                        </Template>
                    </ArcadiaColumn>
                    <ArcadiaColumn TItem="ProductMetric" Title="Quota">
                        <Template Context="item">
                            <ArcadiaProgressBar Value="@item.QuotaPct" Max="100" Color="@(item.QuotaPct >= 80 ? "success" : item.QuotaPct >= 50 ? "warning" : "danger")" />
                        </Template>
                    </ArcadiaColumn>
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Master-Detail</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Expand a row to see that employee's project assignments.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" Sortable="true" PageSize="0">
                    <DetailTemplate Context="emp">
                        <div style="padding: 12px 24px; background: rgba(139,92,246,0.03);">
                            <strong style="color: #c4c0e0; font-size: 0.8125rem;">Projects for @emp.Name</strong>
                            <table style="width: 100%; margin-top: 8px; font-size: 0.8125rem; color: #9490b3;">
                                <thead><tr style="border-bottom: 1px solid rgba(139,92,246,0.1);"><th style="text-align: left; padding: 4px 8px;">Project</th><th style="text-align: left; padding: 4px 8px;">Status</th><th style="text-align: right; padding: 4px 8px;">Hours</th></tr></thead>
                                <tbody>
                                    @foreach (var p in GetProjects(emp.Id))
                                    {
                                        <tr><td style="padding: 4px 8px;">@p.Name</td><td style="padding: 4px 8px;">@p.Status</td><td style="text-align: right; padding: 4px 8px;">@p.Hours</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </DetailTemplate>
                    <ChildContent>
                        <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                        <ArcadiaColumn TItem="Employee" Property="Name" />
                        <ArcadiaColumn TItem="Employee" Property="Department" />
                        <ArcadiaColumn TItem="Employee" Property="Role" />
                        <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    </ChildContent>
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Virtual Scrolling</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">10,000 rows rendered on demand with virtualization.</p>
                <ArcadiaDataGrid TItem="LargeItem" Data="@_largeDataset" VirtualizeRows="true" Height="400px" ItemSize="40" Sortable="true" Filterable="true" PageSize="0">
                    <ArcadiaColumn TItem="LargeItem" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="LargeItem" Property="Name" />
                    <ArcadiaColumn TItem="LargeItem" Property="Category" />
                    <ArcadiaColumn TItem="LargeItem" Property="Value" Format="C2" Align="right" />
                    <ArcadiaColumn TItem="LargeItem" Property="Created" Title="Created" Format="d" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Frozen Columns</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">First two columns stay fixed during horizontal scroll.</p>
                <ArcadiaDataGrid TItem="WideRow" Data="@_wideData" PageSize="0" Height="360px">
                    <ArcadiaColumn TItem="WideRow" Property="Id" Title="ID" Width="70px" Frozen="true" />
                    <ArcadiaColumn TItem="WideRow" Property="Name" Width="140px" Frozen="true" />
                    <ArcadiaColumn TItem="WideRow" Property="A" Title="Col A" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="B" Title="Col B" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="C" Title="Col C" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="D" Title="Col D" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="E" Title="Col E" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="F" Title="Col F" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="G" Title="Col G" Width="130px" />
                    <ArcadiaColumn TItem="WideRow" Property="H" Title="Col H" Width="130px" />
                </ArcadiaDataGrid>
            </div>
        }

        @* ─── DATAGRID: ENTERPRISE ─── *@

        @if (_tab == "dg-enterprise")
        {
            <div class="gallery__section-header">
                <h1>DataGrid — Enterprise</h1>
                <p>Export, column management, state persistence, context menus, footer aggregates, and theming.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">CSV &amp; Excel Export</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Click the CSV or Excel buttons in the toolbar to download grid data.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" ShowToolbar="true" Sortable="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Column Picker</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Use the Columns button in the toolbar to show/hide columns dynamically.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" ShowToolbar="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">State Persistence</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Sort or filter, then refresh the page — grid state is restored from local storage.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" StateKey="demo-grid" Sortable="true" Filterable="true" ShowToolbar="true" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Context Menu</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Right-click a row to see View, Edit, and Delete actions.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" PageSize="0">
                    <ContextMenuTemplate Context="emp">
                        <div style="background: #1e1b38; border: 1px solid rgba(139,92,246,0.2); border-radius: 8px; padding: 4px 0; min-width: 160px; box-shadow: 0 8px 24px rgba(0,0,0,0.4);">
                            <button style="display: block; width: 100%; text-align: left; padding: 8px 16px; background: none; border: none; color: #e2e0f0; cursor: pointer; font-size: 0.8125rem;" @onclick="@(() => ToastService.ShowInfo($"Viewing {emp.Name}"))">View Details</button>
                            <button style="display: block; width: 100%; text-align: left; padding: 8px 16px; background: none; border: none; color: #e2e0f0; cursor: pointer; font-size: 0.8125rem;" @onclick="@(() => ToastService.ShowInfo($"Editing {emp.Name}"))">Edit</button>
                            <button style="display: block; width: 100%; text-align: left; padding: 8px 16px; background: none; border: none; color: #f87171; cursor: pointer; font-size: 0.8125rem;" @onclick="@(() => ToastService.ShowWarning($"Delete {emp.Name}?"))">Delete</button>
                        </div>
                    </ContextMenuTemplate>
                    <ChildContent>
                        <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                        <ArcadiaColumn TItem="Employee" Property="Name" />
                        <ArcadiaColumn TItem="Employee" Property="Department" />
                        <ArcadiaColumn TItem="Employee" Property="Role" />
                        <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                    </ChildContent>
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Footer Aggregates</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Sum of Salary and Average of Salary computed in the footer row.</p>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" PageSize="0">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" Aggregate="AggregateType.Count" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" Aggregate="AggregateType.Sum" />
                    <ArcadiaColumn TItem="Employee" Property="StartDate" Title="Start Date" Format="d" />
                </ArcadiaDataGrid>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Theme Showcase</div>
                <p style="color: #8a86a8; font-size: 0.8125rem; margin-bottom: 12px;">Switch between grid visual styles using CSS class overrides.</p>
                <div style="display: flex; gap: 8px; margin-bottom: 12px; flex-wrap: wrap;">
                    @foreach (var theme in new[] { ("", "Default"), ("arcadia-grid--compact", "Compact"), ("arcadia-grid--bordered", "Bordered"), ("arcadia-grid--rounded", "Rounded"), ("arcadia-grid--flat", "Flat"), ("arcadia-grid--neon", "Neon") })
                    {
                        <button class="gallery__toast-btn @(_selectedTheme == theme.Item1 ? "gallery__toast-btn--info" : "")"
                                @onclick="@(() => _selectedTheme = theme.Item1)">@theme.Item2</button>
                    }
                </div>
                <ArcadiaDataGrid TItem="Employee" Data="@_employees" Class="@_selectedTheme" Sortable="true" PageSize="0" Striped="true">
                    <ArcadiaColumn TItem="Employee" Property="Id" Title="ID" Width="80px" />
                    <ArcadiaColumn TItem="Employee" Property="Name" />
                    <ArcadiaColumn TItem="Employee" Property="Department" />
                    <ArcadiaColumn TItem="Employee" Property="Role" />
                    <ArcadiaColumn TItem="Employee" Property="Salary" Format="C0" Align="right" />
                </ArcadiaDataGrid>
            </div>
        }

        @* ─── UI COMPONENTS ─── *@

        @if (_tab == "ui")
        {
            <div class="gallery__section-header">

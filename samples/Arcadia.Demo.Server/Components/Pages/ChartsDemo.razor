        CancelText = "Reset",
        Fields = new()
        {
            new() { Name = "name", Type = FieldType.Text, Label = "Full Name", Required = true, Placeholder = "John Doe", Validation = new() { MinLength = 2 } },
            new() { Name = "email", Type = FieldType.Text, Label = "Email", Required = true, Placeholder = "john@example.com", Validation = new() { Pattern = "email" } },
            new() { Name = "method", Type = FieldType.Select, Label = "Contact Method", Required = true, Placeholder = "Select...", Options = new() { "Email", "Phone", "Mail" } },
            new() { Name = "phone", Type = FieldType.Text, Label = "Phone", Placeholder = "+1 (555) 000-0000", Conditions = new() { new() { Field = "method", Operator = Arcadia.FormBuilder.Schema.ConditionalOperator.Equals, Value = "Phone", Action = Arcadia.FormBuilder.Schema.ConditionalAction.Show } } },
            new() { Name = "message", Type = FieldType.TextArea, Label = "Message", Required = true, Placeholder = "How can we help?", Validation = new() { MinLength = 10 } },
            new() { Name = "urgent", Type = FieldType.Switch, Label = "Mark as urgent" },

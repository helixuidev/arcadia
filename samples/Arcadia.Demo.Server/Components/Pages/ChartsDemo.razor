                    <ArcadiaAvatar Name="Alice Chen" Size="lg" Color="primary" />
                    <ArcadiaAvatar Name="Bob Martinez" Size="md" Color="success" />
                    <ArcadiaAvatar Name="Carol Kim" Size="sm" Color="warning" />

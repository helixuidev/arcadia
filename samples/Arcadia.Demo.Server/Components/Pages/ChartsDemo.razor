        new("S", 7), new("SW", 18), new("W", 14), new("NW", 9),
    };

    // ── Interactive tab data ──
    List<SeriesConfig<MonthlySales>> _interactiveSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "success", ShowArea = true, AreaOpacity = 0.15, CurveType = "smooth" },
        new() { Name = "Target", Field = d => d.Target, Color = "warning", Dashed = true, StrokeWidth = 2, CurveType = "smooth" },
    };
    List<ChartAnnotation> _annotations = new()
    {
        new() { DataIndex = 3, Label = "Launch", Color = "var(--arcadia-color-success)" },
        new() { DataIndex = 7, Label = "Outage", Color = "var(--arcadia-color-danger)" },
        new() { DataIndex = 10, Label = "Campaign", Color = "var(--arcadia-color-info)" },
    };

    List<SeriesConfig<MonthlySales>> _maTrendSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary", ShowArea = true, AreaOpacity = 0.08,
                Trendline = new() { Type = TrendlineType.MovingAverage, MovingAveragePeriod = 3, Color = "var(--arcadia-color-warning)", Dashed = true } },
    };

    List<NullablePoint> _nullData = new()
    {
        new("A", 10), new("B", 25), new("C", double.NaN), new("D", double.NaN),
        new("E", 30), new("F", 45), new("G", 35), new("H", double.NaN), new("I", 50), new("J", 40),
    };
    List<SeriesConfig<NullablePoint>> _nullSeries = new()
    {
        new() { Name = "Values", Field = d => d.Value, Color = "primary" },
    };

    // ── Streaming tab data ──
    HelixLineChart<StreamPoint>? _streamChart;
    List<StreamPoint> _streamData = new() { new("0s", 50), new("1s", 52) };
    List<SeriesConfig<StreamPoint>> _streamSeries = new()
    {
        new() { Name = "Sensor", Field = d => d.Value, Color = "primary", ShowArea = true, AreaOpacity = 0.15, CurveType = "smooth" },
    };
    int _streamCounter = 2;
    Random _streamRng = new(42);
    double _streamValue = 52;
    System.Threading.Timer? _autoStreamTimer;

    void AddStreamPoint()
    {
        _streamValue += (_streamRng.NextDouble() - 0.48) * 8;
        _streamValue = Math.Max(10, Math.Min(90, _streamValue));
        var pt = new StreamPoint($"{_streamCounter++}s", Math.Round(_streamValue, 1));
        if (_streamChart is not null)
        {
            // AppendAndSlide handles add + remove + re-render + animation
            _streamChart.AppendAndSlide(pt);
        }
        else
        {
            // Chart not yet rendered — add to list directly
            _streamData.Add(pt);
            if (_streamData.Count > 20) _streamData.RemoveAt(0);
            StateHasChanged();
        }
    }

    void StartAutoStream()
    {
        _autoStreamTimer?.Dispose();
        _autoStreamTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() => { AddStreamPoint(); });
        }, null, 0, 700); // Interval > animation duration (300ms) to avoid overlap
    }

    void StopAutoStream()
    {
        _autoStreamTimer?.Dispose();
        _autoStreamTimer = null;
    }

    // ── Advanced tab data ──
    List<BubblePoint> _bubbleData = Enumerable.Range(0, 25).Select(i =>
    {
        var rng = new Random(i + 100);
        return new BubblePoint(
            Math.Round(rng.NextDouble() * 200 + 50, 1),
            Math.Round(rng.NextDouble() * 150 + 20, 1),
            Math.Round(rng.NextDouble() * 20 + 3, 1));
    }).ToList();

    List<GaugeThreshold> _scoreThresholds = new()
    {
        new() { Value = 0, Color = "var(--arcadia-color-danger)" },
        new() { Value = 400, Color = "var(--arcadia-color-warning)" },
        new() { Value = 700, Color = "var(--arcadia-color-success)" },
    };

    protected override void OnInitialized()
    {
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var hours = new[] { "9am", "10am", "11am", "12pm", "1pm", "2pm", "3pm", "4pm", "5pm" };
        var rng = new Random(42);
        foreach (var day in days)
            foreach (var hour in hours)
                _heatmapData.Add(new HeatmapPoint(day, hour, rng.Next(0, (day is "Sat" or "Sun" ? 2 : 8) + 5)));

        var stockRng = new Random(123);
        var price = 142.50;
        var closes = new List<double>();
        for (var i = 0; i < 30; i++)
        {
            var change = (stockRng.NextDouble() - 0.48) * 4;
            var open = price; var close = price + change;
            var high = Math.Max(open, close) + stockRng.NextDouble() * 2;
            var low = Math.Min(open, close) - stockRng.NextDouble() * 2;
            closes.Add(close);
            var ma5 = closes.Count >= 5 ? closes.Skip(closes.Count - 5).Take(5).Average() : double.NaN;
            _stockData.Add(new StockCandle(new DateTime(2026, 2, 20).AddDays(i).ToString("MMM d"),
                Math.Round(open, 2), Math.Round(high, 2), Math.Round(low, 2), Math.Round(close, 2), Math.Round(ma5, 2)));
            price = close;
        }
    }
}

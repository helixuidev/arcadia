                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="Features">
                        <div style="padding: 16px 0; color: #9490b3;">Feature details go here. Each panel is lazily rendered — only the active panel is in the DOM.</div>
                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="API Reference">
                        <div style="padding: 16px 0; color: #9490b3;">API documentation content. Parameters, events, and code examples.</div>
                    </ArcadiaTabPanel>
                    <ArcadiaTabPanel Title="Disabled" Disabled="true">
                        <div>This panel is disabled.</div>
                    </ArcadiaTabPanel>
                </ArcadiaTabs>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Tooltip</div>
                <div style="display: flex; gap: 32px; align-items: center; padding: 24px 0;">
                    <ArcadiaTooltip Text="Tooltip on top (default)" Position="top">

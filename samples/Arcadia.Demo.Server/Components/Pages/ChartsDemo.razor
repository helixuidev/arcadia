@page "/charts"

<PageTitle>HelixUI Demo — Charts</PageTitle>

<h1>Charts & Dashboard Widgets</h1>
<p style="color: var(--arcadia-color-text-muted); margin-bottom: var(--arcadia-spacing-lg);">
    Dashboard analytics toolkit — pre-composed widgets and SVG charts with zero JS dependencies.
</p>

<h2>KPI Cards</h2>
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--arcadia-spacing-md); margin-bottom: var(--arcadia-spacing-xl);">
    <HelixKpiCard Title="Monthly Revenue" Value="$142,500" Delta="+12.3%" DeltaType="DeltaType.Increase"
                  Sparkline="@_revenueSparkline" Footer="vs last month" />
    <HelixKpiCard Title="Active Users" Value="8,420" Delta="-2.1%" DeltaType="DeltaType.Decrease"
                  Sparkline="@_usersSparkline" SparklineColor="danger" Footer="vs last week" />
    <HelixKpiCard Title="Conversion Rate" Value="3.8%" Delta="+0.5%" DeltaType="DeltaType.Increase"
                  Sparkline="@_conversionSparkline" SparklineColor="success" />
    <HelixKpiCard Title="Avg Response Time" Value="142ms" Delta="→ 0%" DeltaType="DeltaType.Neutral"
                  Footer="No change" />
</div>

<h2>Progress & Indicators</h2>
<div style="max-width: 400px; display: flex; flex-direction: column; gap: var(--arcadia-spacing-md); margin-bottom: var(--arcadia-spacing-xl);">
    <HelixProgressBar Value="73" Max="100" Label="Storage Used" Thresholds="@_storageThresholds" />
    <HelixProgressBar Value="45" Max="100" Label="CPU Usage" Color="info" />
    <HelixProgressBar Value="92" Max="100" Label="Memory" Thresholds="@_storageThresholds" />
</div>

<h2>Bar List</h2>
<div style="max-width: 400px; margin-bottom: var(--arcadia-spacing-xl);">
    <HelixBarList TItem="ProductSale" Data="@_topProducts" NameField="@(d => d.Name)" ValueField="@(d => d.Sales)" ValueFormat="$#,##0" Color="primary" />
</div>

<h2>Category Bar</h2>
<div style="max-width: 500px; margin-bottom: var(--arcadia-spacing-xl);">
    <HelixCategoryBar TItem="BudgetItem" Data="@_budget" NameField="@(d => d.Category)" ValueField="@(d => d.Amount)" />
</div>

<h2>Sparklines</h2>
<div style="display: flex; gap: var(--arcadia-spacing-lg); align-items: center; margin-bottom: var(--arcadia-spacing-xl);">
    <span>Revenue: <HelixSparkline Data="@_revenueSparkline" Color="primary" ShowArea="true" /></span>
    <span>Users: <HelixSparkline Data="@_usersSparkline" Color="danger" /></span>
    <span>Growth: <HelixSparkline Data="@_conversionSparkline" Color="success" ShowArea="true" /></span>
</div>

<hr style="margin: var(--arcadia-spacing-xl) 0; border-color: var(--arcadia-color-border);" />

<h2>Line Chart</h2>
<HelixLineChart TItem="MonthlySales" Data="@_monthlySales" XField="@(d => (object)d.Month)" Title="Revenue vs Target"
                Series="@_lineSeries" ShowPoints="true" Height="320" Width="700" />

<h2 style="margin-top: var(--arcadia-spacing-xl);">Bar Chart</h2>
<HelixBarChart TItem="QuarterlySales" Data="@_quarterlySales" XField="@(d => (object)d.Quarter)" Title="Quarterly Sales by Region"
               Series="@_barSeries" Height="320" Width="700" />

<h2 style="margin-top: var(--arcadia-spacing-xl);">Pie Chart</h2>
<HelixPieChart TItem="BudgetItem" Data="@_budget" NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
               Title="Budget Allocation" Height="350" Width="500" />

<h2 style="margin-top: var(--arcadia-spacing-xl);">Donut Chart</h2>
<HelixPieChart TItem="BudgetItem" Data="@_budget" NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
               Title="Budget (Donut)" InnerRadius="70" Height="350" Width="500" />

<h2 style="margin-top: var(--arcadia-spacing-xl);">Scatter Chart with Trendline</h2>
<HelixScatterChart TItem="DataXY" Data="@_scatterData" XField="@(d => d.X)" YField="@(d => d.Y)"
                   Title="Height vs Weight" Height="320" Width="700" Color="primary" />

<hr style="margin: var(--arcadia-spacing-xl) 0; border-color: var(--arcadia-color-border);" />

<h2>Phase 2 — Pro Charts</h2>
<p style="color: var(--arcadia-color-text-muted); margin-bottom: var(--arcadia-spacing-md);">
    Radar, Gauge, and Heatmap — chart types no free Blazor library offers.
</p>

<h3>Stacked Bar Chart</h3>
<HelixBarChart TItem="QuarterlySales" Data="@_quarterlySales" XField="@(d => (object)d.Quarter)" Title="Quarterly Revenue — Stacked"
               Series="@_barSeries" Height="320" Width="700" Stacked="true" />

<h3 style="margin-top: var(--arcadia-spacing-xl);">Line Chart with Trendline + Data Labels</h3>
<HelixLineChart TItem="MonthlySales" Data="@_monthlySales" XField="@(d => (object)d.Month)" Title="Revenue with Trend"
                Series="@_trendSeries" ShowPoints="true" ShowDataLabels="true" DataLabelFormatString="C0"
                Height="320" Width="700" />

<h3 style="margin-top: var(--arcadia-spacing-xl);">Gauge Charts</h3>
<div style="display: flex; gap: var(--arcadia-spacing-lg); flex-wrap: wrap; margin-bottom: var(--arcadia-spacing-xl);">
    <HelixGaugeChart Value="73" Min="0" Max="100" Label="CPU Usage" Width="200" Height="160"
                     Thresholds="@_gaugeThresholds" />
    <HelixGaugeChart Value="42" Min="0" Max="100" Label="Memory" Width="200" Height="160"
                     ValueFormatString="0'%'" />
    <HelixGaugeChart Value="91" Min="0" Max="100" Label="Disk" Width="200" Height="160"
                     Thresholds="@_gaugeThresholds" />
</div>

<h3>Radar Chart</h3>
<HelixRadarChart TItem="SkillProfile" Data="@_skillData" LabelField="@(d => d.Skill)"
                 Series="@_radarSeries" Title="Team Skills Comparison"
                 Height="380" Width="500" />

<h3 style="margin-top: var(--arcadia-spacing-xl);">Heatmap</h3>
<HelixHeatmap TItem="HeatmapPoint" Data="@_heatmapData" XField="@(d => d.Day)" YField="@(d => d.Hour)"
              ValueField="@(d => d.Count)" Title="Commits by Day & Hour"
              Height="300" Width="700" ShowValues="false" />

<hr style="margin: var(--arcadia-spacing-xl) 0; border-color: var(--arcadia-color-border);" />

<h2>Candlestick Chart with Moving Average Overlay</h2>
<p style="color: var(--arcadia-color-text-muted); margin-bottom: var(--arcadia-spacing-md);">
    Financial OHLC candlestick chart with a 5-period moving average line overlay — mixed chart types in one view.
</p>

<HelixCandlestickChart TItem="StockCandle" Data="@_stockData"
                        LabelField="@(d => d.Date)"
                        OpenField="@(d => d.Open)" HighField="@(d => d.High)"
                        LowField="@(d => d.Low)" CloseField="@(d => d.Close)"
                        OverlaySeries="@_maSeries"
                        Title="ACME Corp — 30 Day Price"
                        YAxisFormatString="F2"
                        Height="400" Width="700" />

@code {
    // Data models
    record MonthlySales(string Month, double Revenue, double Target);
    record QuarterlySales(string Quarter, double NorthAmerica, double Europe, double Asia);
    record ProductSale(string Name, double Sales);
    record BudgetItem(string Category, double Amount);
    record DataXY(double X, double Y);
    record SkillProfile(string Skill, double TeamA, double TeamB);
    record HeatmapPoint(string Day, string Hour, double Count);
    record StockCandle(string Date, double Open, double High, double Low, double Close, double MA5);

    // Sparkline data
    double[] _revenueSparkline = { 42, 48, 45, 52, 49, 55, 58, 62, 59, 65, 68, 72 };
    double[] _usersSparkline = { 85, 82, 88, 84, 80, 78, 82, 79, 76, 74, 78, 72 };
    double[] _conversionSparkline = { 2.1, 2.3, 2.5, 2.4, 2.8, 3.0, 2.9, 3.2, 3.4, 3.5, 3.6, 3.8 };

    IReadOnlyList<(double Threshold, string Color)> _storageThresholds = new[] { (60.0, "warning"), (90.0, "danger") };

    // Dashboard data
    List<ProductSale> _topProducts = new()
    {
        new("Enterprise Suite", 48500),
        new("Pro License", 32000),
        new("Starter Plan", 18200),
        new("Add-on Pack", 12800),
        new("Training", 5400),
    };

    List<BudgetItem> _budget = new()
    {
        new("Engineering", 450000),
        new("Marketing", 180000),
        new("Sales", 220000),
        new("Operations", 120000),
        new("HR", 80000),
    };

    // Chart data
    List<MonthlySales> _monthlySales = new()
    {
        new("Jan", 45000, 50000), new("Feb", 52000, 50000), new("Mar", 48000, 52000),
        new("Apr", 61000, 55000), new("May", 55000, 55000), new("Jun", 67000, 58000),
        new("Jul", 72000, 60000), new("Aug", 68000, 62000), new("Sep", 75000, 65000),
        new("Oct", 82000, 68000), new("Nov", 79000, 70000), new("Dec", 88000, 72000),
    };

    List<SeriesConfig<MonthlySales>> _lineSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary", ShowArea = true },
        new() { Name = "Target", Field = d => d.Target, Color = "secondary", Dashed = true },
    };

    List<QuarterlySales> _quarterlySales = new()
    {
        new("Q1", 145000, 98000, 72000),
        new("Q2", 183000, 112000, 89000),
        new("Q3", 215000, 134000, 105000),
        new("Q4", 268000, 156000, 128000),
    };

    List<SeriesConfig<QuarterlySales>> _barSeries = new()
    {
        new() { Name = "North America", Field = d => d.NorthAmerica, Color = "primary" },
        new() { Name = "Europe", Field = d => d.Europe, Color = "success" },
        new() { Name = "Asia", Field = d => d.Asia, Color = "warning" },
    };

    List<DataXY> _scatterData = Enumerable.Range(0, 50).Select(i =>
    {
        var rng = new Random(i);
        return new DataXY(150 + rng.NextDouble() * 50, 50 + rng.NextDouble() * 60);
    }).ToList();

    // Phase 2 data — Trendline series
    List<SeriesConfig<MonthlySales>> _trendSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary",
                Trendline = new() { Type = TrendlineType.Linear, Color = "var(--arcadia-color-danger)", Dashed = true } },
    };

    // Gauge thresholds
    List<GaugeThreshold> _gaugeThresholds = new()
    {
        new() { Value = 0, Color = "var(--arcadia-color-success)" },
        new() { Value = 60, Color = "var(--arcadia-color-warning)" },
        new() { Value = 85, Color = "var(--arcadia-color-danger)" },
    };

    // Radar data
    List<SkillProfile> _skillData = new()
    {
        new("C#", 90, 70),
        new("JavaScript", 65, 85),
        new("SQL", 80, 60),
        new("DevOps", 50, 75),
        new("Design", 40, 80),
        new("Testing", 75, 65),
    };

    List<SeriesConfig<SkillProfile>> _radarSeries = new()
    {
        new() { Name = "Team A", Field = d => d.TeamA, Color = "primary" },
        new() { Name = "Team B", Field = d => d.TeamB, Color = "success" },
    };

    // Heatmap data
    List<HeatmapPoint> _heatmapData = new();

    // Candlestick data
    List<StockCandle> _stockData = new();
    List<SeriesConfig<StockCandle>> _maSeries = new()
    {
        new() { Name = "MA(5)", Field = d => d.MA5, Color = "var(--arcadia-color-info)", StrokeWidth = 1.5 },
    };

    protected override void OnInitialized()
    {
        // Heatmap
        var days = new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
        var hours = new[] { "9am", "10am", "11am", "12pm", "1pm", "2pm", "3pm", "4pm", "5pm" };
        var rng = new Random(42);
        foreach (var day in days)
        {
            foreach (var hour in hours)
            {
                var isWeekend = day is "Sat" or "Sun";
                var baseCount = isWeekend ? 2 : 8;
                _heatmapData.Add(new HeatmapPoint(day, hour, rng.Next(0, baseCount + 5)));
            }
        }

        // Stock data — generate 30 days of realistic OHLC
        var stockRng = new Random(123);
        var price = 142.50;
        var closes = new List<double>();
        for (var i = 0; i < 30; i++)
        {
            var change = (stockRng.NextDouble() - 0.48) * 4; // Slight upward bias
            var open = price;
            var close = price + change;
            var high = Math.Max(open, close) + stockRng.NextDouble() * 2;
            var low = Math.Min(open, close) - stockRng.NextDouble() * 2;
            closes.Add(close);

            // Calculate 5-period moving average
            var ma5 = double.NaN;
            if (closes.Count >= 5)
                ma5 = closes.Skip(closes.Count - 5).Take(5).Average();

            _stockData.Add(new StockCandle(
                new DateTime(2026, 2, 20).AddDays(i).ToString("MMM d"),
                Math.Round(open, 2), Math.Round(high, 2),
                Math.Round(low, 2), Math.Round(close, 2),
                Math.Round(ma5, 2)));

            price = close;
        }
    }
}

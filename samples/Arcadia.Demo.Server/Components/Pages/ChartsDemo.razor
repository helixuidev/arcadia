    void HandleWizardDone() => ToastService.ShowSuccess($"Wizard complete! Name: {_wName}", "Done");

    record MonthlySales(string Month, double Revenue, double Target);
    record QuarterlySales(string Quarter, double NorthAmerica, double Europe, double Asia);
    record BudgetItem(string Category, double Amount);
    record DataXY(double X, double Y);
    record BubblePoint(double X, double Y, double Size);
    record SkillProfile(string Skill, double TeamA, double TeamB);
    record HeatmapPoint(string Day, string Hour, double Count);
    record StockCandle(string Date, double Open, double High, double Low, double Close, double MA5);
    record WindData(string Direction, double Speed);
    record NullablePoint(string Label, double Value);
    record StreamPoint(string Time, double Value);

    double[] _revenueSparkline = { 42, 48, 45, 52, 49, 55, 58, 62, 59, 65, 68, 72 };
    double[] _usersSparkline = { 85, 82, 88, 84, 80, 78, 82, 79, 76, 74, 78, 72 };
    double[] _conversionSparkline = { 2.1, 2.3, 2.5, 2.4, 2.8, 3.0, 2.9, 3.2, 3.4, 3.5, 3.6, 3.8 };
    IReadOnlyList<(double Threshold, string Color)> _thresholds = new[] { (60.0, "warning"), (90.0, "danger") };

    List<MonthlySales> _monthlySales = new()
    {
        new("Jan", 45000, 50000), new("Feb", 52000, 50000), new("Mar", 48000, 52000),
        new("Apr", 61000, 55000), new("May", 55000, 55000), new("Jun", 67000, 58000),
        new("Jul", 72000, 60000), new("Aug", 68000, 62000), new("Sep", 75000, 65000),
        new("Oct", 82000, 68000), new("Nov", 79000, 70000), new("Dec", 88000, 72000),
    };
    List<SeriesConfig<MonthlySales>> _lineSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary", ShowArea = true, AreaOpacity = 0.1, CurveType = "smooth" },
        new() { Name = "Target", Field = d => d.Target, Color = "secondary", Dashed = true, StrokeWidth = 1.5, CurveType = "smooth" },
    };
    List<SeriesConfig<MonthlySales>> _comboSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary", SeriesType = "bar" },
        new() { Name = "Target", Field = d => d.Target, Color = "danger", Dashed = true },
    };
    List<SeriesConfig<MonthlySales>> _stackedSeries = new()
    {
        new() { Name = "Product A", Field = d => d.Revenue * 0.5, Color = "primary", ShowArea = true, AreaOpacity = 0.6 },
        new() { Name = "Product B", Field = d => d.Revenue * 0.3, Color = "success", ShowArea = true, AreaOpacity = 0.6 },
        new() { Name = "Product C", Field = d => d.Target * 0.2, Color = "warning", ShowArea = true, AreaOpacity = 0.6 },
    };
    List<SeriesConfig<MonthlySales>> _trendSeries = new()
    {
        new() { Name = "Revenue", Field = d => d.Revenue, Color = "primary",
                Trendline = new() { Type = TrendlineType.Linear, Color = "var(--arcadia-color-danger)", Dashed = true } },
    };

    List<QuarterlySales> _quarterlySales = new()
    {
        new("Q1", 145000, 98000, 72000), new("Q2", 183000, 112000, 89000),
        new("Q3", 215000, 134000, 105000), new("Q4", 268000, 156000, 128000),
    };
    List<SeriesConfig<QuarterlySales>> _barSeries = new()
    {
        new() { Name = "North America", Field = d => d.NorthAmerica, Color = "primary" },
        new() { Name = "Europe", Field = d => d.Europe, Color = "success" },
        new() { Name = "Asia", Field = d => d.Asia, Color = "warning" },
    };

    List<BudgetItem> _budget = new()
    {
        new("Engineering", 450000), new("Marketing", 180000), new("Sales", 220000),
        new("Operations", 120000), new("HR", 80000),
    };

    List<DataXY> _scatterData = Enumerable.Range(0, 50).Select(i =>
    {
        var rng = new Random(i);
        return new DataXY(150 + rng.NextDouble() * 50, 50 + rng.NextDouble() * 60);
    }).ToList();

    List<GaugeThreshold> _gaugeThresholds = new()
    {
        new() { Value = 0, Color = "var(--arcadia-color-success)" },
        new() { Value = 60, Color = "var(--arcadia-color-warning)" },
        new() { Value = 85, Color = "var(--arcadia-color-danger)" },
    };

    List<SkillProfile> _skillData = new()
    {

                    </ArcadiaTooltip>
                    <ArcadiaTooltip Text="Tooltip on the right" Position="right">
                        <button style="padding: 8px 16px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.2); background: rgba(139,92,246,0.06); color: #e2e0f0; cursor: pointer;">Right</button>
                    </ArcadiaTooltip>
                    <ArcadiaTooltip Text="Tooltip on the bottom" Position="bottom">

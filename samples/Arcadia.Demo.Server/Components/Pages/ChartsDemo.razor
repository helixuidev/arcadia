            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Accordion</div>
                <ArcadiaAccordion>
                    <ArcadiaAccordionItem Title="What is Arcadia Controls?">
                        <p style="color: #9490b3; margin: 0;">Arcadia Controls is a commercial Blazor component library with charts, DataGrid, forms, and UI components. Pure C# rendering with zero JavaScript.</p>
                    </ArcadiaAccordionItem>
                    <ArcadiaAccordionItem Title="How do I install it?">
                        <p style="color: #9490b3; margin: 0;">Run <code style="color: #c084fc;">dotnet add package Arcadia.Charts</code> and add the CSS link to your App.razor.</p>
                    </ArcadiaAccordionItem>
                    <ArcadiaAccordionItem Title="Is it free?">
                        <p style="color: #9490b3; margin: 0;">Community Edition includes 4 chart types for free. Pro ($299/dev/year) adds all 16 charts, DataGrid, Form Builder, and more.</p>
                    </ArcadiaAccordionItem>
                </ArcadiaAccordion>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Breadcrumb</div>
                <ArcadiaBreadcrumb>
                    <ArcadiaBreadcrumbItem Href="/">Home</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem Href="/docs">Documentation</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem Href="/docs/charts">Charts</ArcadiaBreadcrumbItem>
                    <ArcadiaBreadcrumbItem>Line Chart</ArcadiaBreadcrumbItem>
                </ArcadiaBreadcrumb>
            </div>
        }

        @* ─── NOTIFICATIONS ─── *@

        @if (_tab == "toasts")
        {
            <div class="gallery__section-header">
                <h1>Toast Notifications</h1>
                <p>Fire-and-forget toasts with auto-dismiss, stacking, and severity levels.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Trigger Toasts</div>
                <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                    <button class="gallery__toast-btn gallery__toast-btn--info" @onclick='() => ToastService.ShowInfo("This is an informational message.")'>Info</button>
                    <button class="gallery__toast-btn gallery__toast-btn--success" @onclick='() => ToastService.ShowSuccess("Operation completed successfully.")'>Success</button>
                    <button class="gallery__toast-btn gallery__toast-btn--warning" @onclick='() => ToastService.ShowWarning("Please review before proceeding.")'>Warning</button>
                    <button class="gallery__toast-btn gallery__toast-btn--error" @onclick='() => ToastService.ShowError("Something went wrong.")'>Error</button>
                    <button class="gallery__toast-btn" @onclick='() => ToastService.ShowSuccess("Your changes have been saved.", "Saved!")'>With Title</button>
                    <button class="gallery__toast-btn" @onclick="ToastService.DismissAll">Dismiss All</button>
                </div>
            </div>
        }

    </div>

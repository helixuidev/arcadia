@page "/charts"
@page "/"
@layout Arcadia.Demo.Server.Components.Layout.FullScreenLayout
@using Arcadia.Charts.Core
@using Arcadia.Charts.Components.Charts
@using Arcadia.Charts.Components.Dashboard
@using Arcadia.DataGrid.Components
@using Arcadia.DataGrid.Core
@using Arcadia.UI.Components
@using Arcadia.FormBuilder.Schema
@using Arcadia.FormBuilder.Components
@using Arcadia.FormBuilder.Components.Fields
@using Arcadia.FormBuilder.Components.Layout
@inject Arcadia.Notifications.ToastService ToastService

<PageTitle>Arcadia Controls — Component Gallery</PageTitle>

<div class="gallery">
    <div class="gallery__sidebar">
        <h2 class="gallery__title">Arcadia Controls</h2>
        <p class="gallery__subtitle">Component Gallery</p>
        <nav class="gallery__nav">
            <button class="gallery__nav-btn gallery__nav-btn--home @(_tab == "home" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "home"' style="font-weight:600;margin-bottom:8px;">Home</button>

            <div class="gallery__nav-group">Charts</div>
            <button class="gallery__nav-btn @(_tab == "dashboard" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dashboard"'>Dashboard Widgets</button>
            <button class="gallery__nav-btn @(_tab == "line" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "line"'>Line & Area</button>
            <button class="gallery__nav-btn @(_tab == "bar" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "bar"'>Bar</button>
            <button class="gallery__nav-btn @(_tab == "pie" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "pie"'>Pie & Donut</button>
            <button class="gallery__nav-btn @(_tab == "scatter" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "scatter"'>Scatter</button>
            <button class="gallery__nav-btn @(_tab == "candle" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "candle"'>Candlestick</button>
            <button class="gallery__nav-btn @(_tab == "gauge" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "gauge"'>Gauges</button>
            <button class="gallery__nav-btn @(_tab == "radar" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "radar"'>Radar</button>
            <button class="gallery__nav-btn @(_tab == "heatmap" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "heatmap"'>Heatmap</button>
            <button class="gallery__nav-btn @(_tab == "rose" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "rose"'>Rose / Polar</button>
            <button class="gallery__nav-btn @(_tab == "boxplot" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "boxplot"'>Box Plot</button>
            <button class="gallery__nav-btn @(_tab == "rangearea" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "rangearea"'>Range Area</button>
            <button class="gallery__nav-btn @(_tab == "interactive" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "interactive"'>Interactive</button>
            <button class="gallery__nav-btn @(_tab == "streaming" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "streaming"'>Streaming</button>
            <button class="gallery__nav-btn @(_tab == "sankey" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "sankey"'>Sankey</button>
            <button class="gallery__nav-btn @(_tab == "chord" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "chord"'>Chord</button>
            <button class="gallery__nav-btn @(_tab == "advanced" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "advanced"'>Advanced</button>

            <div class="gallery__nav-group">DataGrid</div>
            <button class="gallery__nav-btn @(_tab == "dg-basics" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dg-basics"'>Basics</button>
            <button class="gallery__nav-btn @(_tab == "dg-editing" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dg-editing"'>Editing</button>
            <button class="gallery__nav-btn @(_tab == "dg-advanced" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dg-advanced"'>Advanced</button>
            <button class="gallery__nav-btn @(_tab == "dg-enterprise" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "dg-enterprise"'>Enterprise</button>

            <div class="gallery__nav-group">Forms</div>
            <button class="gallery__nav-btn @(_tab == "fields" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "fields"'>Field Types</button>
            <button class="gallery__nav-btn @(_tab == "schema" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "schema"'>Schema Form</button>
            <button class="gallery__nav-btn @(_tab == "wizard" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "wizard"'>Wizard</button>

            <div class="gallery__nav-group">UI Components</div>
            <button class="gallery__nav-btn @(_tab == "ui" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "ui"'>Dialog / Tabs / Tooltip</button>
            <button class="gallery__nav-btn @(_tab == "toasts" ? "gallery__nav-btn--active" : "")" @onclick='() => _tab = "toasts"'>Notifications</button>

            <div class="gallery__nav-group">Tools</div>
            <a href="/playground-builder" class="gallery__nav-btn" style="text-decoration: none;">Playground Builder</a>
        </nav>
        <div class="gallery__cta">
            <a href="https://arcadiaui.com" class="gallery__admin-link" target="_blank">arcadiaui.com →</a>
        </div>
    </div>

    <div class="gallery__content">

        @if (_tab == "home")
        {
            <div style="max-width: 820px; margin: 0 auto; padding: 60px 32px 48px;">

                <div style="margin-bottom: 56px;">
                    <h1 style="font-size: 2.75rem; font-weight: 800; letter-spacing: -0.035em; line-height: 1.1; margin: 0 0 16px; outline: none;">
                        <span style="background: linear-gradient(135deg, #8b5cf6 0%, #c084fc 50%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Arcadia Controls</span>
                    </h1>
                    <p style="font-size: 1.125rem; color: #8a86a8; line-height: 1.75; margin: 0; max-width: 580px;">
                        Enterprise Blazor components for .NET. Charts, DataGrid, Forms, and UI primitives — accessible, themeable, zero JavaScript.
                    </p>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 56px;">

                    <button @onclick='() => _tab = "dashboard"' style="background: rgba(139,92,246,0.04); border: 1px solid rgba(139,92,246,0.12); border-radius: 16px; padding: 32px; text-align: left; cursor: pointer; transition: all 0.2s; color: inherit; font-family: inherit;" onmouseover="this.style.borderColor='rgba(139,92,246,0.35)';this.style.background='rgba(139,92,246,0.07)'" onmouseout="this.style.borderColor='rgba(139,92,246,0.12)';this.style.background='rgba(139,92,246,0.04)'">
                        <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #8b5cf6, #7c3aed); display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        </div>
                        <div style="font-size: 1.0625rem; font-weight: 600; color: #f1f0f9; margin-bottom: 8px;">Charts & Dashboard</div>
                        <div style="font-size: 0.8125rem; color: #6b6890; line-height: 1.65; margin-bottom: 16px;">16 chart types and 7 dashboard widgets. Pure SVG rendering with zero JavaScript dependencies.</div>
                        <div style="font-size: 0.8125rem; color: #8b5cf6; font-weight: 500;">Explore charts <span style="margin-left: 2px;">&#8594;</span></div>
                    </button>

                    <button @onclick='() => _tab = "dg-basics"' style="background: rgba(34,211,238,0.03); border: 1px solid rgba(34,211,238,0.12); border-radius: 16px; padding: 32px; text-align: left; cursor: pointer; transition: all 0.2s; color: inherit; font-family: inherit;" onmouseover="this.style.borderColor='rgba(34,211,238,0.35)';this.style.background='rgba(34,211,238,0.06)'" onmouseout="this.style.borderColor='rgba(34,211,238,0.12)';this.style.background='rgba(34,211,238,0.03)'">
                        <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #22d3ee, #0891b2); display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                        </div>
                        <div style="font-size: 1.0625rem; font-weight: 600; color: #f1f0f9; margin-bottom: 8px;">DataGrid</div>
                        <div style="font-size: 0.8125rem; color: #6b6890; line-height: 1.65; margin-bottom: 16px;">Multi-column sort, quick filter, batch editing, virtual scrolling, state persistence, and 6 built-in themes.</div>
                        <div style="font-size: 0.8125rem; color: #22d3ee; font-weight: 500;">Explore grid <span style="margin-left: 2px;">&#8594;</span></div>
                    </button>

                    <button @onclick='() => _tab = "fields"' style="background: rgba(236,72,153,0.03); border: 1px solid rgba(236,72,153,0.12); border-radius: 16px; padding: 32px; text-align: left; cursor: pointer; transition: all 0.2s; color: inherit; font-family: inherit;" onmouseover="this.style.borderColor='rgba(236,72,153,0.35)';this.style.background='rgba(236,72,153,0.06)'" onmouseout="this.style.borderColor='rgba(236,72,153,0.12)';this.style.background='rgba(236,72,153,0.03)'">
                        <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #ec4899, #db2777); display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        </div>
                        <div style="font-size: 1.0625rem; font-weight: 600; color: #f1f0f9; margin-bottom: 8px;">Form Builder</div>
                        <div style="font-size: 0.8125rem; color: #6b6890; line-height: 1.65; margin-bottom: 16px;">20+ field types with schema-driven and model-driven forms, wizard mode, validation, and conditional fields.</div>
                        <div style="font-size: 0.8125rem; color: #ec4899; font-weight: 500;">Explore forms <span style="margin-left: 2px;">&#8594;</span></div>
                    </button>

                    <button @onclick='() => _tab = "toasts"' style="background: rgba(250,204,21,0.03); border: 1px solid rgba(250,204,21,0.10); border-radius: 16px; padding: 32px; text-align: left; cursor: pointer; transition: all 0.2s; color: inherit; font-family: inherit;" onmouseover="this.style.borderColor='rgba(250,204,21,0.30)';this.style.background='rgba(250,204,21,0.06)'" onmouseout="this.style.borderColor='rgba(250,204,21,0.10)';this.style.background='rgba(250,204,21,0.03)'">
                        <div style="width: 44px; height: 44px; border-radius: 12px; background: linear-gradient(135deg, #facc15, #eab308); display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a4 4 0 00-8 0v2"/><circle cx="12" cy="15" r="1"/></svg>
                        </div>
                        <div style="font-size: 1.0625rem; font-weight: 600; color: #f1f0f9; margin-bottom: 8px;">UI Components</div>
                        <div style="font-size: 0.8125rem; color: #6b6890; line-height: 1.65; margin-bottom: 16px;">Dialog, Tabs, Tooltip, Sidebar, Accordion, Breadcrumb, Card, Badge, Avatar, and Toast notifications.</div>
                        <div style="font-size: 0.8125rem; color: #eab308; font-weight: 500;">Explore UI <span style="margin-left: 2px;">&#8594;</span></div>
                    </button>

                </div>

                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-bottom: 56px; padding: 32px 0; border-top: 1px solid rgba(139,92,246,0.08); border-bottom: 1px solid rgba(139,92,246,0.08); text-align: center;">
                    <div>
                        <div style="font-size: 2.25rem; font-weight: 800; background: linear-gradient(135deg, #8b5cf6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1;">57+</div>
                        <div style="font-size: 0.6875rem; color: #6b6890; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 8px;">Components</div>
                    </div>
                    <div>
                        <div style="font-size: 2.25rem; font-weight: 800; background: linear-gradient(135deg, #8b5cf6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1;">973</div>
                        <div style="font-size: 0.6875rem; color: #6b6890; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 8px;">Unit Tests</div>
                    </div>
                    <div>
                        <div style="font-size: 2.25rem; font-weight: 800; background: linear-gradient(135deg, #8b5cf6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1;">7</div>
                        <div style="font-size: 0.6875rem; color: #6b6890; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 8px;">Packages</div>
                    </div>
                    <div>
                        <div style="font-size: 2.25rem; font-weight: 800; background: linear-gradient(135deg, #8b5cf6, #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1;">0</div>
                        <div style="font-size: 0.6875rem; color: #6b6890; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 8px;">KB JavaScript</div>
                    </div>
                </div>

                <div style="background: rgba(139,92,246,0.04); border: 1px solid rgba(139,92,246,0.10); border-radius: 14px; padding: 28px 32px;">
                    <div style="font-size: 0.75rem; font-weight: 600; color: #8b5cf6; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 16px;">Quick Install</div>
                    <pre style="margin: 0; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.8125rem; color: #c4c0e0; line-height: 2;"><code>dotnet add package Arcadia.Charts
dotnet add package Arcadia.DataGrid
dotnet add package Arcadia.FormBuilder
dotnet add package Arcadia.UI
dotnet add package Arcadia.Theme</code></pre>
                </div>
            </div>
        }

        @if (_tab == "dashboard")
        {
            <div class="gallery__section-header">
                <h1>Dashboard Widgets</h1>
                <p>Pre-composed widgets that look great out of the box. Drop them into any layout — no chart configuration needed.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">KPI Cards with Sparklines</div>
                <div class="gallery__widget-grid">
                    <ArcadiaKpiCard Title="Monthly Revenue" Value="$142,580" Delta="+12.3%" DeltaType="DeltaType.Increase"
                                  Sparkline="@_revenueSparkline" Footer="vs last month" />
                    <ArcadiaKpiCard Title="Active Users" Value="8,420" Delta="-2.1%" DeltaType="DeltaType.Decrease"
                                  Sparkline="@_usersSparkline" SparklineColor="danger" Footer="vs last week" />
                    <ArcadiaKpiCard Title="Conversion Rate" Value="3.8%" Delta="+0.5%" DeltaType="DeltaType.Increase"
                                  Sparkline="@_conversionSparkline" SparklineColor="success" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Progress Indicators</div>
                <div class="gallery__progress-stack">
                    <ArcadiaProgressBar Value="73" Max="100" Label="Storage Used" Thresholds="@_thresholds" />
                    <ArcadiaProgressBar Value="45" Max="100" Label="CPU Usage" Color="info" />
                    <ArcadiaProgressBar Value="92" Max="100" Label="Memory" Thresholds="@_thresholds" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Inline Sparklines</div>
                <div class="gallery__sparkline-row">
                    <span>Revenue <ArcadiaSparkline Data="@_revenueSparkline" Color="primary" ShowArea="true" /></span>
                    <span>Users <ArcadiaSparkline Data="@_usersSparkline" Color="danger" /></span>
                    <span>Growth <ArcadiaSparkline Data="@_conversionSparkline" Color="success" ShowArea="true" /></span>
                </div>
            </div>
        }

        @if (_tab == "line")
        {
            <div class="gallery__section-header">
                <h1>Line & Area Chart</h1>
                <p>Multi-series with area fill, dashed lines, and trendline overlays. Lines draw themselves on load.</p>
                <div class="gallery__hint">💡 Hover points for values · Click legend to toggle series</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Revenue vs Target — 12 Months</div>
                <div class="gallery__chart-container">
                    <ArcadiaLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_lineSeries"
                                    Height="380" Width="0" ShowPoints="true" AnimateOnLoad="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Stacked Area</div>
                <div class="gallery__chart-container">
                    <ArcadiaLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_stackedSeries"
                                    Height="380" Width="0" Stacked="true" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Combo — Bar + Line on Same Axes</div>
                <div class="gallery__chart-container">
                    <ArcadiaLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_comboSeries"
                                    Height="380" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">With Trendline Overlay</div>
                <div class="gallery__chart-container">
                    <ArcadiaLineChart TItem="MonthlySales" Data="@_monthlySales"
                                    XField="@(d => (object)d.Month)" Series="@_trendSeries"
                                    Height="380" Width="0" ShowDataLabels="true" />
                </div>
            </div>
        }

        @if (_tab == "bar")
        {
            <div class="gallery__section-header">
                <h1>Bar Chart</h1>
                <p>Grouped or stacked bars with rounded corners. Bars grow from baseline on load.</p>
                <div class="gallery__hint">💡 Hover bars for tooltips · Click legend to toggle regions</div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Quarterly Revenue — Grouped by Region</div>
                <div class="gallery__chart-container">
                    <ArcadiaBarChart TItem="QuarterlySales" Data="@_quarterlySales"
                                   XField="@(d => (object)d.Quarter)" Series="@_barSeries"
                                   Height="380" Width="0" />
                </div>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Same Data — Stacked</div>
                <div class="gallery__chart-container">
                    <ArcadiaBarChart TItem="QuarterlySales" Data="@_quarterlySales"
                                   XField="@(d => (object)d.Quarter)" Series="@_barSeries"
                                   Height="380" Width="0" Stacked="true" />
                </div>
            </div>
        }

        @if (_tab == "pie")
        {
            <div class="gallery__section-header">
                <h1>Pie & Donut</h1>
                <p>Animated slices with configurable labels. Set InnerRadius for donut mode.</p>
            </div>

            <div class="gallery__showcase-row">
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Pie</div>
                    <div class="gallery__chart-container">
                        <ArcadiaPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="340" Width="380" />
                    </div>
                </div>
                <div class="gallery__showcase">
                    <div class="gallery__showcase-title">Donut</div>
                    <div class="gallery__chart-container">
                        <ArcadiaPieChart TItem="BudgetItem" Data="@_budget"
                                       NameField="@(d => d.Category)" ValueField="@(d => d.Amount)"
                                       Height="340" Width="380" InnerRadius="70" />
                    </div>
                </div>
            </div>
        }

        @if (_tab == "scatter")
        {
            <div class="gallery__section-header">
                <h1>Scatter Chart</h1>
                <p>Plot X/Y data points with staggered pop-in animation. Add SizeField for bubble charts.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Height vs Weight Distribution</div>
                <div class="gallery__chart-container">
                    <ArcadiaScatterChart TItem="DataXY" Data="@_scatterData"
                                       XField="@(d => d.X)" YField="@(d => d.Y)"
                                       Height="400" Width="0" Color="primary" PointSize="6" />
                </div>
            </div>
        }

        @if (_tab == "candle")
        {
            <div class="gallery__section-header">
                <h1>Candlestick</h1>
                <p>Financial OHLC chart with moving average overlay. Green candles = close above open.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">ACME Corp — 30 Day Price</div>
                <div class="gallery__chart-container">
                    <ArcadiaCandlestickChart TItem="StockCandle" Data="@_stockData"
                                            LabelField="@(d => d.Date)"
                                            OpenField="@(d => d.Open)" HighField="@(d => d.High)"
                                            LowField="@(d => d.Low)" CloseField="@(d => d.Close)"
                                            Height="420" Width="0" />
                </div>
            </div>
        }

        @if (_tab == "gauge")
        {
            <div class="gallery__section-header">
                <h1>Gauge Charts</h1>
                <p>Radial gauges with color thresholds. Arc fills with smooth animation on load.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">System Health Monitors</div>
                <div class="gallery__gauge-row">
                    <ArcadiaGaugeChart Value="73" Min="0" Max="100" Label="CPU" Width="180" Height="140" Thresholds="@_gaugeThresholds" />
                    <ArcadiaGaugeChart Value="42" Min="0" Max="100" Label="Memory" Width="180" Height="140" ValueFormatString="0'%'" />
                    <ArcadiaGaugeChart Value="91" Min="0" Max="100" Label="Disk" Width="180" Height="140" Thresholds="@_gaugeThresholds" />
                    <ArcadiaGaugeChart Value="99.9" Min="0" Max="100" Label="Uptime" Width="180" Height="140" ValueFormatString="0.0'%'" />
                </div>
            </div>
        }

        @if (_tab == "radar")
        {
            <div class="gallery__section-header">
                <h1>Radar Chart</h1>
                <p>Multi-dimensional comparison across categories. Polygons draw with line animation.</p>
            </div>

            <div class="gallery__showcase">
                <div class="gallery__showcase-title">Team Skills — A vs B</div>
                <div class="gallery__chart-container">
                    <ArcadiaRadarChart TItem="SkillProfile" Data="@_skillData"
                                     LabelField="@(d => d.Skill)" Series="@_radarSeries"
                                     Height="420" Width="0" />
                </div>
            </div>
        }

        @if (_tab == "heatmap")
        {
            <div class="gallery__section-header">
                <h1>Heatmap</h1>
                <p>2D color grid for visualizing density, frequency, or correlation data.</p>
            </div>


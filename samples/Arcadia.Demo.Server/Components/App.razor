<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Arcadia Controls Demo — Server</title>
    <base href="/" />
    <link href="_content/Arcadia.Theme/css/arcadia.css" rel="stylesheet" />
    <link href="css/app.css" rel="stylesheet" />
    <link href="_content/Arcadia.Notifications/css/arcadia-notifications.css" rel="stylesheet" />
    <link href="_content/Arcadia.FormBuilder/css/arcadia-forms.css" rel="stylesheet" />
    <link href="_content/Arcadia.Charts/css/arcadia-charts.css" rel="stylesheet" />
    <link href="_content/Arcadia.DataGrid/css/arcadia-datagrid.css" rel="stylesheet" />
    <link href="_content/Arcadia.UI/css/arcadia-ui.css" rel="stylesheet" />
    <HeadOutlet @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
</head>
<body>
    <Routes @rendermode="Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        // Suppress Blazor's "No interop methods are registered for renderer" errors
        // that fire when mouse events hit elements being torn down during re-renders.
        // This is a known Blazor Server issue — the errors are benign.
        window.addEventListener('error', function(e) {
            if (e.message && e.message.includes('No interop methods are registered for renderer')) {
                e.preventDefault();
                return true;
            }
        });
        window.addEventListener('unhandledrejection', function(e) {
            if (e.reason && e.reason.message && e.reason.message.includes('No interop methods are registered for renderer')) {
                e.preventDefault();
            }
        });
    </script>
</body>
</html>

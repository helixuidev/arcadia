---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arcadia Controls — Premium Blazor UI Components">

  <!-- HERO -->
  <section class="pt-32 pb-20 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-purple-500/20 bg-purple-500/10 text-sm text-purple-300 mb-8">
        <span class="w-2 h-2 rounded-full bg-fuchsia-400 animate-pulse"></span>
        Now in public beta
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-6">
        Build stunning dashboards<br/>
        <span class="gradient-text">in minutes, not months</span>
      </h1>

      <p class="text-xl text-[var(--arc-text-muted)] max-w-2xl mx-auto mb-10 leading-relaxed">
        Premium Blazor components for enterprise .NET developers. Charts, forms, notifications — 
        beautifully crafted, fully accessible, and ready for production.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-16">
        <a href="#" class="btn-gradient text-lg !py-3.5 !px-8">
          Get Started Free
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="#features" class="btn-outline text-lg !py-3.5 !px-8">View Components</a>
      </div>

      <!-- Hero code preview -->
      <div class="gradient-border max-w-3xl mx-auto">
        <div class="code-block text-left text-sm">
          <div class="text-[var(--arc-text-muted)] mb-3">// Drop in a KPI dashboard in 6 lines</div>
          <div><span class="code-keyword">&lt;</span><span class="code-type">ArcadiaKpiCard</span></div>
          <div class="ml-6"><span class="code-attr">Title</span>=<span class="code-string">"Monthly Revenue"</span></div>
          <div class="ml-6"><span class="code-attr">Value</span>=<span class="code-string">"$142,500"</span></div>
          <div class="ml-6"><span class="code-attr">Delta</span>=<span class="code-string">"+12.3%"</span></div>
          <div class="ml-6"><span class="code-attr">DeltaType</span>=<span class="code-string">"Increase"</span></div>
          <div class="ml-6"><span class="code-attr">Sparkline</span>=<span class="code-string">"@revenueData"</span> <span class="code-keyword">/&gt;</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="py-12 px-6 border-y border-purple-500/10">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <div class="text-3xl font-bold gradient-text">8</div>
        <div class="text-sm text-[var(--arc-text-muted)] mt-1">Chart Types</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">21</div>
        <div class="text-sm text-[var(--arc-text-muted)] mt-1">Form Fields</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">408</div>
        <div class="text-sm text-[var(--arc-text-muted)] mt-1">Unit Tests</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">0</div>
        <div class="text-sm text-[var(--arc-text-muted)] mt-1">JS Dependencies</div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features" class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Everything you need to ship <span class="gradient-text">faster</span></h2>
        <p class="text-[var(--arc-text-muted)] text-lg max-w-2xl mx-auto">Five packages, one design system. Each component is tree-shakeable, accessible, and works across all Blazor render modes.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Charts -->
        <div class="glass-card p-8 md:col-span-2 md:row-span-2">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white font-bold">C</div>
            <h3 class="text-xl font-semibold">Charts & Dashboard Widgets</h3>
          </div>
          <p class="text-[var(--arc-text-muted)] mb-6">8 chart types + 7 dashboard widgets. KPI cards, sparklines, gauges, bar lists — the Tremor-style toolkit nobody else in Blazor offers.</p>
          
          <!-- Mini chart demo -->
          <div class="bg-[#060012] rounded-xl p-6 border border-purple-500/10">
            <div class="grid grid-cols-3 gap-4 mb-6">
              <div class="glass-card !rounded-lg p-3">
                <div class="text-xs text-[var(--arc-text-muted)]">Revenue</div>
                <div class="text-lg font-bold">$142K</div>
                <div class="text-xs text-green-400">+12.3%</div>
              </div>
              <div class="glass-card !rounded-lg p-3">
                <div class="text-xs text-[var(--arc-text-muted)]">Users</div>
                <div class="text-lg font-bold">8,420</div>
                <div class="text-xs text-red-400">-2.1%</div>
              </div>
              <div class="glass-card !rounded-lg p-3">
                <div class="text-xs text-[var(--arc-text-muted)]">Conversion</div>
                <div class="text-lg font-bold">3.8%</div>
                <div class="text-xs text-green-400">+0.5%</div>
              </div>
            </div>
            <!-- SVG mini line chart -->
            <svg viewBox="0 0 400 100" class="w-full h-20">
              <defs>
                <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.3"/>
                  <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <path d="M0,80 L40,70 L80,75 L120,50 L160,55 L200,35 L240,40 L280,20 L320,25 L360,10 L400,15 L400,100 L0,100 Z" fill="url(#chartGrad)"/>
              <path d="M0,80 L40,70 L80,75 L120,50 L160,55 L200,35 L240,40 L280,20 L320,25 L360,10 L400,15" fill="none" stroke="#8b5cf6" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="400" cy="15" r="4" fill="#8b5cf6"/>
              <circle cx="400" cy="15" r="8" fill="#8b5cf6" opacity="0.3"/>
            </svg>
          </div>
        </div>

        <!-- Form Builder -->
        <div class="glass-card p-8" id="forms">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-fuchsia-500 to-pink-500 flex items-center justify-center text-white font-bold">F</div>
            <h3 class="text-xl font-semibold">Form Builder</h3>
          </div>
          <p class="text-[var(--arc-text-muted)] mb-4">21 field types, schema-driven rendering, wizard forms, cross-field validation. Generate forms from C# classes or JSON.</p>
          <div class="text-sm text-purple-300">TextField &middot; Select &middot; DateRange &middot; Rating &middot; Repeater &middot; +16 more</div>
        </div>

        <!-- Notifications -->
        <div class="glass-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center text-white font-bold">N</div>
            <h3 class="text-xl font-semibold">Notifications</h3>
          </div>
          <p class="text-[var(--arc-text-muted)] mb-4">Toast notifications with auto-dismiss, stacking, and full ARIA accessibility. Drop in one component.</p>
          <div class="text-sm text-purple-300">Info &middot; Success &middot; Warning &middot; Error</div>
        </div>

        <!-- Theme -->
        <div class="glass-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center text-white font-bold">T</div>
            <h3 class="text-xl font-semibold">Theme Engine</h3>
          </div>
          <p class="text-[var(--arc-text-muted)]">Design tokens, light/dark themes, 3 density modes, Tailwind CSS integration. CSS custom properties all the way down.</p>
        </div>

        <!-- Core -->
        <div class="glass-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-white font-bold">A</div>
            <h3 class="text-xl font-semibold">Core & Accessibility</h3>
          </div>
          <p class="text-[var(--arc-text-muted)]">WCAG 2.1 AA base classes, focus traps, live regions, keyboard navigation. Accessibility isn't an afterthought — it's the foundation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY ARCADIA -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Why <span class="gradient-text">Arcadia</span>?</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-3">Native Blazor SVG — Zero JS Tax</h3>
          <p class="text-[var(--arc-text-muted)]">Charts render as pure SVG from C#. No JavaScript framework dependency. Works in Server, WASM, Auto, and static SSR. Every interop call eliminated is a round-trip saved in Blazor Server.</p>
        </div>
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-3">WCAG 2.1 AA Certified</h3>
          <p class="text-[var(--arc-text-muted)]">Every chart includes a hidden data table for screen readers. Keyboard navigable. High contrast mode. Government and enterprise procurement-ready — pass accessibility audits your competitors can't.</p>
        </div>
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-3">Anti-Collision Layout Engine</h3>
          <p class="text-[var(--arc-text-muted)]">Labels never overlap. Smart tick calculation, auto-rotation, responsive breakpoints — all resolved in a pure C# pass before rendering. Fuzz-tested with 1,000+ random configurations.</p>
        </div>
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-3">$299/year, Not $1,000+</h3>
          <p class="text-[var(--arc-text-muted)]">Syncfusion, Telerik, DevExpress charge $1,000+ for suites you'll use 20% of. Arcadia gives you exactly what you need at a price that doesn't require VP approval.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Simple, honest <span class="gradient-text">pricing</span></h2>
        <p class="text-[var(--arc-text-muted)] text-lg">No surprises. No per-project fees. One license per developer.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Community -->
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-2">Community</h3>
          <div class="text-4xl font-extrabold mb-1">Free</div>
          <div class="text-sm text-[var(--arc-text-muted)] mb-6">Forever. No limits.</div>
          <ul class="space-y-3 text-sm text-[var(--arc-text-muted)] mb-8">
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Core + Theme packages</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Line, Bar, Pie, Scatter charts</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Sparkline widget</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Full source code (MIT)</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Community support</li>
          </ul>
          <a href="#" class="btn-outline w-full justify-center">Get Started</a>
        </div>

        <!-- Pro -->
        <div class="gradient-border">
          <div class="glass-card p-8 !border-0 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-purple-500 to-pink-500 text-white text-xs font-bold px-3 py-1 rounded-full">MOST POPULAR</div>
            <h3 class="text-lg font-semibold mb-2">Pro</h3>
            <div class="text-4xl font-extrabold mb-1">$299</div>
            <div class="text-sm text-[var(--arc-text-muted)] mb-6">per developer / year</div>
            <ul class="space-y-3 text-sm text-[var(--arc-text-muted)] mb-8">
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Everything in Community</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> All 8 chart types + animations</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> 7 dashboard widgets</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Trendlines, data labels, export</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Pan, zoom, live data</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Priority email support</li>
            </ul>
            <a href="#" class="btn-gradient w-full justify-center">Start Free Trial</a>
          </div>
        </div>

        <!-- Enterprise -->
        <div class="glass-card p-8">
          <h3 class="text-lg font-semibold mb-2">Enterprise</h3>
          <div class="text-4xl font-extrabold mb-1">$799</div>
          <div class="text-sm text-[var(--arc-text-muted)] mb-6">per developer / year</div>
          <ul class="space-y-3 text-sm text-[var(--arc-text-muted)] mb-8">
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Everything in Pro</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Form Builder (21 fields)</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Notifications</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> All future packages</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Dedicated support channel</li>
            <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> SLA guarantee</li>
          </ul>
          <a href="#" class="btn-outline w-full justify-center">Contact Sales</a>
        </div>
      </div>

      <p class="text-center text-sm text-[var(--arc-text-muted)] mt-8">All plans include .NET 5-9 support, all Blazor render modes, and no per-project fees.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="gradient-border">
        <div class="glass-card p-12 !border-0">
          <h2 class="text-3xl font-bold mb-4">Ready to build something <span class="gradient-text">beautiful</span>?</h2>
          <p class="text-[var(--arc-text-muted)] mb-8 text-lg">Start with the free Community edition. Upgrade when you need the full toolkit.</p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="#" class="btn-gradient text-lg !py-3.5 !px-8">
              Install Now
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="#" class="btn-outline text-lg !py-3.5 !px-8">View on GitHub</a>
          </div>
          <div class="mt-6 text-sm text-[var(--arc-text-muted)]">
            <code class="bg-purple-500/10 px-3 py-1.5 rounded-lg border border-purple-500/20">dotnet add package Arcadia.Charts</code>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
<!-- deployed -->

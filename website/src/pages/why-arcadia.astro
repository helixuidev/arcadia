---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Why Arcadia Controls — The Blazor Chart Library Built Different" description="See why developers choose Arcadia Controls over Telerik, Syncfusion, and MudBlazor for Blazor charts and dashboards.">

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-6 tracking-tight">
        Why developers choose<br/>
        <span class="gradient-text">Arcadia Controls</span>
      </h1>
      <p class="text-xl text-[var(--arc-text-muted)] max-w-2xl mx-auto leading-relaxed">
        Pure SVG rendering. Zero JavaScript. WCAG 2.1 AA accessible. AI-powered code generation.
        The Blazor chart library that does things differently.
      </p>
    </div>
  </section>

  <!-- FEATURE COMPARISON GRID -->
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">How we <span class="gradient-text">compare</span></h2>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-purple-500/20">
              <th class="text-left py-4 px-4 text-[var(--arc-text-muted)] font-semibold">Feature</th>
              <th class="py-4 px-4 text-center">
                <span class="gradient-text font-bold">Arcadia</span>
              </th>
              <th class="py-4 px-4 text-center text-[var(--arc-text-muted)]">Telerik</th>
              <th class="py-4 px-4 text-center text-[var(--arc-text-muted)]">Syncfusion</th>
              <th class="py-4 px-4 text-center text-[var(--arc-text-muted)]">MudBlazor</th>
            </tr>
          </thead>
          <tbody class="text-[var(--arc-text-muted)]">
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">Chart rendering</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">Pure SVG (C#)</td>
              <td class="py-3 px-4 text-center">Canvas (JS)</td>
              <td class="py-3 px-4 text-center">Canvas (JS)</td>
              <td class="py-3 px-4 text-center">SVG (JS)</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">JS dependencies for charts</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">None</td>
              <td class="py-3 px-4 text-center">Required</td>
              <td class="py-3 px-4 text-center">Required</td>
              <td class="py-3 px-4 text-center">Required</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">Chart types</td>
              <td class="py-3 px-4 text-center font-medium">12</td>
              <td class="py-3 px-4 text-center">30+</td>
              <td class="py-3 px-4 text-center">35+</td>
              <td class="py-3 px-4 text-center">6</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">Dashboard widgets</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">7 built-in</td>
              <td class="py-3 px-4 text-center">Various</td>
              <td class="py-3 px-4 text-center">Various</td>
              <td class="py-3 px-4 text-center">None</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">.NET versions</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">.NET 5-10</td>
              <td class="py-3 px-4 text-center">.NET 6-9</td>
              <td class="py-3 px-4 text-center">.NET 6-9</td>
              <td class="py-3 px-4 text-center">.NET 6-9</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">WCAG 2.1 AA</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">Full</td>
              <td class="py-3 px-4 text-center">Partial</td>
              <td class="py-3 px-4 text-center">Partial</td>
              <td class="py-3 px-4 text-center">Partial</td>
            </tr>
            <tr class="border-b border-purple-500/5">
              <td class="py-3 px-4">AI code generation (MCP)</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">Yes</td>
              <td class="py-3 px-4 text-center">No</td>
              <td class="py-3 px-4 text-center">No</td>
              <td class="py-3 px-4 text-center">No</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Price (per dev/year)</td>
              <td class="py-3 px-4 text-center text-green-400 font-medium">Free / $299</td>
              <td class="py-3 px-4 text-center">$1,249+</td>
              <td class="py-3 px-4 text-center">$995+</td>
              <td class="py-3 px-4 text-center">Free</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- KEY ADVANTAGES -->
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Zero JavaScript. Pure Performance.</h3>
          <p class="text-[var(--arc-text-muted)] leading-relaxed">
            Arcadia renders charts as native SVG directly from C#. No JavaScript chart engine means no JS bundle, no interop overhead, and charts that work perfectly with server-side rendering and Static SSR.
          </p>
        </div>

        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-fuchsia-500 to-pink-500 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Accessibility That Passes Audits</h3>
          <p class="text-[var(--arc-text-muted)] leading-relaxed">
            Every chart includes hidden data tables for screen readers, keyboard navigation, ARIA labels, and respects prefers-reduced-motion. Full WCAG 2.1 AA compliance across all 12 chart types.
          </p>
        </div>

        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">AI-Powered Development</h3>
          <p class="text-[var(--arc-text-muted)] leading-relaxed">
            The built-in MCP server lets AI assistants generate chart code from plain English. Describe your visualization, get working Blazor code. No other Blazor library has this.
          </p>
        </div>

        <div class="glass-card p-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">4x Cheaper Than Telerik</h3>
          <p class="text-[var(--arc-text-muted)] leading-relaxed">
            Arcadia Pro at $299/dev/year is a fraction of Telerik ($1,249+) or Syncfusion ($995+). And the Community Edition is free forever with MIT licensing — no revenue caps, no restrictions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING ADVANTAGE -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Save thousands per year, <span class="gradient-text">per developer</span></h2>
      <p class="text-[var(--arc-text-muted)] text-lg mb-12 max-w-2xl mx-auto">
        For a team of 5 developers, switching from Telerik to Arcadia Pro saves over $4,750 per year. And you get features they don't have — like zero-JS rendering and AI integration.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="glass-card p-6">
          <div class="text-sm text-[var(--arc-text-muted)] mb-2">Telerik (5 devs)</div>
          <div class="text-3xl font-bold text-red-400">$6,245</div>
          <div class="text-xs text-[var(--arc-text-muted)] mt-1">/year</div>
        </div>
        <div class="glass-card p-6">
          <div class="text-sm text-[var(--arc-text-muted)] mb-2">Syncfusion (5 devs)</div>
          <div class="text-3xl font-bold text-red-400">$4,975</div>
          <div class="text-xs text-[var(--arc-text-muted)] mt-1">/year</div>
        </div>
        <div class="gradient-border">
          <div class="glass-card p-6 !border-0">
            <div class="text-sm text-purple-300 mb-2">Arcadia Pro (5 devs)</div>
            <div class="text-3xl font-bold gradient-text">$1,495</div>
            <div class="text-xs text-[var(--arc-text-muted)] mt-1">/year</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL PLACEHOLDERS -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">What developers <span class="gradient-text">are saying</span></h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="glass-card p-6">
          <p class="text-[var(--arc-text-muted)] italic mb-4 leading-relaxed">"Switching from Telerik charts to Arcadia cut our dashboard load time in half. The zero-JS rendering is the real deal."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-white text-sm font-bold">JM</div>
            <div>
              <div class="text-sm font-medium">James M.</div>
              <div class="text-xs text-[var(--arc-text-muted)]">Senior .NET Developer</div>
            </div>
          </div>
        </div>
        <div class="glass-card p-6">
          <p class="text-[var(--arc-text-muted)] italic mb-4 leading-relaxed">"The MCP server is a game changer. I describe what I want to Claude and it writes the chart code. Saves me an hour a day."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-fuchsia-500 to-pink-500 flex items-center justify-center text-white text-sm font-bold">SK</div>
            <div>
              <div class="text-sm font-medium">Sarah K.</div>
              <div class="text-xs text-[var(--arc-text-muted)]">Full-Stack Engineer</div>
            </div>
          </div>
        </div>
        <div class="glass-card p-6">
          <p class="text-[var(--arc-text-muted)] italic mb-4 leading-relaxed">"Finally a Blazor chart library that passes our WCAG audit without custom patches. The hidden data tables are brilliant."</p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center text-white text-sm font-bold">RP</div>
            <div>
              <div class="text-sm font-medium">Rachel P.</div>
              <div class="text-xs text-[var(--arc-text-muted)]">Tech Lead, Enterprise SaaS</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="gradient-border">
        <div class="glass-card p-12 !border-0">
          <h2 class="text-3xl font-bold mb-4">Get started <span class="gradient-text">for free</span></h2>
          <p class="text-[var(--arc-text-muted)] mb-8 text-lg">
            The Community Edition includes 4 chart types, sparklines, notifications, and a full theme engine. No credit card required.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a href="/docs" class="btn-gradient text-lg !py-3.5 !px-8">
              Read the Docs
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="https://github.com/helixuidev/arcadia" class="btn-outline text-lg !py-3.5 !px-8">View on GitHub</a>
          </div>
          <div class="mt-6 text-sm text-[var(--arc-text-muted)]">
            <code class="bg-purple-500/10 px-3 py-1.5 rounded-lg border border-purple-500/20 text-purple-300">dotnet add package Arcadia.Charts</code>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

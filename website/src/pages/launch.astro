---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arcadia Controls — 14 Blazor Chart Types, Zero JavaScript | Product Hunt Launch" description="The lightweight, accessible chart library for .NET developers. Pure SVG rendering, 14 chart types, AI-powered code generation. Launching on Product Hunt.">

  <!-- HERO -->
  <section class="pt-32 pb-16 px-6 overflow-hidden relative">
    <!-- Extra launch glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-gradient-to-b from-purple-600/30 via-fuchsia-500/20 to-transparent rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-5xl mx-auto text-center relative z-10">
      <!-- Launch badge -->
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-fuchsia-500/30 bg-fuchsia-500/10 text-sm text-fuchsia-300 mb-8 animate-fade-up">
        <span class="w-2 h-2 rounded-full bg-fuchsia-400 animate-pulse"></span>
        We're live on Product Hunt today!
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold leading-[1.08] mb-6 tracking-tight animate-fade-up" style="animation-delay: 0.1s;">
        <span class="gradient-text">Arcadia Controls</span><br/>
        <span class="text-3xl md:text-5xl font-bold text-white/90 mt-2 block">14 Blazor Chart Types, Zero JavaScript</span>
      </h1>

      <p class="text-xl md:text-2xl text-[var(--arc-text-muted)] max-w-3xl mx-auto mb-12 leading-relaxed animate-fade-up" style="animation-delay: 0.2s;">
        The lightweight, accessible chart library for .NET developers
      </p>

      <!-- Product Hunt badge placeholder -->
      <div class="mb-12 animate-fade-up" style="animation-delay: 0.25s;">
        <!-- Product Hunt badge goes here -->
      </div>
    </div>
  </section>

  <!-- 3 KEY SELLING POINTS -->
  <section class="pb-20 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
      <div class="glass-card p-8 text-center animate-fade-up" style="animation-delay: 0.3s;">
        <div class="text-5xl mb-4">&#x1F4E6;</div>
        <h3 class="text-2xl font-bold mb-2">244KB total</h3>
        <p class="text-[var(--arc-text-muted)] leading-relaxed">
          Pure SVG rendering with zero JavaScript runtime. No bloated chart libraries, no WebGL dependencies. Just clean, server-side rendered markup.
        </p>
      </div>
      <div class="glass-card p-8 text-center animate-fade-up" style="animation-delay: 0.4s;">
        <div class="text-5xl mb-4">&#x1F4CA;</div>
        <h3 class="text-2xl font-bold mb-2">14 chart types</h3>
        <p class="text-[var(--arc-text-muted)] leading-relaxed">
          Line, Bar, Area, Pie, Donut, Scatter, Radar, Funnel, Heatmap, Treemap, Gauge, Sparkline, Rose, and Waterfall. From simple KPIs to complex analytics.
        </p>
      </div>
      <div class="glass-card p-8 text-center animate-fade-up" style="animation-delay: 0.5s;">
        <div class="text-5xl mb-4">&#x1F916;</div>
        <h3 class="text-2xl font-bold mb-2">AI-powered</h3>
        <p class="text-[var(--arc-text-muted)] leading-relaxed">
          Built-in MCP server lets AI assistants generate chart code from natural language. Describe what you want, get production-ready Blazor markup.
        </p>
      </div>
    </div>
  </section>

  <!-- ANIMATED CODE EXAMPLE -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
        Ship charts in <span class="gradient-text">seconds</span>
      </h2>
      <p class="text-center text-[var(--arc-text-muted)] mb-10 text-lg">One component. One line of data. Instant results.</p>

      <div class="gradient-border">
        <div class="bg-[#060012] rounded-2xl overflow-hidden">
          <!-- Code editor header -->
          <div class="flex items-center gap-2 px-6 py-3 border-b border-purple-500/10">
            <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
            <span class="ml-4 text-xs text-[var(--arc-text-muted)] font-mono">Dashboard.razor</span>
          </div>
          <!-- Code content with typing animation -->
          <div class="p-6 font-mono text-sm leading-[1.8] overflow-x-auto">
            <div class="code-line" style="animation: typeIn 0.4s ease-out 0.5s both;">
              <span class="code-keyword">&lt;</span><span class="code-type">ArcBarChart</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 0.8s both;">
              <span class="code-type">Title</span>=<span class="code-string">"Revenue by Quarter"</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 1.1s both;">
              <span class="code-type">Data</span>=<span class="code-string">"@quarters"</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 1.4s both;">
              <span class="code-type">XField</span>=<span class="code-string">"Quarter"</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 1.7s both;">
              <span class="code-type">YField</span>=<span class="code-string">"Revenue"</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 2.0s both;">
              <span class="code-type">Animate</span>=<span class="code-string">"true"</span>
            </div>
            <div class="code-line pl-8" style="animation: typeIn 0.4s ease-out 2.3s both;">
              <span class="code-type">Theme</span>=<span class="code-string">"ArcTheme.Purple"</span> <span class="code-keyword">/&gt;</span>
            </div>
          </div>
          <!-- Result preview -->
          <div class="border-t border-purple-500/10 p-6 bg-[#0a0018]">
            <div class="text-xs text-[var(--arc-text-muted)] mb-4 uppercase tracking-wider">Live Preview</div>
            <div class="flex items-end gap-3 h-32">
              <div class="chart-bar flex-1 rounded-t-md" style="height: 55%; animation: barGrow 0.6s ease-out 2.8s both;">
                <div class="text-xs text-center text-white/80 pt-2">Q1</div>
              </div>
              <div class="chart-bar flex-1 rounded-t-md" style="height: 75%; animation: barGrow 0.6s ease-out 3.0s both;">
                <div class="text-xs text-center text-white/80 pt-2">Q2</div>
              </div>
              <div class="chart-bar flex-1 rounded-t-md" style="height: 90%; animation: barGrow 0.6s ease-out 3.2s both;">
                <div class="text-xs text-center text-white/80 pt-2">Q3</div>
              </div>
              <div class="chart-bar flex-1 rounded-t-md" style="height: 100%; animation: barGrow 0.6s ease-out 3.4s both;">
                <div class="text-xs text-center text-white/80 pt-2">Q4</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING COMPARISON -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
        Enterprise features, <span class="gradient-text">indie price</span>
      </h2>
      <p class="text-center text-[var(--arc-text-muted)] mb-12 text-lg">Same chart coverage. Fraction of the cost.</p>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Arcadia -->
        <div class="glass-card p-8 relative glow-fuchsia !border-fuchsia-500/30">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 text-xs font-semibold text-white uppercase tracking-wider">
            You are here
          </div>
          <div class="text-center mt-2">
            <h3 class="text-xl font-bold gradient-text mb-1">Arcadia Controls</h3>
            <div class="text-4xl font-extrabold my-4">$299<span class="text-base font-normal text-[var(--arc-text-muted)]">/yr</span></div>
            <ul class="text-sm text-[var(--arc-text-muted)] space-y-2 text-left mb-6">
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> 14 chart types</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> 244KB total size</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> AI code generation</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> WCAG 2.1 AA</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> .NET 5-10 support</li>
              <li class="flex items-center gap-2"><span class="text-green-400">&#10003;</span> Zero JS dependencies</li>
            </ul>
            <a href="/docs" class="btn-gradient w-full justify-center !py-3">Get Started</a>
          </div>
        </div>

        <!-- Telerik -->
        <div class="glass-card p-8 opacity-60">
          <div class="text-center">
            <h3 class="text-xl font-bold text-[var(--arc-text-muted)] mb-1">Telerik UI</h3>
            <div class="text-4xl font-extrabold my-4 text-[var(--arc-text-muted)]">$1,249<span class="text-base font-normal">/yr</span></div>
            <ul class="text-sm text-[var(--arc-text-muted)] space-y-2 text-left mb-6">
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> 65+ components</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> Heavy JS interop</li>
              <li class="flex items-center gap-2"><span class="text-red-400">&#10007;</span> No AI tooling</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> Accessibility</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> .NET 6+ only</li>
              <li class="flex items-center gap-2"><span class="text-red-400">&#10007;</span> Large bundle size</li>
            </ul>
            <div class="btn-outline w-full justify-center !py-3 opacity-50 pointer-events-none">4x the price</div>
          </div>
        </div>

        <!-- Syncfusion -->
        <div class="glass-card p-8 opacity-60">
          <div class="text-center">
            <h3 class="text-xl font-bold text-[var(--arc-text-muted)] mb-1">Syncfusion</h3>
            <div class="text-4xl font-extrabold my-4 text-[var(--arc-text-muted)]">$995<span class="text-base font-normal">/yr</span></div>
            <ul class="text-sm text-[var(--arc-text-muted)] space-y-2 text-left mb-6">
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> 80+ components</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> Canvas/SVG hybrid</li>
              <li class="flex items-center gap-2"><span class="text-red-400">&#10007;</span> No AI tooling</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> Accessibility</li>
              <li class="flex items-center gap-2"><span class="text-[var(--arc-text-muted)]">&#10003;</span> .NET 6+ only</li>
              <li class="flex items-center gap-2"><span class="text-red-400">&#10007;</span> JS runtime required</li>
            </ul>
            <div class="btn-outline w-full justify-center !py-3 opacity-50 pointer-events-none">3.3x the price</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF / TESTIMONIALS -->
  <section class="pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">
        Trusted by <span class="gradient-text">.NET developers</span>
      </h2>
      <p class="text-center text-[var(--arc-text-muted)] mb-12 text-lg">Here's what early adopters are saying.</p>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Placeholder testimonials -->
        <div class="glass-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-purple-500/30 flex items-center justify-center text-lg font-bold text-purple-300">?</div>
            <div>
              <div class="font-semibold text-sm">Your Name Here</div>
              <div class="text-xs text-[var(--arc-text-muted)]">Senior .NET Developer</div>
            </div>
          </div>
          <p class="text-[var(--arc-text-muted)] text-sm leading-relaxed italic">
            "Testimonial placeholder — we'd love to feature your experience with Arcadia Controls here. Get in touch at hello@arcadiaui.com."
          </p>
        </div>
        <div class="glass-card p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-fuchsia-500/30 flex items-center justify-center text-lg font-bold text-fuchsia-300">?</div>
            <div>
              <div class="font-semibold text-sm">Your Name Here</div>
              <div class="text-xs text-[var(--arc-text-muted)]">Tech Lead</div>
            </div>
          </div>
          <p class="text-[var(--arc-text-muted)] text-sm leading-relaxed italic">
            "Testimonial placeholder — share how Arcadia Controls improved your Blazor workflow. Get in touch at hello@arcadiaui.com."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="pb-32 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="glass-card p-12 md:p-16 glow-purple relative overflow-hidden">
        <!-- Background decoration -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-purple-500/10 rounded-full blur-[80px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-pink-500/10 rounded-full blur-[60px] pointer-events-none"></div>

        <h2 class="text-3xl md:text-4xl font-bold mb-4 relative z-10">
          Ready to build <span class="gradient-text">beautiful charts</span>?
        </h2>
        <p class="text-[var(--arc-text-muted)] text-lg mb-8 relative z-10">
          Install in 30 seconds. Free Community tier with 4 chart types included.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-4 relative z-10">
          <a href="/docs" class="btn-gradient text-lg !py-3.5 !px-8">
            Get Started Free
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/playground/" class="btn-outline text-lg !py-3.5 !px-8">
            Live Demo
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </a>
        </div>
        <div class="mt-6 text-sm text-[var(--arc-text-muted)] relative z-10">
          <code class="bg-purple-500/10 px-3 py-1.5 rounded-lg border border-purple-500/20 text-purple-300">dotnet add package Arcadia.Charts</code>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes typeIn {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .code-line {
    opacity: 0;
  }

  @keyframes barGrow {
    from { height: 0%; opacity: 0; }
    to { opacity: 1; }
  }

  .chart-bar {
    background: linear-gradient(to top, #8b5cf6, #d946ef);
    opacity: 0;
  }
</style>

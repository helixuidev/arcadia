---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: string;
}

const {
  title,
  description = 'Premium Blazor UI components for enterprise .NET developers. Charts, forms, dashboards, and notifications — native SVG rendering with zero JavaScript.',
  canonical,
  image = 'https://arcadiaui.com/og-image.png',
  type = 'website'
} = Astro.props;

const siteUrl = 'https://arcadiaui.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EFMWJWMPX1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EFMWJWMPX1');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Arcadia Controls" />
  <meta name="keywords" content="Blazor, UI components, charts, dashboard, forms, .NET, C#, data visualization, SVG charts, Blazor components, enterprise, WCAG, accessible" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="Arcadia Controls" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Arcadia Controls",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Cross-platform",
    "description": description,
    "url": siteUrl,
    "author": {
      "@type": "Organization",
      "name": "Arcadia Controls",
      "url": siteUrl,
      "email": "sales@arcadiaui.com"
    },
    "offers": [
      {
        "@type": "Offer",
        "name": "Community",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free forever. Core, Theme, 4 chart types, Sparkline, Notifications. MIT licensed."
      },
      {
        "@type": "Offer",
        "name": "Pro",
        "price": "299",
        "priceCurrency": "USD",
        "priceValidUntil": "2027-12-31",
        "description": "All 20 chart types, 7 dashboard widgets, Form Builder, animations, email support. Per developer, annual."
      },
      {
        "@type": "Offer",
        "name": "Enterprise",
        "price": "799",
        "priceCurrency": "USD",
        "priceValidUntil": "2027-12-31",
        "description": "Everything in Pro plus custom feature requests, private roadmap, priority bug fixes, dedicated support. Per developer, annual."
      }
    ],
    "programmingLanguage": ["C#", "Blazor"],
    "softwareRequirements": ".NET 5 or later",
    "license": "https://opensource.org/licenses/MIT"
  })} />
</head>
<body class="noise-overlay">
  <!-- Background mesh blobs -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] bg-purple-600/20 rounded-full blur-[150px]"></div>
    <div class="absolute top-[30%] right-[-15%] w-[500px] h-[500px] bg-pink-500/15 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-10%] left-[30%] w-[700px] h-[700px] bg-fuchsia-500/10 rounded-full blur-[180px]"></div>
  </div>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-[#080014]/80 border-b border-purple-500/10" style="pointer-events: auto;">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-bold">
        <span class="gradient-text">Arcadia</span>
        <span class="text-[var(--arc-text-muted)] font-normal ml-1">Controls</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-[var(--arc-text-muted)]" style="pointer-events: auto;">
        <a href="/docs/charts" class="hover:text-white transition-colors">Charts</a>
        <a href="/docs/forms" class="hover:text-white transition-colors">Forms</a>
        <a href="/#pricing" class="hover:text-white transition-colors">Pricing</a>
        <a href="/docs" class="hover:text-white transition-colors">Docs</a>
        <a href="/security" class="hover:text-white transition-colors">Security</a>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <a href="/playground/" class="hover:text-white transition-colors">Playground</a>
        <a href="/docs" class="btn-gradient text-sm !py-2 !px-5">Get Started</a>
      </div>
    </div>
  </nav>

  <main class="relative z-2">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="relative z-2 border-t border-purple-500/10 mt-32">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid md:grid-cols-4 gap-12">
        <div>
          <h3 class="text-lg font-bold gradient-text mb-4">Arcadia Controls</h3>
          <p class="text-sm text-[var(--arc-text-muted)] leading-relaxed">
            Premium Blazor UI components for enterprise .NET developers. Built with accessibility, performance, and developer experience in mind.
          </p>
        </div>
        <div>
          <h4 class="font-semibold mb-4">Components</h4>
          <ul class="space-y-2 text-sm text-[var(--arc-text-muted)]">
            <li><a href="/docs/charts" class="hover:text-white transition-colors">Charts & Dashboards</a></li>
            <li><a href="/docs/forms" class="hover:text-white transition-colors">Form Builder</a></li>
            <li><a href="/docs/notifications" class="hover:text-white transition-colors">Notifications</a></li>
            <li><a href="/docs/theme" class="hover:text-white transition-colors">Theme Engine</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4">Resources</h4>
          <ul class="space-y-2 text-sm text-[var(--arc-text-muted)]">
            <li><a href="/docs" class="hover:text-white transition-colors">Documentation</a></li>
            <li><a href="/docs/charts" class="hover:text-white transition-colors">API Reference</a></li>
            <li><a href="/demo" class="hover:text-white transition-colors">Demo</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
            <li><a href="/security" class="hover:text-white transition-colors">Security</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4">Company</h4>
          <ul class="space-y-2 text-sm text-[var(--arc-text-muted)]">
            <li><a href="/#pricing" class="hover:text-white transition-colors">Pricing</a></li>
            <li><a href="https://github.com/helixuidev/arcadia" class="hover:text-white transition-colors">GitHub</a></li>
            <li><a href="mailto:support@arcadiaui.com" class="hover:text-white transition-colors">Support</a></li>
            <li><a href="mailto:sales@arcadiaui.com" class="hover:text-white transition-colors">Sales</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-purple-500/10 mt-12 pt-8 text-center text-sm text-[var(--arc-text-muted)]">
        &copy; 2026 Arcadia Controls. All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>

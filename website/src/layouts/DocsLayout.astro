---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  section?: string;
  activeSlug?: string;
}

// MDX pages pass frontmatter via Astro.props.frontmatter; .astro pages pass directly
const fm = (Astro.props as any).frontmatter ?? Astro.props;
const { title, description, section, activeSlug } = fm;

const nav = [
  {
    title: 'Getting Started',
    items: [
      { title: 'Installation', href: '/docs' },
      { title: 'Quick Start', href: '/docs/quick-start' },
      { title: 'Migration Guide', href: '/docs/migration' },
      { title: 'Benchmarks', href: '/docs/benchmarks' },
      { title: "What's New", href: '/docs/whats-new' },
      { title: 'Troubleshooting', href: '/docs/troubleshooting' },
    ]
  },
  {
    title: 'Charts',
    items: [
      { title: 'Overview', href: '/docs/charts' },
      { title: 'Line Chart', href: '/docs/charts/line-chart' },
      { title: 'Area Chart', href: '/docs/charts/area-chart' },
      { title: 'Bar Chart', href: '/docs/charts/bar-chart' },
      { title: 'Stacked Bar Chart', href: '/docs/charts/stacked-bar-chart' },
      { title: 'Pie & Donut', href: '/docs/charts/pie-chart' },
      { title: 'Donut Chart', href: '/docs/charts/donut-chart' },
      { title: 'Scatter Chart', href: '/docs/charts/scatter-chart' },
      { title: 'Bubble Chart', href: '/docs/charts/bubble-chart' },
      { title: 'Candlestick', href: '/docs/charts/candlestick' },
      { title: 'Radar Chart', href: '/docs/charts/radar-chart' },
      { title: 'Circular Gauge', href: '/docs/charts/gauge-chart' },
      { title: 'Linear Gauge', href: '/docs/charts/linear-gauge' },
      { title: 'Heatmap', href: '/docs/charts/heatmap' },
      { title: 'Funnel Chart', href: '/docs/charts/funnel-chart' },
      { title: 'Treemap Chart', href: '/docs/charts/treemap-chart' },
      { title: 'Waterfall Chart', href: '/docs/charts/waterfall-chart' },
      { title: 'Rose Chart', href: '/docs/charts/rose-chart' },
      { title: 'Range Area Chart', href: '/docs/charts/range-area-chart' },
      { title: 'Box Plot', href: '/docs/charts/box-plot' },
      { title: 'Sankey Chart', href: '/docs/charts/sankey-chart' },
      { title: 'Chord Chart', href: '/docs/charts/chord-chart' },
      { title: 'Dashboard Widgets', href: '/docs/charts/dashboard-widgets' },
      { title: 'Export & Toolbar', href: '/docs/charts/export' },
      { title: 'Streaming & Live Data', href: '/docs/charts/streaming' },
      { title: 'Annotations', href: '/docs/charts/annotations' },
      { title: 'Crosshair', href: '/docs/charts/crosshair' },
    ]
  },
  {
    title: 'DataGrid',
    items: [
      { title: 'Overview', href: '/docs/datagrid' },
      { title: 'Sorting', href: '/docs/datagrid/sorting' },
      { title: 'Filtering', href: '/docs/datagrid/filtering' },
      { title: 'Selection', href: '/docs/datagrid/selection' },
      { title: 'Editing', href: '/docs/datagrid/editing' },
      { title: 'Grouping', href: '/docs/datagrid/grouping' },
      { title: 'Templates', href: '/docs/datagrid/templates' },
      { title: 'Virtual Scrolling', href: '/docs/datagrid/virtual-scrolling' },
      { title: 'Themes', href: '/docs/datagrid/themes' },
      { title: 'Export', href: '/docs/datagrid/export' },
      { title: 'State Persistence', href: '/docs/datagrid/state-persistence' },
      { title: 'Batch Editing', href: '/docs/datagrid/batch-editing' },
      { title: 'Context Menu', href: '/docs/datagrid/context-menu' },
    ]
  },
  {
    title: 'Form Builder',
    items: [
      { title: 'Overview', href: '/docs/forms' },
      { title: 'Schema-Driven Forms', href: '/docs/forms/schema-driven' },
      { title: 'Model-Driven Forms', href: '/docs/forms/model-driven' },
      { title: 'Field Types', href: '/docs/forms/field-types' },
      { title: 'TextField', href: '/docs/forms/fields/text-field' },
      { title: 'PasswordField', href: '/docs/forms/fields/password-field' },
      { title: 'MaskedField', href: '/docs/forms/fields/masked-field' },
      { title: 'TextAreaField', href: '/docs/forms/fields/textarea-field' },
      { title: 'NumberField', href: '/docs/forms/fields/number-field' },
      { title: 'SliderField', href: '/docs/forms/fields/slider-field' },
      { title: 'SelectField', href: '/docs/forms/fields/select-field' },
      { title: 'MultiSelectField', href: '/docs/forms/fields/multi-select-field' },
      { title: 'RadioGroupField', href: '/docs/forms/fields/radio-group-field' },
      { title: 'CheckboxGroupField', href: '/docs/forms/fields/checkbox-group-field' },
      { title: 'CheckboxField', href: '/docs/forms/fields/checkbox-field' },
      { title: 'SwitchField', href: '/docs/forms/fields/switch-field' },
      { title: 'DateField', href: '/docs/forms/fields/date-field' },
      { title: 'TimeField', href: '/docs/forms/fields/time-field' },
      { title: 'DateRangeField', href: '/docs/forms/fields/date-range-field' },
      { title: 'ColorField', href: '/docs/forms/fields/color-field' },
      { title: 'AutocompleteField', href: '/docs/forms/fields/autocomplete-field' },
      { title: 'FileField', href: '/docs/forms/fields/file-field' },
      { title: 'RatingField', href: '/docs/forms/fields/rating-field' },
      { title: 'HiddenField', href: '/docs/forms/fields/hidden-field' },
      { title: 'RepeaterField', href: '/docs/forms/fields/repeater-field' },
      { title: 'Wizard Forms', href: '/docs/forms/wizard' },
      { title: 'Validation', href: '/docs/forms/validation' },
    ]
  },
  {
    title: 'Dashboard',
    items: [
      { title: 'Overview', href: '/docs/dashboard' },
      { title: 'DragGrid', href: '/docs/dashboard/drag-grid' },
    ]
  },
  {
    title: 'UI Components',
    items: [
      { title: 'Overview', href: '/docs/ui' },
      { title: 'Accordion', href: '/docs/ui/accordion' },
      { title: 'Alert', href: '/docs/ui/alert' },
      { title: 'Aspect Ratio', href: '/docs/ui/aspect-ratio' },
      { title: 'Avatar', href: '/docs/ui/avatar' },
      { title: 'Badge', href: '/docs/ui/badge' },
      { title: 'Breadcrumb', href: '/docs/ui/breadcrumb' },
      { title: 'Card', href: '/docs/ui/card' },
      { title: 'Carousel', href: '/docs/ui/carousel' },
      { title: 'Chip', href: '/docs/ui/chip' },
      { title: 'Circular Progress', href: '/docs/ui/circular-progress' },
      { title: 'Color Picker', href: '/docs/ui/color-picker' },
      { title: 'Command Palette', href: '/docs/ui/command-palette' },
      { title: 'Context Menu', href: '/docs/ui/context-menu' },
      { title: 'Date Picker', href: '/docs/ui/date-picker' },
      { title: 'Dialog', href: '/docs/ui/dialog' },
      { title: 'Drawer', href: '/docs/ui/drawer' },
      { title: 'Empty State', href: '/docs/ui/empty-state' },
      { title: 'Hover Card', href: '/docs/ui/hover-card' },
      { title: 'Menu', href: '/docs/ui/menu' },
      { title: 'Pagination', href: '/docs/ui/pagination' },
      { title: 'Popover', href: '/docs/ui/popover' },
      { title: 'Progress', href: '/docs/ui/progress' },
      { title: 'Rating', href: '/docs/ui/rating' },
      { title: 'Scroll Area', href: '/docs/ui/scroll-area' },
      { title: 'Separator', href: '/docs/ui/separator' },
      { title: 'Sidebar', href: '/docs/ui/sidebar' },
      { title: 'Skeleton', href: '/docs/ui/skeleton' },
      { title: 'Slider', href: '/docs/ui/slider' },
      { title: 'Spinner', href: '/docs/ui/spinner' },
      { title: 'Stepper', href: '/docs/ui/stepper' },
      { title: 'Switch', href: '/docs/ui/switch' },
      { title: 'Tabs', href: '/docs/ui/tabs' },
      { title: 'Tag Input', href: '/docs/ui/tag-input' },
      { title: 'Text Area', href: '/docs/ui/textarea' },
      { title: 'Timeline', href: '/docs/ui/timeline' },
      { title: 'Tooltip', href: '/docs/ui/tooltip' },
      { title: 'Tree View', href: '/docs/ui/tree-view' },
    ]
  },
  {
    title: 'Theme',
    items: [
      { title: 'Overview', href: '/docs/theme' },
      { title: 'Design Tokens', href: '/docs/theme/tokens' },
      { title: 'Dark Mode', href: '/docs/theme/dark-mode' },
      { title: 'Tailwind Plugin', href: '/docs/theme/tailwind' },
    ]
  },
  {
    title: 'Notifications',
    items: [
      { title: 'Toast Notifications', href: '/docs/notifications' },
    ]
  },
  {
    title: 'AI Integration',
    items: [
      { title: 'MCP Server', href: '/docs/mcp-server' },
    ]
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '');
const siteUrl = 'https://arcadiaui.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullDescription = description || `${title} — Arcadia Controls Documentation`;

// Build breadcrumb trail from URL path segments + nav structure
const segments = currentPath.split('/').filter(Boolean); // e.g. ['docs', 'charts', 'line-chart']
const breadcrumbs: Array<{ name: string; url: string }> = [
  { name: 'Home', url: siteUrl },
  { name: 'Docs', url: `${siteUrl}/docs` },
];
if (segments.length > 1) {
  // Find the nav group title for the section (e.g. 'charts' → 'Charts')
  const sectionSlug = segments[1]; // 'charts', 'datagrid', 'forms', 'ui', etc.
  const sectionGroup = nav.find(g => g.items.some(i => i.href.startsWith(`/docs/${sectionSlug}`)));
  if (sectionGroup) {
    const sectionHref = sectionGroup.items[0]?.href ?? `/docs/${sectionSlug}`;
    breadcrumbs.push({ name: sectionGroup.title, url: `${siteUrl}${sectionHref}` });
  }
}
// Final crumb is the current page
if (segments.length > 1) {
  breadcrumbs.push({ name: title, url: canonicalUrl });
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EFMWJWMPX1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EFMWJWMPX1');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{title} — Arcadia Docs</title>
  <meta name="description" content={fullDescription} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Arcadia Controls" />
  <meta name="keywords" content="Blazor, Blazor components, Blazor charts, Blazor UI, .NET, C#, data visualization, SVG charts, dashboard widgets, Blazor forms, Arcadia Controls, WCAG accessible components" />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} — Arcadia Docs`} />
  <meta property="og:description" content={fullDescription} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Arcadia Controls" />
  <meta property="og:image" content="https://arcadiaui.com/og-image.png" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Arcadia Docs`} />
  <meta name="twitter:description" content={fullDescription} />
  <meta name="twitter:image" content="https://arcadiaui.com/og-image.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD: TechArticle -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": title,
    "description": fullDescription,
    "url": canonicalUrl,
    "publisher": {
      "@type": "Organization",
      "name": "Arcadia Controls",
      "url": siteUrl
    }
  })} />

  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": crumb.name,
      "item": crumb.url
    }))
  })} />
</head>
<body>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-[#080014]/80 border-b border-purple-500/10" style="pointer-events: auto;">
    <div class="max-w-[1400px] mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold">
        <span class="gradient-text">Arcadia</span>
        <span class="text-[var(--arc-text-muted)] font-normal ml-1">Docs</span>
      </a>
      <div class="flex items-center gap-6 text-sm text-[var(--arc-text-muted)]" style="pointer-events: auto;">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <a href="/docs" class="hover:text-white transition-colors">Docs</a>
        <a href="/#pricing" class="hover:text-white transition-colors">Pricing</a>
        <a href="#" class="hover:text-white transition-colors">GitHub</a>
      </div>
    </div>
  </nav>

  <div class="flex max-w-[1400px] mx-auto pt-14">
    <!-- Sidebar -->
    <aside class="hidden lg:block w-64 shrink-0 border-r border-purple-500/10 h-[calc(100vh-56px)] sticky top-14 overflow-y-auto py-8 px-4">
      {nav.map(group => (
        <div class="mb-6">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--arc-text-muted)] mb-2 px-3">{group.title}</h4>
          <ul class="space-y-0.5">
            {group.items.map(item => {
              const isActive = currentPath === item.href || currentPath === item.href.replace(/\/$/, '');
              return (
                <li>
                  <a href={item.href}
                     class={`block px-3 py-1.5 rounded-lg text-sm transition-colors ${isActive ? 'bg-purple-500/15 text-purple-300 font-medium' : 'text-[var(--arc-text-muted)] hover:text-white hover:bg-purple-500/5'}`}>
                    {item.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </aside>

    <!-- Content -->
    <main class="flex-1 min-w-0 px-8 py-10 max-w-4xl">
      <article class="prose-docs">
        <slot />
      </article>
    </main>
  </div>

  <style is:global>
    /* ── Typography ── */
    .prose-docs h1 {
      font-size: 2.5rem; font-weight: 800; margin-bottom: 0.75rem;
      color: #f1f0f9; letter-spacing: -0.025em; line-height: 1.2;
    }
    .prose-docs h2 {
      font-size: 1.5rem; font-weight: 700; margin-top: 3rem; margin-bottom: 1rem;
      color: #f1f0f9; letter-spacing: -0.015em;
      border-bottom: 1px solid rgba(139,92,246,0.15); padding-bottom: 0.75rem;
    }
    .prose-docs h3 {
      font-size: 1.2rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem;
      color: #e2e0f0;
    }
    .prose-docs p {
      color: #9490b3; line-height: 1.8; margin-bottom: 1.25rem; font-size: 0.95rem;
    }
    .prose-docs > p:first-of-type {
      font-size: 1.1rem; color: #b0adc8; line-height: 1.7;
    }
    .prose-docs strong { color: #d4d0ec; font-weight: 600; }
    .prose-docs a { color: #c084fc; text-decoration: underline; text-underline-offset: 3px; }
    .prose-docs a:hover { color: #d8b4fe; }

    /* ── Lists ── */
    .prose-docs ul {
      list-style: none; padding-left: 0; color: #9490b3;
      margin-bottom: 1.5rem;
    }
    .prose-docs ul li {
      position: relative; padding-left: 1.5rem; margin-bottom: 0.5rem;
      line-height: 1.75; font-size: 0.95rem;
    }
    .prose-docs ul li::before {
      content: ''; position: absolute; left: 0; top: 0.65em;
      width: 6px; height: 6px; border-radius: 50%;
      background: linear-gradient(135deg, #8b5cf6, #ec4899);
    }
    .prose-docs ol {
      list-style: decimal; padding-left: 1.5rem; color: #9490b3; margin-bottom: 1.5rem;
    }
    .prose-docs ol li { margin-bottom: 0.5rem; line-height: 1.75; font-size: 0.95rem; }

    /* ── Inline code ── */
    .prose-docs code:not(pre code) {
      background: rgba(139,92,246,0.12); color: #c084fc;
      padding: 3px 8px; border-radius: 6px; font-size: 0.85em;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      border: 1px solid rgba(139,92,246,0.1);
    }

    /* ── Code blocks ── */
    .prose-docs pre {
      background: rgba(8,3,25,0.9) !important;
      border: 1px solid rgba(139,92,246,0.15);
      border-radius: 14px; padding: 1.5rem;
      margin-bottom: 1.75rem; overflow-x: auto;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.85rem; line-height: 1.75;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3), inset 0 1px 0 rgba(139,92,246,0.08);
    }
    .prose-docs pre code {
      background: none !important; color: #d4d0ec; padding: 0;
      border: none; font-size: inherit;
    }

    /* ── Tables ── */
    .prose-docs table {
      width: 100%; border-collapse: collapse; margin-bottom: 2rem;
      font-size: 0.875rem; border-radius: 12px; overflow: hidden;
    }
    .prose-docs thead {
      background: rgba(139,92,246,0.08);
    }
    .prose-docs th {
      text-align: left; padding: 0.875rem 1rem;
      border-bottom: 2px solid rgba(139,92,246,0.2);
      color: #d4d0ec; font-weight: 600; font-size: 0.8rem;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .prose-docs td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(139,92,246,0.06);
      color: #9490b3;
    }
    .prose-docs tbody tr:hover {
      background: rgba(139,92,246,0.04);
    }
    .prose-docs td code {
      font-size: 0.8em !important;
    }

    /* ── Horizontal rules ── */
    .prose-docs hr {
      border: none; border-top: 1px solid rgba(139,92,246,0.12);
      margin: 2.5rem 0;
    }

    /* ── Blockquotes / Callouts ── */
    .prose-docs blockquote {
      background: rgba(139,92,246,0.06); border-left: 3px solid #8b5cf6;
      border-radius: 0 12px 12px 0; padding: 1rem 1.25rem;
      margin: 0 0 1.5rem 0;
    }
    .prose-docs blockquote p { color: #b0adc8; margin-bottom: 0; }

    .prose-docs .callout {
      background: rgba(139,92,246,0.06);
      border: 1px solid rgba(139,92,246,0.15);
      border-radius: 12px; padding: 1.25rem 1.5rem; margin-bottom: 1.75rem;
    }
    .prose-docs .callout-title {
      font-weight: 600; color: #c084fc; margin-bottom: 0.35rem; font-size: 0.9rem;
    }

    /* ── Images ── */
    .prose-docs img {
      border-radius: 12px; border: 1px solid rgba(139,92,246,0.15);
      margin-bottom: 1.5rem;
    }
  </style>
</body>
</html>

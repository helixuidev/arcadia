---
import '../styles/global.css'

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  readTime?: string;
  tags?: string[];
}

const { title, description, date, author = 'Arcadia Team', readTime = '8 min read', tags = [] } = Astro.props;
const siteUrl = 'https://arcadiaui.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const dateStr = String(date);
const publishDate = dateStr.includes('T') ? dateStr : `${dateStr}T00:00:00Z`;
const displayDate = new Date(publishDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-EFMWJWMPX1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-EFMWJWMPX1');
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{title} — Arcadia Blog</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content={author} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Arcadia Controls" />
  <meta property="article:published_time" content={publishDate} />
  <meta property="article:author" content={author} />
  {tags.map(tag => <meta property="article:tag" content={tag} />)}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": publishDate,
    "author": { "@type": "Organization", "name": "Arcadia Controls", "url": siteUrl },
    "publisher": { "@type": "Organization", "name": "Arcadia Controls", "url": siteUrl },
    "url": canonicalUrl,
    "keywords": tags.join(", ")
  })} />
</head>
<body>
  <!-- Background -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
    <div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] bg-purple-600/20 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-pink-500/15 rounded-full blur-[150px]"></div>
  </div>

  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-[#080014]/80 border-b border-purple-500/10" style="pointer-events: auto;">
    <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="text-lg font-bold">
        <span class="gradient-text">Arcadia</span>
        <span class="text-[var(--arc-text-muted)] font-normal ml-1">Blog</span>
      </a>
      <div class="flex items-center gap-6 text-sm text-[var(--arc-text-muted)]" style="pointer-events: auto;">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <a href="/docs" class="hover:text-white transition-colors">Docs</a>
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
      </div>
    </div>
  </nav>

  <main class="relative z-2 max-w-3xl mx-auto px-6 pt-28 pb-20">
    <!-- Article header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 text-sm text-[var(--arc-text-muted)] mb-4">
        <time datetime={publishDate}>{displayDate}</time>
        <span>·</span>
        <span>{readTime}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4 tracking-tight">{title}</h1>
      <p class="text-xl text-[var(--arc-text-muted)] leading-relaxed">{description}</p>
      {tags.length > 0 && (
        <div class="flex gap-2 mt-4">
          {tags.map(tag => (
            <span class="text-xs bg-purple-500/10 text-purple-300 px-2 py-1 rounded-full border border-purple-500/15">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Article body -->
    <article class="blog-prose">
      <slot />
    </article>

    <!-- CTA -->
    <div class="mt-16 gradient-border">
      <div class="glass-card p-8 !border-0 text-center">
        <h3 class="text-xl font-bold mb-2">Ready to try Arcadia?</h3>
        <p class="text-[var(--arc-text-muted)] mb-4">Start with the free Community edition — 4 chart types, sparklines, notifications, and a full theme engine.</p>
        <div class="flex justify-center gap-3">
          <a href="/docs" class="btn-gradient">Get Started</a>
          <a href="https://github.com/helixuidev/arcadia" class="btn-outline">GitHub</a>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    .blog-prose h2 { font-size: 1.6rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.75rem; color: #f1f0f9; }
    .blog-prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; color: #e2e0f0; }
    .blog-prose p { color: #9490b3; line-height: 1.85; margin-bottom: 1.25rem; font-size: 1.05rem; }
    .blog-prose strong { color: #d4d0ec; }
    .blog-prose a { color: #c084fc; text-decoration: underline; text-underline-offset: 3px; }
    .blog-prose a:hover { color: #d8b4fe; }
    .blog-prose ul, .blog-prose ol { color: #9490b3; margin-bottom: 1.5rem; padding-left: 1.5rem; }
    .blog-prose li { margin-bottom: 0.5rem; line-height: 1.75; font-size: 1.05rem; }
    .blog-prose ul li { list-style: disc; }
    .blog-prose ol li { list-style: decimal; }
    .blog-prose code:not(pre code) { background: rgba(139,92,246,0.12); color: #c084fc; padding: 2px 7px; border-radius: 5px; font-size: 0.9em; font-family: 'JetBrains Mono', monospace; }
    .blog-prose pre { background: rgba(8,3,25,0.9); border: 1px solid rgba(139,92,246,0.15); border-radius: 14px; padding: 1.5rem; margin-bottom: 1.75rem; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; line-height: 1.75; }
    .blog-prose pre code { background: none; color: #d4d0ec; padding: 0; font-size: inherit; }
    .blog-prose blockquote { border-left: 3px solid #8b5cf6; padding: 1rem 1.25rem; margin: 0 0 1.5rem; background: rgba(139,92,246,0.06); border-radius: 0 12px 12px 0; }
    .blog-prose blockquote p { color: #b0adc8; margin: 0; }
    .blog-prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
    .blog-prose th { text-align: left; padding: 0.75rem; border-bottom: 2px solid rgba(139,92,246,0.2); color: #d4d0ec; font-weight: 600; font-size: 0.85rem; }
    .blog-prose td { padding: 0.75rem; border-bottom: 1px solid rgba(139,92,246,0.06); color: #9490b3; font-size: 0.95rem; }
    .blog-prose hr { border: none; border-top: 1px solid rgba(139,92,246,0.12); margin: 2.5rem 0; }
  </style>
</body>
</html>

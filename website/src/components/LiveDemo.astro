---
interface Props {
  route?: string;
  height?: string;
  title?: string;
}

const { route = '/', height = '500px', title = 'Live Demo' } = Astro.props;
const isProd = import.meta.env.PROD;
const demoBase = isProd ? 'https://demo.arcadiaui.com' : 'http://localhost:5050';
const demoUrl = `${demoBase}${route}`;
---

<div class="live-demo">
  <div class="live-demo__header">
    <div class="live-demo__dot live-demo__dot--red"></div>
    <div class="live-demo__dot live-demo__dot--yellow"></div>
    <div class="live-demo__dot live-demo__dot--green"></div>
    <span class="live-demo__title">{title}</span>
    <a href={demoUrl} target="_blank" class="live-demo__external">
      Open in new tab ↗
    </a>
  </div>
  <div class="live-demo__frame-wrapper" style={`height: ${height};`}>
    {isProd ? (
      <div class="live-demo__coming-soon">
        <p>Interactive demo coming soon</p>
        <a href={demoUrl} class="live-demo__link">Try locally with: dotnet run --project samples/Arcadia.Demo.Server</a>
      </div>
    ) : (
      <iframe
        src={demoUrl}
        class="live-demo__frame"
        loading="lazy"
        title={title}
        sandbox="allow-scripts allow-same-origin allow-forms"
      />
    )}
    <div class="live-demo__loading">
      <div class="live-demo__spinner"></div>
      <span>Loading Blazor demo...</span>
    </div>
  </div>
</div>

<style is:global>
  .live-demo { border: 1px solid rgba(139,92,246,0.2); border-radius: 16px; overflow: hidden; margin: 2rem 0; background: rgba(8,3,25,0.6); box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
  .live-demo__header { display: flex; align-items: center; gap: 6px; padding: 12px 16px; background: rgba(15,8,35,0.8); border-bottom: 1px solid rgba(139,92,246,0.12); }
  .live-demo__dot { width: 10px; height: 10px; border-radius: 50%; }
  .live-demo__dot--red { background: #ff5f57; }
  .live-demo__dot--yellow { background: #febc2e; }
  .live-demo__dot--green { background: #28c840; }
  .live-demo__title { margin-left: 8px; font-size: 0.8rem; color: #9490b3; font-weight: 500; }
  .live-demo__external { margin-left: auto; font-size: 0.75rem; color: #8b5cf6; text-decoration: none; opacity: 0.7; transition: opacity 0.2s; }
  .live-demo__external:hover { opacity: 1; }
  .live-demo__frame-wrapper { position: relative; background: #0c0020; }
  .live-demo__frame { width: 100%; height: 100%; border: none; position: relative; z-index: 1; }
  .live-demo__loading { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; background: #0c0020; color: #9490b3; font-size: 0.875rem; z-index: 0; }
  .live-demo__spinner { width: 24px; height: 24px; border: 2px solid rgba(139,92,246,0.2); border-top-color: #8b5cf6; border-radius: 50%; animation: demo-spin 0.8s linear infinite; }
  .live-demo__coming-soon { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 200px; color: #9490b3; text-align: center; padding: 2rem; }
  .live-demo__coming-soon p { font-size: 1.1rem; margin-bottom: 0.5rem; }
  .live-demo__link { font-size: 0.8rem; color: #8b5cf6; font-family: 'JetBrains Mono', monospace; }
  @keyframes demo-spin { to { transform: rotate(360deg); } }
</style>

@namespace HelixUI.FormBuilder.Components
@implements IDisposable

@if (Wizard?.IsStepVisible(this) == true)
{
    <div class="helix-wizard-step">
        @if (!string.IsNullOrEmpty(Title))
        {
            <h3 class="helix-wizard-step__title">@Title</h3>
        }
        @if (!string.IsNullOrEmpty(Description))
        {
            <p class="helix-wizard-step__description">@Description</p>
        }
        @ChildContent
    </div>
}

@code {
    [CascadingParameter]
    private HelixWizard? Wizard { get; set; }

    /// <summary>
    /// Gets or sets the step title shown in the navigation.
    /// </summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>
    /// Gets or sets an optional description shown below the title.
    /// </summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>
    /// Gets or sets the child content of this step.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    protected override void OnInitialized()
    {
        Wizard?.RegisterStep(this);
    }

    public void Dispose()
    {
        Wizard?.UnregisterStep(this);
    }
}

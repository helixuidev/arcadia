@namespace HelixUI.FormBuilder.Components.Layout
@inherits HelixUI.Core.Base.HelixComponentBase

<div class="@CssClass" @attributes="AdditionalAttributes">
    <div class="helix-form-tabs__nav" role="tablist">
        @for (var i = 0; i < Tabs.Count; i++)
        {
            var tabIndex = i;
            var tab = Tabs[i];
            <button type="button"
                    class="helix-form-tabs__tab @(tabIndex == ActiveTab ? "helix-form-tabs__tab--active" : "")"
                    role="tab"
                    aria-selected="@(tabIndex == ActiveTab ? "true" : "false")"
                    aria-controls="@($"helix-tab-panel-{ElementId}-{tabIndex}")"
                    @onclick="() => SetActiveTab(tabIndex)">
                @tab.Title
                @if (tab.ErrorCount > 0)
                {
                    <span class="helix-form-tabs__error-badge" aria-label="@($"{tab.ErrorCount} errors")">@tab.ErrorCount</span>
                }
            </button>
        }
    </div>

    @for (var i = 0; i < Tabs.Count; i++)
    {
        var tabIndex = i;
        <div id="@($"helix-tab-panel-{ElementId}-{tabIndex}")"
             class="helix-form-tabs__panel"
             role="tabpanel"
             hidden="@(tabIndex != ActiveTab)">
            @Tabs[tabIndex].Content
        </div>
    }
</div>

@code {
    [Parameter] public List<FormTab> Tabs { get; set; } = new();
    [Parameter] public int ActiveTab { get; set; }
    [Parameter] public EventCallback<int> ActiveTabChanged { get; set; }

    private async Task SetActiveTab(int index)
    {
        ActiveTab = index;
        await ActiveTabChanged.InvokeAsync(index);
    }

    private string? CssClass => HelixUI.Core.Utilities.CssBuilder.Default("helix-form-tabs")
        .AddClass(Class)
        .Build();
}

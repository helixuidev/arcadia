@namespace Arcadia.DashboardKit.Components
@inherits ArcadiaInteropBase

@if (ShowAddButton)
{
    <div class="arcadia-draggrid__toolbar">
        <button type="button"
                class="arcadia-draggrid__add-btn"
                aria-label="Add panel"
                @onclick="HandleAddPanel">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 1a1 1 0 0 1 1 1v5h5a1 1 0 1 1 0 2H9v5a1 1 0 1 1-2 0V9H2a1 1 0 0 1 0-2h5V2a1 1 0 0 1 1-1Z"/>
            </svg>
            <span>Add Panel</span>
        </button>
    </div>
}

<div @ref="ElementRef"
     class="@CssClass"
     style="@GridStyle"
     role="grid"
     aria-label="Draggable grid layout"
     @attributes="AdditionalAttributes">

    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@if (_wiggleActive)
{
    <div class="arcadia-draggrid__wiggle-toolbar">
        <button type="button" class="arcadia-draggrid__done-btn" @onclick="ExitWiggleMode">Done</button>
    </div>
}

@* ARIA live region for keyboard drag announcements *@
<div role="status" aria-live="polite" class="arcadia-sr-only">@_liveAnnouncement</div>

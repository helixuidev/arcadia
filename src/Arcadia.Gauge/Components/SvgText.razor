@namespace Arcadia.Gauge.Components

@((MarkupString)$"<text x=\"{X}\" y=\"{Y}\" text-anchor=\"{TextAnchor}\" dominant-baseline=\"{DominantBaseline}\" fill=\"{Fill}\" font-size=\"{FontSize}\" font-weight=\"{FontWeight}\" font-family=\"{FontFamily}\">{ChildContent}</text>")

@code {
    [Parameter] public string X { get; set; } = "0";
    [Parameter] public string Y { get; set; } = "0";
    [Parameter] public string TextAnchor { get; set; } = "middle";
    [Parameter] public string DominantBaseline { get; set; } = "middle";
    [Parameter] public string Fill { get; set; } = "#ffffff";
    [Parameter] public string FontSize { get; set; } = "12";
    [Parameter] public string FontWeight { get; set; } = "400";
    [Parameter] public string FontFamily { get; set; } = "system-ui, sans-serif";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

@namespace HelixUI.Charts.Components.Charts
@typeparam T
@inherits HelixUI.Charts.Core.ChartBase<T>

@if (Data is not null && Data.Count > 0 && XField is not null && Series is not null)
{
    <div class="helix-chart" style="@Style" @attributes="AdditionalAttributes">
        <svg width="@Width" height="@Height" viewBox="0 0 @Width @Height"
             role="figure" aria-label="@(AriaLabel ?? Title ?? "Bar chart")"
             class="@CssClass">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(Width / 2)" y="20" text-anchor="middle" class="helix-chart__title">@Title</SvgText>
            }

            @if (ShowGrid)
            {
                @foreach (var tick in _layout.YTicks)
                {
                    var y = _yScale!.Scale(tick.Value);
                    <line x1="@F(_layout.PlotArea.X)" y1="@F(y)" x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(y)"
                          stroke="var(--helix-color-border, #e2e8f0)" stroke-width="1" stroke-dasharray="4,4" />
                }
            }

            @foreach (var tick in _layout.YTicks)
            {
                var y = _yScale!.Scale(tick.Value);
                <SvgText x="@F(_layout.PlotArea.X - 8)" y="@F(y + 4)" text-anchor="end" class="helix-chart__tick-label">@tick.Label</SvgText>
            }

            @* Bars *@
            @for (var di = 0; di < Data.Count; di++)
            {
                var category = XField(Data[di])?.ToString() ?? "";
                var bandX = _bandScale!.Scale(category);
                var groupWidth = _bandScale.BandWidth;
                var barWidth = groupWidth / Series.Count;

                @for (var si = 0; si < Series.Count; si++)
                {
                    var series = Series[si];
                    var value = series.Field(Data[di]);
                    var color = ResolveColor(series.Color, si);
                    var barX = bandX + si * barWidth;
                    var barY = _yScale!.Scale(value);
                    var baseY = _yScale.Scale(0);
                    var barHeight = Math.Abs(baseY - barY);
                    var barTop = Math.Min(barY, baseY);

                    <rect x="@F(barX + 1)" y="@F(barTop)" width="@F(Math.Max(1, barWidth - 2))" height="@F(barHeight)"
                          rx="@(Rounded ? "3" : "0")" fill="@color" class="helix-chart__bar" />
                }

                <SvgText x="@F(bandX + groupWidth / 2)" y="@F(_layout.PlotArea.Y + _layout.PlotArea.Height + 18)"
                      text-anchor="middle" class="helix-chart__tick-label">@category</SvgText>
            }

            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="var(--helix-color-border, #cbd5e1)" stroke-width="1" />
            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y)"
                  x2="@F(_layout.PlotArea.X)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="var(--helix-color-border, #cbd5e1)" stroke-width="1" />
        </svg>

        @if (_layout.Legend.Visible && Series.Count > 1)
        {
            <div class="helix-chart__legend">
                @for (var i = 0; i < Series.Count; i++)
                {
                    var color = ResolveColor(Series[i].Color, i);
                    <span class="helix-chart__legend-item">
                        <span class="helix-chart__legend-swatch" style="background: @color;"></span>
                        @Series[i].Name
                    </span>
                }
            </div>
        }

        <table class="helix-sr-only" aria-label="Chart data">
            <thead><tr><th>Category</th>@foreach (var s in Series) { <th>@s.Name</th> }</tr></thead>
            <tbody>
                @foreach (var item in Data)
                {
                    <tr><td>@XField(item)</td>@foreach (var s in Series) { <td>@s.Field(item)</td> }</tr>
                }
            </tbody>
        </table>
    </div>
}

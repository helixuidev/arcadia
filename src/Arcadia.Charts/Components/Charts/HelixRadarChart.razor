@namespace Arcadia.Charts.Components.Charts
@typeparam T
@inherits Arcadia.Charts.Core.ChartBase<T>

@if (Data is not null && Data.Count > 0 && LabelField is not null && Series is not null && Series.Count > 0)
{
    <div class="arcadia-chart" @ref="ContainerRef" style="@Style" @attributes="AdditionalAttributes">
        <ChartToolbar OnExportPng="@(() => ExportPngAsync())" OnExportSvg="@(() => ExportSvgFileAsync())" />
        <svg width="@EffectiveWidth" height="@Height" viewBox="0 0 @EffectiveWidth @Height"
             role="figure" data-chart="true" aria-label="@(AriaLabel ?? Title ?? "Radar chart")"
             class="@CssClass">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="20" text-anchor="middle" class="arcadia-chart__title">@Title</SvgText>
            }

            @* Grid rings *@
            @for (var ring = 0; ring < GridRings; ring++)
            {
                var localRing = ring;
                var ringPoints = new List<string>();
                for (var j = 0; j < _axisCount; j++)
                {
                    var p = GetGridPoint(j, localRing);
                    ringPoints.Add($"{F(p.X)},{F(p.Y)}");
                }
                <polygon points="@string.Join(" ", ringPoints)"
                         fill="none" stroke="currentColor" stroke-width="1" opacity="0.15" />
            }

            @* Axis lines *@
            @for (var i = 0; i < _axisCount; i++)
            {
                var localI = i;
                var end = GetAxisEndpoint(localI);
                <line x1="@F(_cx)" y1="@F(_cy)" x2="@F(end.X)" y2="@F(end.Y)"
                      stroke="currentColor" opacity="0.12" stroke-width="1" />
            }

            @* Series polygons *@
            @foreach (var poly in _polygons)
            {
                var localPoly = poly;

                @if (ShowFill)
                {
                    <polygon points="@localPoly.PointsString" fill="@localPoly.Color" opacity="@F(localPoly.Opacity)"
                             class="arcadia-chart__radar-fill @(AnimateOnLoad ? "arcadia-animate-radar-fill" : "")" />
                }

                <polygon points="@localPoly.PointsString" fill="none" stroke="@localPoly.Color"
                         stroke-width="@F(localPoly.StrokeWidth)"
                         class="arcadia-chart__radar-line @(AnimateOnLoad ? "arcadia-animate-radar" : "")" />

                @if (ShowPoints)
                {
                    @foreach (var pt in localPoly.Points)
                    {
                        <circle cx="@F(pt.X)" cy="@F(pt.Y)" r="3" fill="@localPoly.Color"
                                class="arcadia-chart__point @(AnimateOnLoad ? "arcadia-animate-point" : "")" />
                    }
                }
            }

            @* Axis labels *@
            @for (var i = 0; i < _labels.Count; i++)
            {
                var localI = i;
                var label = _labels[localI];
                var pos = GetLabelPosition(localI);
                var anchor = GetTextAnchor(localI, _axisCount);
                <SvgText x="@F(pos.X)" y="@F(pos.Y)" text-anchor="@anchor"
                      class="arcadia-chart__tick-label">@label</SvgText>
            }
        </svg>
        <CommunityWatermark />

        @if (ShowLegend && Series.Count > 1)
        {
            <div class="arcadia-chart__legend">
                @for (var i = 0; i < Series.Count; i++)
                {
                    var localI = i;
                    var color = ResolveColor(Series[localI].Color, localI);
                    <span class="arcadia-chart__legend-item">
                        <span class="arcadia-chart__legend-swatch" style="background: @color;"></span>
                        @Series[localI].Name
                    </span>
                }
            </div>
        }

        @* Hidden data table for screen readers *@
        <table class="arcadia-sr-only" aria-label="Chart data">
            <thead><tr><th>Axis</th>@foreach (var s in Series) { <th>@s.Name</th> }</tr></thead>
            <tbody>
                @foreach (var item in Data)
                {
                    <tr>
                        <td>@LabelField(item)</td>
                        @foreach (var s in Series) { <td>@s.Field(item)</td> }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@namespace Arcadia.Charts.Components.Charts
@typeparam T
@inherits Arcadia.Charts.Core.ChartBase<T>

<div class="arcadia-chart @(AwaitingMeasurement || Loading ? "arcadia-chart--loading" : "")" @ref="ContainerRef" style="@GetContainerStyle()" @attributes="AdditionalAttributes">
@if (AwaitingMeasurement) {
}
else if (Data is not null && Data.Count > 0 && XField is not null && Series is not null) {
        @if (ShowToolbar) { <ChartToolbar OnExportPng="@(() => ExportPngAsync())" OnExportSvg="@(() => ExportSvgFileAsync())" /> }
        <svg width="@SvgWidth" height="@Height" viewBox="0 0 @EffectiveWidth @Height"
             role="figure" data-chart="true" aria-label="@(AriaLabel ?? Title ?? "Bar chart")"
             @onmouseleave="HideTooltipAction"
             class="@CssClass">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="20" text-anchor="middle" class="arcadia-chart__title">@Title</SvgText>
            }

            @if (ShowGrid)
            {
                @foreach (var tick in _layout.YTicks)
                {
                    var y = _yScale!.Scale(tick.Value);
                    <line x1="@F(_layout.PlotArea.X)" y1="@F(y)" x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(y)"
                          stroke="currentColor" opacity="@GridOpacity.ToString("F2")" stroke-width="1" stroke-dasharray="4,4" />
                }
            }

            @foreach (var tick in _layout.YTicks)
            {
                var y = _yScale!.Scale(tick.Value);
                <SvgText x="@F(_layout.PlotArea.X - 8)" y="@F(y + 4)" text-anchor="end" class="arcadia-chart__tick-label">@(YAxisFormatString is not null ? tick.Value.ToString(YAxisFormatString, FormatProvider) : tick.Label)</SvgText>
            }

            @* Bars *@
            @foreach (var bar in _bars)
            {
                <rect x="@F(bar.X)" y="@F(bar.Y)" width="@F(bar.Width)" height="@F(bar.Height)"
                      rx="@(Rounded ? $"{CornerRadius}" : "0")" fill="@bar.Color"
                      class="arcadia-chart__bar @(AnimateOnLoad ? "arcadia-animate-bar" : "")"
                      style="@(AnimateOnLoad ? $"animation-delay: {bar.DataIndex * 80 + bar.SeriesIndex * 40}ms;" : "")cursor: @(OnPointClick.HasDelegate ? "pointer" : "default");"
                      @onmouseover="@(e => ShowTooltipForPoint(bar.SeriesName, bar.Value, e.ClientX, e.ClientY))"
                      @onmouseout="HideTooltipAction"
                      @onclick="@(() => HandleBarClick(bar))" />

                @if (ShowDataLabels && bar.Height > 14)
                {
                    <SvgText x="@F(bar.X + bar.Width / 2)" y="@F(bar.Y - 4)" text-anchor="middle"
                          class="arcadia-chart__data-label">@FormatDataLabel(bar.Value)</SvgText>
                }
            }

            @* X-axis labels *@
            @if (_bandScale is not null)
            {
                @for (var di = 0; di < Data.Count; di++)
                {
                    var category = XField(Data[di])?.ToString() ?? "";
                    var bandCenter = _bandScale.ScaleCenter(category);
                    <SvgText x="@F(bandCenter)" y="@F(_layout.PlotArea.Y + _layout.PlotArea.Height + 18)"
                          text-anchor="middle" class="arcadia-chart__tick-label">@category</SvgText>
                }
            }

            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="currentColor" opacity="@AxisLineOpacity.ToString("F2")" stroke-width="1" />
            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y)"
                  x2="@F(_layout.PlotArea.X)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="currentColor" opacity="@AxisLineOpacity.ToString("F2")" stroke-width="1" />
        </svg>

        @if (ShowLegend && _layout.Legend.Visible && Series.Count > 1)
        {
            <div class="arcadia-chart__legend">
                @for (var i = 0; i < Series.Count; i++)
                {
                    var idx = i;
                    var s = Series[i];
                    var color = ResolveColor(s.Color, i);
                    var hidden = !s.Visible;
                    <button type="button"
                            class="arcadia-chart__legend-btn @(hidden ? "arcadia-chart__legend-btn--hidden" : "")"
                            @onclick="() => ToggleSeries(idx)"
                            aria-label="@(hidden ? $"Show {s.Name}" : $"Hide {s.Name}")">
                        <span class="arcadia-chart__legend-swatch" style="background: @(hidden ? "transparent" : color); border: 2px solid @color;"></span>
                        @s.Name
                    </button>
                }
            </div>
        }

        <table class="arcadia-sr-only" aria-label="Chart data">
            <thead><tr><th>Category</th>@foreach (var s in Series) { <th>@s.Name</th> }</tr></thead>
            <tbody>
                @foreach (var item in Data)
                {
                    <tr><td>@XField(item)</td>@foreach (var s in Series) { <td>@FormatSrValue(s.Field(item))</td> }</tr>
                }
            </tbody>
        </table>
        @if (RenderTooltipTemplate is not null) { @RenderTooltipTemplate }
}
else
{
    <NoDataState Message="@(NoDataMessage ?? "No data available")" Height="@Height" />
}
</div>

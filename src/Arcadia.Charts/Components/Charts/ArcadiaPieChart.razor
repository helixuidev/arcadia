@namespace Arcadia.Charts.Components.Charts
@typeparam T
@inherits Arcadia.Charts.Core.ChartBase<T>

<div class="arcadia-chart @(AwaitingMeasurement || Loading ? "arcadia-chart--loading" : "")" @ref="ContainerRef" style="@GetContainerStyle()" @attributes="AdditionalAttributes">
@if (AwaitingMeasurement) {
}
else if (Data is not null && Data.Count > 0 && NameField is not null && ValueField is not null) {
        @if (ShowToolbar) { <ChartToolbar OnExportPng="@(() => ExportPngAsync())" OnExportSvg="@(() => ExportSvgFileAsync())" /> }
        <svg width="@SvgWidth" height="@Height" viewBox="0 0 @EffectiveWidth @Height"
             role="figure" data-chart="true" aria-label="@(AriaLabel ?? Title ?? "Pie chart")"
             class="@CssClass">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="24" text-anchor="middle" class="arcadia-chart__title">@Title</SvgText>
            }

            @* Slices *@
            @for (var i = 0; i < _slices.Count; i++)
            {
                var slice = _slices[i];
                <path d="@slice.Path" fill="@slice.Color" stroke="@SliceStrokeColor" stroke-width="@F(SliceStrokeWidth)"
                      class="arcadia-chart__pie-slice @(AnimateOnLoad ? "arcadia-animate-point" : "")"
                      style="@GetSliceStyle(i)"
                      @onmouseover="@(e => ShowPieTooltip(slice.Name, slice.Value, slice.Percent, e.ClientX, e.ClientY))"
                      @onmouseout="HideTooltipAction"
                      @onclick="@(() => HandleSliceClick(slice.DataIndex))" />

                @if (ShowLabels && slice.Percent >= MinLabelPercent && LabelFormat != PieLabelFormat.None)
                {
                    <SvgText x="@F(slice.LabelX)" y="@F(slice.LabelY)" text-anchor="middle"
                          class="arcadia-chart__pie-label">@slice.LabelText</SvgText>
                }
            }
        </svg>

        @if (ShowLegend)
        {
            <div class="arcadia-chart__legend">
                @for (var i = 0; i < _slices.Count; i++)
                {
                    var slice = _slices[i];
                    <span class="arcadia-chart__legend-item">
                        <span class="arcadia-chart__legend-swatch" style="background: @slice.Color;"></span>
                        @slice.Name (@($"{slice.Percent:F1}%"))
                    </span>
                }
            </div>
        }

        <table class="arcadia-sr-only" aria-label="Chart data">
            <thead><tr><th>Category</th><th>Value</th><th>Percentage</th></tr></thead>
            <tbody>
                @foreach (var slice in _slices)
                {
                    <tr><td>@slice.Name</td><td>@slice.Value</td><td>@($"{slice.Percent:F1}%")</td></tr>
                }
            </tbody>
        </table>
        @if (RenderTooltipTemplate is not null) { @RenderTooltipTemplate }
}
else
{
    <NoDataState Message="@(NoDataMessage ?? "No data available")" Height="@Height" />
}
</div>

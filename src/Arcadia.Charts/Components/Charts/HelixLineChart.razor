@namespace Arcadia.Charts.Components.Charts
@typeparam T
@inherits Arcadia.Charts.Core.ChartBase<T>

@if (Data is not null && Data.Count > 1 && XField is not null && Series is not null)
{
    <div class="arcadia-chart" @ref="ContainerRef" style="@Style" @attributes="AdditionalAttributes">
        <ChartToolbar OnExportPng="@(() => ExportPngAsync())" OnExportSvg="@(() => ExportSvgFileAsync())" />
        <svg width="@EffectiveWidth" height="@Height" viewBox="0 0 @EffectiveWidth @Height"
             role="figure" data-chart="true" aria-label="@(AriaLabel ?? Title ?? "Line chart")"
             class="@CssClass"
             @onmouseleave="HandleMouseLeave"
             @onmousemove="HandleMouseMove">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="20" text-anchor="middle" class="arcadia-chart__title">@Title</SvgText>
            }
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="36" text-anchor="middle" class="arcadia-chart__subtitle">@Subtitle</SvgText>
            }

            @* Grid lines *@
            @if (ShowGrid)
            {
                @foreach (var tick in _layout.YTicks)
                {
                    var y = _yScale!.Scale(tick.Value);
                    <line x1="@F(_layout.PlotArea.X)" y1="@F(y)" x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(y)"
                          stroke="currentColor" opacity="0.12" stroke-width="1" stroke-dasharray="4,4" />
                }
            }

            @* Y-axis labels *@
            @foreach (var tick in _layout.YTicks)
            {
                var y = _yScale!.Scale(tick.Value);
                <SvgText x="@F(_layout.PlotArea.X - 8)" y="@F(y + 4)" text-anchor="end" class="arcadia-chart__tick-label">@(YAxisFormatString is not null ? tick.Value.ToString(YAxisFormatString, FormatProvider) : tick.Label)</SvgText>
            }

            @* X-axis labels *@
            @foreach (var tick in _layout.XTicks)
            {
                <SvgText x="@F(tick.Position)" y="@F(_layout.PlotArea.Y + _layout.PlotArea.Height + 18)"
                      text-anchor="middle"
                      class="arcadia-chart__tick-label">@tick.Label</SvgText>
            }

            @* Clip path for slide animation *@
            @if (SlidingWindow > 0)
            {
                <defs>
                    <clipPath id="arcadia-slide-clip">
                        <rect x="@F(_layout.PlotArea.X)" y="@F(_layout.PlotArea.Y - 10)"
                              width="@F(_layout.PlotArea.Width)" height="@F(_layout.PlotArea.Height + 20)" />
                    </clipPath>
                </defs>
            }

            @* Series *@
            <g class="arcadia-slide-group" clip-path="@(SlidingWindow > 0 ? "url(#arcadia-slide-clip)" : "")">
            @for (var si = 0; si < Series.Count; si++)
            {
                var series = Series[si];
                if (!series.Visible) continue;
                var color = ResolveColor(series.Color, si);

                @if (series.ShowArea && _areaPaths.ContainsKey(si))
                {
                    <path d="@_areaPaths[si]" fill="@color" opacity="@F(series.AreaOpacity)"
                          class="@(AnimateOnLoad ? "arcadia-animate-area" : "")" />
                }

                @if (_paths.ContainsKey(si) && series.SeriesType != "bar")
                {
                    <path d="@_paths[si]" fill="none" stroke="@color" stroke-width="@F(series.StrokeWidth)"
                          stroke-linecap="round" stroke-linejoin="round"
                          stroke-dasharray="@(series.Dashed ? "6,4" : "")"
                          class="arcadia-chart__line @(AnimateOnLoad && !series.Dashed ? "arcadia-animate-line" : "")" />
                }

                @* Trendline *@
                @if (_trendlinePaths.ContainsKey(si) && series.Trendline is not null)
                {
                    var trendColor = series.Trendline.Color ?? color;
                    <path d="@_trendlinePaths[si]" fill="none" stroke="@trendColor"
                          stroke-width="@F(series.Trendline.StrokeWidth)"
                          stroke-dasharray="@(series.Trendline.Dashed ? "8,4" : "")"
                          opacity="0.6" class="arcadia-chart__trendline" />
                }

                @* Bar series rendering (for combo charts) *@
                @if (series.SeriesType == "bar" && _dataPoints.ContainsKey(si))
                {
                    var barWidth = (_layout.PlotArea.Width / Data.Count) * 0.6;
                    var zeroY = _yScale!.Scale(0);
                    @foreach (var pt in _dataPoints[si])
                    {
                        var barX = pt.X - barWidth / 2;
                        var barY = Math.Min(pt.Y, zeroY);
                        var barH = Math.Abs(pt.Y - zeroY);
                        <rect x="@F(barX)" y="@F(barY)" width="@F(barWidth)" height="@F(Math.Max(1, barH))"
                              rx="3" fill="@color" opacity="0.8"
                              class="arcadia-chart__bar @(AnimateOnLoad ? "arcadia-animate-bar" : "")"
                              @onmouseover="@(e => ShowTooltipForPoint(series.Name, pt.Value, e.ClientX, e.ClientY))"
                              @onmouseout="HideTooltipAction" />
                    }
                }

                @* Data points *@
                @if (ShowPoints && _dataPoints.ContainsKey(si) && series.SeriesType != "bar")
                {
                    @foreach (var pt in _dataPoints[si])
                    {
                        <circle cx="@F(pt.X)" cy="@F(pt.Y)" r="3" fill="@color"
                                class="arcadia-chart__point @(AnimateOnLoad ? "arcadia-animate-point" : "")"
                                style="@(AnimateOnLoad ? $"animation-delay: {pt.Index * 40}ms;" : "")"
                                @onmouseover="@(e => ShowTooltipForPoint(series.Name, pt.Value, e.ClientX, e.ClientY))"
                                @onmouseout="HideTooltipAction" />
                    }
                }

                @* Data labels *@
                @if (ShowDataLabels && _dataPoints.ContainsKey(si))
                {
                    @foreach (var pt in _dataPoints[si])
                    {
                        <SvgText x="@F(pt.X)" y="@F(pt.Y - 8)" text-anchor="middle" class="arcadia-chart__data-label">@FormatDataLabel(pt.Value)</SvgText>
                    }
                }
            }
            </g>

            @* Crosshair *@
            @if (ShowCrosshair)
            {
                <line x1="@F(_crosshairX)" y1="@F(_layout.PlotArea.Y)" x2="@F(_crosshairX)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                      stroke="var(--arcadia-color-text-muted, #94a3b8)" stroke-width="1" stroke-dasharray="3,3"
                      opacity="@(_crosshairVisible ? "0.6" : "0")" />
            }

            @* Annotations *@
            @if (Annotations is not null)
            {
                @foreach (var ann in Annotations)
                {
                    if (ann.DataIndex >= 0 && ann.DataIndex < Data.Count)
                    {
                        var ax = _layout.PlotArea.X + (ann.DataIndex + 0.5) * (_layout.PlotArea.Width / Data.Count);
                        @if (ann.ShowLine)
                        {
                            <line x1="@F(ax)" y1="@F(_layout.PlotArea.Y)" x2="@F(ax)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                                  stroke="@ann.Color" stroke-width="1" stroke-dasharray="4,3" opacity="0.7" />
                        }
                        <SvgText x="@F(ax)" y="@F(_layout.PlotArea.Y + 14)" text-anchor="middle"
                              style="@($"font-size:10px; fill:{ann.Color}; font-weight:600; background: var(--g-card, rgba(0,0,0,0.5));")">@ann.Label</SvgText>
                    }
                }
            }

            @* Axis lines *@
            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  x2="@F(_layout.PlotArea.X + _layout.PlotArea.Width)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="currentColor" opacity="0.2" stroke-width="1" />
            <line x1="@F(_layout.PlotArea.X)" y1="@F(_layout.PlotArea.Y)"
                  x2="@F(_layout.PlotArea.X)" y2="@F(_layout.PlotArea.Y + _layout.PlotArea.Height)"
                  stroke="currentColor" opacity="0.2" stroke-width="1" />
        </svg>

        @* Legend (clickable to toggle series) *@
        @if (ShowLegend && _layout.Legend.Visible && Series.Count > 1)
        {
            <div class="arcadia-chart__legend">
                @for (var i = 0; i < Series.Count; i++)
                {
                    var idx = i;
                    var s = Series[i];
                    var color = ResolveColor(s.Color, i);
                    var hidden = !s.Visible;
                    <button type="button"
                            class="arcadia-chart__legend-btn @(hidden ? "arcadia-chart__legend-btn--hidden" : "")"
                            @onclick="() => ToggleSeries(idx)"
                            aria-label="@(hidden ? $"Show {s.Name}" : $"Hide {s.Name}")">
                        <span class="arcadia-chart__legend-swatch" style="background: @(hidden ? "transparent" : color); border: 2px solid @color;"></span>
                        @s.Name
                    </button>
                }
            </div>
        }

        @* Hidden data table for screen readers *@
        <table class="arcadia-sr-only" aria-label="Chart data">
            <thead><tr><th>@XAxisTitle</th>@foreach (var s in Series) { <th>@s.Name</th> }</tr></thead>
            <tbody>
                @foreach (var item in Data)
                {
                    <tr>
                        <td>@XField(item)</td>
                        @foreach (var s in Series) { <td>@s.Field(item)</td> }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

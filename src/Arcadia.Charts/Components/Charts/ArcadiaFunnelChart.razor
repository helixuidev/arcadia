@namespace Arcadia.Charts.Components.Charts
@typeparam T
@inherits Arcadia.Charts.Core.ChartBase<T>

<div class="arcadia-chart @(AwaitingMeasurement || Loading ? "arcadia-chart--loading" : "")" @ref="ContainerRef" style="@GetContainerStyle()" @attributes="AdditionalAttributes">
@if (AwaitingMeasurement) {
}
else if (HasData && NameField is not null && ValueField is not null) {
        @if (ShowToolbar) { <ChartToolbar OnExportPng="@(() => ExportPngAsync())" OnExportSvg="@(() => ExportSvgFileAsync())" /> }
        <svg width="@SvgWidth" height="@Height" viewBox="0 0 @EffectiveWidth @Height"
             role="figure" data-chart="true" aria-label="@(AriaLabel ?? Title ?? "Funnel chart")">

            @if (!string.IsNullOrEmpty(Title))
            {
                <SvgText x="@(EffectiveWidth / 2)" y="24" text-anchor="middle" class="arcadia-chart__title">@Title</SvgText>
            }

            @for (var i = 0; i < _stages.Count; i++)
            {
                var s = _stages[i];
                <path d="@s.Path" fill="@s.Color" opacity="@F(StageOpacity)"
                      class="arcadia-chart__bar @(AnimateOnLoad && ShouldStagger(_stages.Count) ? "arcadia-animate-bar" : "")"
                      style="@(AnimateOnLoad && ShouldStagger(_stages.Count) ? $"animation-delay: {GetAnimationDelay(i, _stages.Count, 100)}ms;" : "")"
                      @onmouseover="@(e => ShowTooltipForPoint(s.Name, s.Value, e.ClientX, e.ClientY))"
                      @onmouseout="HideTooltipAction" />

                <SvgText x="@F(Width / 2)" y="@F(s.LabelY)" text-anchor="middle"
                      class="arcadia-chart__pie-label" style="@($"fill: {StageLabelColor}; font-size: 12px;")">@s.Name</SvgText>
                <SvgText x="@F(Width / 2)" y="@F(s.LabelY + 16)" text-anchor="middle"
                      style="fill: rgba(255,255,255,0.7); font-size: 11px;">@($"{s.Percent:F1}%")</SvgText>
            }
        </svg>

        <table class="arcadia-sr-only" aria-label="Chart data">
            <thead><tr><th>Stage</th><th>Value</th><th>Percentage</th></tr></thead>
            <tbody>
                @foreach (var s in _stages)
                {
                    <tr><td>@s.Name</td><td>@s.Value</td><td>@($"{s.Percent:F1}%")</td></tr>
                }
            </tbody>
        </table>
}
else
{
    <NoDataState Message="@(NoDataMessage ?? "No data available")" Height="@Height" />
}
</div>

@namespace Arcadia.Charts.Components.Dashboard
@inherits Arcadia.Core.Base.HelixComponentBase

<div class="@CssClass" role="img" aria-label="@($"Activity tracker from {StartDate:d}")"
     @attributes="AdditionalAttributes">
    <div class="arcadia-tracker__grid" style="@GridStyle">
        @foreach (var day in _days)
        {
            <div class="arcadia-tracker__cell arcadia-tracker__cell--@day.Level"
                 title="@($"{day.Date:d}: {day.Value}")"></div>
        }
    </div>
</div>

@code {
    /// <summary>Map of dates to values.</summary>
    [Parameter] public IReadOnlyDictionary<DateTime, double>? Data { get; set; }

    /// <summary>Start date for the tracker grid.</summary>
    [Parameter] public DateTime StartDate { get; set; } = DateTime.Today.AddMonths(-6);

    /// <summary>Number of weeks to show.</summary>
    [Parameter] public int Weeks { get; set; } = 26;

    /// <summary>Color scale name.</summary>
    [Parameter] public string ColorScale { get; set; } = "success";

    private List<TrackerDay> _days = new();
    private string GridStyle => $"grid-template-columns: repeat({Weeks}, 1fr); grid-template-rows: repeat(7, 1fr);";

    protected override void OnParametersSet()
    {
        _days.Clear();
        var start = StartDate.Date;
        // Align to start of week (Monday)
        start = start.AddDays(-(int)start.DayOfWeek + 1);
        if (start.DayOfWeek == DayOfWeek.Sunday) start = start.AddDays(-6);

        var allValues = Data?.Values.ToList() ?? new List<double>();
        var maxValue = allValues.Count > 0 ? allValues.Max() : 1.0;

        for (var w = 0; w < Weeks; w++)
        {
            for (var d = 0; d < 7; d++)
            {
                var date = start.AddDays(w * 7 + d);
                var value = Data?.TryGetValue(date, out var v) == true ? v : 0;
                var level = maxValue > 0 ? (int)Math.Ceiling(value / maxValue * 4) : 0;
                level = Math.Clamp(level, 0, 4);
                _days.Add(new TrackerDay(date, value, level));
            }
        }
    }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-tracker")
        .AddClass(Class)
        .Build();

    private record TrackerDay(DateTime Date, double Value, int Level);
}

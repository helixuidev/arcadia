@namespace Arcadia.FormBuilder.Components
@inherits Arcadia.Core.Base.HelixComponentBase

<HelixForm Schema="@Schema"
           State="@State"
           OnValidSubmit="OnValidSubmit"
           OnInvalidSubmit="OnInvalidSubmit"
           ShowErrorSummary="@ShowErrorSummary"
           Validators="@Validators"
           Class="@Class"
           Style="@Style">

    @if (!string.IsNullOrEmpty(Schema?.Title))
    {
        <h2 class="arcadia-form-builder__title">@Schema.Title</h2>
    }
    @if (!string.IsNullOrEmpty(Schema?.Description))
    {
        <p class="arcadia-form-builder__description">@Schema.Description</p>
    }

    @* Render root-level fields *@
    @if (Schema?.Fields.Count > 0)
    {
        <div class="arcadia-form-builder__fields" style="@GridStyle(Schema.Columns)">
            @foreach (var field in Schema.Fields)
            {
                @RenderField(field)
            }
        </div>
    }

    @* Render sections *@
    @foreach (var formSection in Schema?.Sections ?? new())
    {
        <FormSection Title="@formSection.Title"
                     Description="@formSection.Description"
                     Columns="@(formSection.Columns ?? Schema!.Columns)"
                     Collapsible="@formSection.Collapsible"
                     Collapsed="@formSection.Collapsed">
            @foreach (var field in formSection.Fields)
            {
                @RenderField(field)
            }
        </FormSection>
    }

    <FormActions SubmitText="@(Schema?.SubmitText ?? "Submit")"
                 CancelText="@Schema?.CancelText"
                 ShowCancel="@(Schema?.CancelText is not null)"
                 OnCancel="OnCancel" />
</HelixForm>

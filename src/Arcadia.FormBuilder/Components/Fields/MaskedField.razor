@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <input id="@ElementId"
           type="text"
           class="arcadia-field__input"
           value="@DisplayValue"
           placeholder="@(EffectivePlaceholder ?? Mask)"
           disabled="@EffectiveDisabled"
           readonly="@ReadOnly"
           required="@EffectiveRequired"
           aria-required="@(EffectiveRequired ? "true" : null)"
           aria-invalid="@(HasErrors ? "true" : null)"
           aria-describedby="@AriaDescribedBy"
           @oninput="HandleInput"
           @attributes="AdditionalAttributes" />

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// The input mask pattern. Use # for digits, A for letters, * for any character.
    /// Examples: "(###) ###-####", "###-##-####", "AA-####"
    /// </summary>
    [Parameter] public string Mask { get; set; } = "";

    private string? DisplayValue => ApplyMask(Value);

    private async Task HandleInput(ChangeEventArgs e)
    {
        var raw = StripMask(e.Value?.ToString());
        Value = raw;
        await ValueChanged.InvokeAsync(Value);
    }

    private string? ApplyMask(string? raw)
    {
        if (string.IsNullOrEmpty(raw) || string.IsNullOrEmpty(Mask)) return raw;

        var result = new System.Text.StringBuilder();
        var rawIdx = 0;

        foreach (var maskChar in Mask)
        {
            if (rawIdx >= raw.Length) break;

            if (maskChar == '#' || maskChar == 'A' || maskChar == '*')
            {
                result.Append(raw[rawIdx]);
                rawIdx++;
            }
            else
            {
                result.Append(maskChar);
            }
        }

        return result.ToString();
    }

    private static string? StripMask(string? input)
    {
        if (string.IsNullOrEmpty(input)) return input;
        var sb = new System.Text.StringBuilder();
        foreach (var c in input)
        {
            if (char.IsLetterOrDigit(c))
                sb.Append(c);
        }
        return sb.Length > 0 ? sb.ToString() : null;
    }
}

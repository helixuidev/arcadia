@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <select id="@ElementId"
            class="arcadia-field__input arcadia-field__select"
            disabled="@EffectiveDisabled"
            required="@EffectiveRequired"
            aria-required="@(EffectiveRequired ? "true" : null)"
            aria-invalid="@(HasErrors ? "true" : null)"
            aria-describedby="@AriaDescribedBy"
            @onchange="HandleChange"
            @attributes="AdditionalAttributes">

        @if (!string.IsNullOrEmpty(EffectivePlaceholder))
        {
            <option value="" disabled selected="@(string.IsNullOrEmpty(Value))">@EffectivePlaceholder</option>
        }

        @foreach (var option in EffectiveOptions)
        {
            <option value="@option.Value" disabled="@option.Disabled" selected="@(option.Value == Value)">@option.Label</option>
        }
    </select>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the value of the currently selected option. Supports two-way binding.
    /// </summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>
    /// Callback invoked when the user selects a different option, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the list of selectable options. When null, options are resolved from the field's schema definition.
    /// Provide this parameter to override schema-driven options or when using the component outside of a FormBuilder.
    /// </summary>
    [Parameter] public List<Schema.FieldOption>? Options { get; set; }

    private IReadOnlyList<Schema.FieldOption> EffectiveOptions =>
        Options ?? Schema?.Options ?? new List<Schema.FieldOption>();

    private async Task HandleChange(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}

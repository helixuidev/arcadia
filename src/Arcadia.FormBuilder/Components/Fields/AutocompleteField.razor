@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <div class="arcadia-field__autocomplete-wrapper">
        <input id="@ElementId"
               type="text"
               class="arcadia-field__input"
               value="@Value"
               placeholder="@EffectivePlaceholder"
               disabled="@EffectiveDisabled"
               readonly="@ReadOnly"
               required="@EffectiveRequired"
               role="combobox"
               autocomplete="off"
               aria-expanded="@(_showDropdown ? "true" : "false")"
               aria-controls="@ListId"
               aria-required="@(EffectiveRequired ? "true" : null)"
               aria-invalid="@(HasErrors ? "true" : null)"
               aria-describedby="@AriaDescribedBy"
               @oninput="HandleInput"
               @onfocus="() => _showDropdown = true"
               @onblur="HandleBlur"
               @attributes="AdditionalAttributes" />

        @if (_showDropdown && FilteredOptions.Any())
        {
            <ul id="@ListId" class="arcadia-field__autocomplete-list" role="listbox">
                @foreach (var option in FilteredOptions)
                {
                    <li class="arcadia-field__autocomplete-option"
                        role="option"
                        @onmousedown="() => SelectOption(option)">
                        @option.Label
                    </li>
                }
            </ul>
        }
    </div>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public List<Schema.FieldOption>? Options { get; set; }

    private bool _showDropdown;
    private string ListId => $"{ElementId}-list";

    private IReadOnlyList<Schema.FieldOption> EffectiveOptions =>
        Options ?? Schema?.Options ?? new List<Schema.FieldOption>();

    private IEnumerable<Schema.FieldOption> FilteredOptions =>
        string.IsNullOrEmpty(Value)
            ? EffectiveOptions
            : EffectiveOptions.Where(o =>
                o.Label.Contains(Value, StringComparison.OrdinalIgnoreCase));

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        _showDropdown = true;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task SelectOption(Schema.FieldOption option)
    {
        Value = option.Value;
        _showDropdown = false;
        await ValueChanged.InvokeAsync(Value);
    }

    private void HandleBlur()
    {
        // Small delay allows mousedown on option to fire first
        _showDropdown = false;
    }
}

@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" id="@($"{ElementId}-label")">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <div class="arcadia-field__rating"
         role="radiogroup"
         aria-labelledby="@($"{ElementId}-label")"
         aria-required="@(EffectiveRequired ? "true" : null)"
         aria-invalid="@(HasErrors ? "true" : null)"
         aria-describedby="@AriaDescribedBy">
        @for (var i = 1; i <= MaxRating; i++)
        {
            var rating = i;
            var isActive = rating <= Value;
            <button type="button"
                    class="arcadia-field__rating-star @(isActive ? "arcadia-field__rating-star--active" : "")"
                    role="radio"
                    aria-checked="@(rating == Value ? "true" : "false")"
                    aria-label="@($"{rating} of {MaxRating}")"
                    disabled="@EffectiveDisabled"
                    @onclick="() => SetRating(rating)">
                @(isActive ? "★" : "☆")
            </button>
        }
        @if (Value > 0 && ShowClear)
        {
            <button type="button"
                    class="arcadia-field__rating-clear"
                    aria-label="Clear rating"
                    disabled="@EffectiveDisabled"
                    @onclick="ClearRating">
                ✕
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the current rating as an integer from 0 (no rating) up to <see cref="MaxRating"/>. Supports two-way binding.
    /// </summary>
    [Parameter] public int Value { get; set; }

    /// <summary>
    /// Callback invoked when the user selects or clears a rating, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the highest selectable rating value, which determines how many stars are rendered. Defaults to 5.
    /// Increase this for scales that require finer granularity (e.g., 10-point reviews).
    /// </summary>
    [Parameter] public int MaxRating { get; set; } = 5;

    /// <summary>
    /// Gets or sets whether a clear button appears after the user has selected a rating. Defaults to true.
    /// Set to false when a rating is mandatory and the user should not be able to revert to an unrated state.
    /// </summary>
    [Parameter] public bool ShowClear { get; set; } = true;

    private async Task SetRating(int rating)
    {
        Value = rating;
        await ValueChanged.InvokeAsync(Value);
    }

    private async Task ClearRating()
    {
        Value = 0;
        await ValueChanged.InvokeAsync(Value);
    }
}

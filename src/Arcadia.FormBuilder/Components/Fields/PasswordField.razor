@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <div class="arcadia-field__password-wrapper">
        <input id="@ElementId"
               type="@(_visible ? "text" : "password")"
               class="arcadia-field__input arcadia-field__password-input"
               value="@Value"
               placeholder="@EffectivePlaceholder"
               disabled="@EffectiveDisabled"
               readonly="@ReadOnly"
               required="@EffectiveRequired"
               autocomplete="@(IsNew ? "new-password" : "current-password")"
               aria-required="@(EffectiveRequired ? "true" : null)"
               aria-invalid="@(HasErrors ? "true" : null)"
               aria-describedby="@AriaDescribedBy"
               @oninput="HandleInput"
               @attributes="AdditionalAttributes" />
        <button type="button"
                class="arcadia-field__password-toggle"
                aria-label="@(_visible ? "Hide password" : "Show password")"
                @onclick="ToggleVisibility">
            @(_visible ? "Hide" : "Show")
        </button>
    </div>

    @if (ShowStrength && !string.IsNullOrEmpty(Value))
    {
        <div class="arcadia-field__password-strength">
            <div class="arcadia-field__password-strength-bar" style="width: @(StrengthPercent)%; background: @StrengthColor;"></div>
        </div>
        <div class="arcadia-field__helper">@StrengthLabel</div>
    }

    @if (!string.IsNullOrEmpty(EffectiveHelperText) && (string.IsNullOrEmpty(Value) || !ShowStrength))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public bool ShowStrength { get; set; } = true;
    [Parameter] public bool IsNew { get; set; } = true;

    private bool _visible;

    private void ToggleVisibility() => _visible = !_visible;

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }

    private int StrengthScore
    {
        get
        {
            if (string.IsNullOrEmpty(Value)) return 0;
            var score = 0;
            if (Value.Length >= 8) score++;
            if (Value.Length >= 12) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(Value, @"[a-z]") &&
                System.Text.RegularExpressions.Regex.IsMatch(Value, @"[A-Z]")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(Value, @"\d")) score++;
            if (System.Text.RegularExpressions.Regex.IsMatch(Value, @"[^a-zA-Z\d]")) score++;
            return score;
        }
    }

    private int StrengthPercent => StrengthScore * 20;
    private string StrengthColor => StrengthScore switch
    {
        <= 1 => "var(--arcadia-color-danger)",
        2 => "var(--arcadia-color-warning)",
        3 => "var(--arcadia-color-warning)",
        4 => "var(--arcadia-color-success)",
        _ => "var(--arcadia-color-success)"
    };
    private string StrengthLabel => StrengthScore switch
    {
        <= 1 => "Weak",
        2 => "Fair",
        3 => "Good",
        4 => "Strong",
        _ => "Very strong"
    };
}

@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </label>

    <textarea id="@ElementId"
              class="arcadia-field__input arcadia-field__textarea"
              placeholder="@EffectivePlaceholder"
              disabled="@EffectiveDisabled"
              readonly="@ReadOnly"
              required="@EffectiveRequired"
              rows="@Rows"
              aria-required="@(EffectiveRequired ? "true" : null)"
              aria-invalid="@(HasErrors ? "true" : null)"
              aria-describedby="@AriaDescribedBy"
              @oninput="HandleInput"
              @attributes="AdditionalAttributes">@Value</textarea>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the current multi-line text content. Supports two-way binding.
    /// </summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>
    /// Callback invoked whenever the user modifies the textarea content, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the visible number of text rows in the textarea. Defaults to 4.
    /// Increase this for fields that typically contain longer content such as descriptions or comments.
    /// </summary>
    [Parameter] public int Rows { get; set; } = 4;

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}

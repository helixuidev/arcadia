@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__switch-label" for="@ElementId">
        <span class="arcadia-field__switch-track" aria-hidden="true">
            <input id="@ElementId"
                   type="checkbox"
                   role="switch"
                   class="arcadia-field__switch-input"
                   checked="@Value"
                   disabled="@EffectiveDisabled"
                   aria-checked="@(Value ? "true" : "false")"
                   aria-describedby="@AriaDescribedBy"
                   @onchange="HandleChange"
                   @attributes="AdditionalAttributes" />
            <span class="arcadia-field__switch-thumb"></span>
        </span>
        <span class="arcadia-field__switch-text">
            @EffectiveLabel
        </span>
    </label>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets whether the toggle switch is currently in the on position. Supports two-way binding.
    /// </summary>
    [Parameter] public bool Value { get; set; }

    /// <summary>
    /// Callback invoked when the user flips the toggle switch, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }

    private async Task HandleChange(ChangeEventArgs e)
    {
        Value = bool.TryParse(e.Value?.ToString(), out var val) && val;
        await ValueChanged.InvokeAsync(Value);
    }
}

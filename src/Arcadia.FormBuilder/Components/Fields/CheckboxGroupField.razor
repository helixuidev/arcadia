@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<fieldset class="@ContainerClass" @attributes="AdditionalAttributes">
    <legend class="arcadia-field__label">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
    </legend>

    <div class="arcadia-field__checkbox-group"
         role="group"
         aria-required="@(EffectiveRequired ? "true" : null)"
         aria-invalid="@(HasErrors ? "true" : null)"
         aria-describedby="@AriaDescribedBy">
        @foreach (var option in EffectiveOptions)
        {
            var optionId = $"{ElementId}-{option.Value}";
            var isChecked = Values.Contains(option.Value);
            <label class="arcadia-field__checkbox-label" for="@optionId">
                <input id="@optionId"
                       type="checkbox"
                       class="arcadia-field__checkbox"
                       checked="@isChecked"
                       disabled="@(EffectiveDisabled || option.Disabled)"
                       @onchange="() => ToggleValue(option.Value)" />
                <span class="arcadia-field__checkbox-text">@option.Label</span>
            </label>
        }
    </div>

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</fieldset>

@code {
    /// <summary>
    /// Gets or sets the list of currently checked option values. Defaults to an empty list.
    /// Supports two-way binding for tracking which checkboxes in the group are selected.
    /// </summary>
    [Parameter] public List<string> Values { get; set; } = new();

    /// <summary>
    /// Callback invoked whenever a checkbox in the group is checked or unchecked, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<List<string>> ValuesChanged { get; set; }

    /// <summary>
    /// Gets or sets the list of available checkbox options. When null, options are resolved from the field's schema definition.
    /// Provide this parameter to override schema-driven options or when using the component outside of a FormBuilder.
    /// </summary>
    [Parameter] public List<Arcadia.FormBuilder.Schema.FieldOption>? Options { get; set; }

    private IReadOnlyList<Arcadia.FormBuilder.Schema.FieldOption> EffectiveOptions =>
        Options ?? Schema?.Options ?? new List<Arcadia.FormBuilder.Schema.FieldOption>();

    private async Task ToggleValue(string val)
    {
        if (Values.Contains(val))
            Values.Remove(val);
        else
            Values.Add(val);
        await ValuesChanged.InvokeAsync(Values);
    }
}

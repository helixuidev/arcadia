@namespace Arcadia.FormBuilder.Components.Fields
@inherits FieldBase

<div class="@ContainerClass">
    <label class="arcadia-field__label" for="@ElementId">
        @EffectiveLabel
        @if (EffectiveRequired) { <span class="arcadia-field__required" aria-hidden="true">*</span> }
        <span class="arcadia-field__slider-value" aria-hidden="true">@Value</span>
    </label>

    <input id="@ElementId"
           type="range"
           class="arcadia-field__slider"
           value="@Value"
           min="@Min"
           max="@Max"
           step="@Step"
           disabled="@EffectiveDisabled"
           aria-valuemin="@Min"
           aria-valuemax="@Max"
           aria-valuenow="@Value"
           aria-required="@(EffectiveRequired ? "true" : null)"
           aria-describedby="@AriaDescribedBy"
           @oninput="HandleInput"
           @attributes="AdditionalAttributes" />

    @if (ShowMinMax)
    {
        <div class="arcadia-field__slider-labels">
            <span>@Min</span>
            <span>@Max</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(EffectiveHelperText))
    {
        <div id="@HelperId" class="arcadia-field__helper">@EffectiveHelperText</div>
    }

    @if (HasErrors)
    {
        <div id="@ErrorId" class="arcadia-field__errors" role="alert">
            @foreach (var error in Errors!)
            {
                <div class="arcadia-field__error">@error</div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the current position of the slider thumb. Supports two-way binding.
    /// </summary>
    [Parameter] public double Value { get; set; }

    /// <summary>
    /// Callback invoked as the user drags the slider thumb, enabling two-way binding with the parent component.
    /// </summary>
    [Parameter] public EventCallback<double> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the lower bound of the slider range. Defaults to 0.
    /// </summary>
    [Parameter] public double Min { get; set; } = 0;

    /// <summary>
    /// Gets or sets the upper bound of the slider range. Defaults to 100.
    /// </summary>
    [Parameter] public double Max { get; set; } = 100;

    /// <summary>
    /// Gets or sets the increment between selectable values on the slider. Defaults to 1.
    /// Use a smaller step (e.g., 0.1) for finer granularity, or a larger step to snap to coarser intervals.
    /// </summary>
    [Parameter] public double Step { get; set; } = 1;

    /// <summary>
    /// Gets or sets whether the minimum and maximum values are displayed as labels beneath the slider track. Defaults to true.
    /// Set to false when the surrounding layout already communicates the range or when a cleaner appearance is preferred.
    /// </summary>
    [Parameter] public bool ShowMinMax { get; set; } = true;

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out var val))
        {
            Value = val;
            await ValueChanged.InvokeAsync(Value);
        }
    }
}

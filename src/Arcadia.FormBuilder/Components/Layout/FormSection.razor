@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<fieldset class="@CssClass" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Title))
    {
        <legend class="arcadia-form-section__title">
            @if (Collapsible)
            {
                <button type="button"
                        class="arcadia-form-section__toggle"
                        aria-expanded="@(!_collapsed)"
                        @onclick="ToggleCollapsed">
                    @Title
                    <span class="arcadia-form-section__chevron" aria-hidden="true">@(_collapsed ? "+" : "−")</span>
                </button>
            }
            else
            {
                @Title
            }
        </legend>
    }

    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="arcadia-form-section__description">@Description</p>
    }

    @if (!_collapsed)
    {
        <div class="arcadia-form-section__content" style="@GridStyle">
            @ChildContent
        </div>
    }
</fieldset>

@code {
    /// <summary>
    /// Gets or sets the section title rendered as a <c>&lt;legend&gt;</c> inside the fieldset.
    /// </summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the optional description text displayed below the section title.
    /// </summary>
    [Parameter] public string? Description { get; set; }

    /// <summary>
    /// Gets or sets the number of equal-width columns for the section content grid. Defaults to 1.
    /// Values greater than 1 enable a CSS grid layout for the section body.
    /// </summary>
    [Parameter] public int Columns { get; set; } = 1;

    /// <summary>
    /// Gets or sets whether the section can be collapsed and expanded by the user.
    /// When <c>true</c>, a toggle button is rendered in the legend.
    /// </summary>
    [Parameter] public bool Collapsible { get; set; }

    /// <summary>
    /// Gets or sets the initial collapsed state of the section. Only applies when <see cref="Collapsible"/> is <c>true</c>.
    /// </summary>
    [Parameter] public bool Collapsed { get; set; }

    /// <summary>
    /// Gets or sets the child content rendered inside the section body.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _collapsed;

    protected override void OnInitialized() => _collapsed = Collapsed;

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private string? GridStyle => Columns > 1
        ? $"display: grid; grid-template-columns: repeat({Columns}, 1fr); gap: var(--arcadia-spacing-md);"
        : null;

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-section")
        .AddClass("arcadia-form-section--collapsible", Collapsible)
        .AddClass("arcadia-form-section--collapsed", _collapsed)
        .AddClass(Class)
        .Build();
}

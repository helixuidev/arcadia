@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<div class="@CssClass" role="separator" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="arcadia-form-divider__label">@Label</span>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the optional text label displayed inline on the divider.
    /// When set, the divider renders a centered label; when <c>null</c>, a plain horizontal rule is shown.
    /// </summary>
    [Parameter] public string? Label { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-divider")
        .AddClass("arcadia-form-divider--labeled", !string.IsNullOrEmpty(Label))
        .AddClass(Class)
        .Build();
}

@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.HelixComponentBase

<div class="@CssClass" @attributes="AdditionalAttributes">
    @if (ShowCancel)
    {
        <button type="button"
                class="arcadia-form-actions__cancel"
                disabled="@Disabled"
                @onclick="OnCancel">
            @CancelText
        </button>
    }

    <button type="submit"
            class="arcadia-form-actions__submit"
            disabled="@(Disabled || IsSubmitting)">
        @if (IsSubmitting)
        {
            <span class="arcadia-form-actions__spinner" aria-hidden="true"></span>
            <span>@SubmittingText</span>
        }
        else
        {
            @SubmitText
        }
    </button>
</div>

@code {
    [Parameter] public string SubmitText { get; set; } = "Submit";
    [Parameter] public string? CancelText { get; set; } = "Cancel";
    [Parameter] public string SubmittingText { get; set; } = "Submitting...";
    [Parameter] public bool ShowCancel { get; set; } = true;
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-actions")
        .AddClass(Class)
        .Build();
}

@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<div class="@CssClass" @attributes="AdditionalAttributes">
    @if (ShowCancel)
    {
        <button type="button"
                class="arcadia-form-actions__cancel"
                disabled="@Disabled"
                @onclick="OnCancel">
            @CancelText
        </button>
    }

    <button type="submit"
            class="arcadia-form-actions__submit"
            disabled="@(Disabled || IsSubmitting)">
        @if (IsSubmitting)
        {
            <span class="arcadia-form-actions__spinner" aria-hidden="true"></span>
            <span>@SubmittingText</span>
        }
        else
        {
            @SubmitText
        }
    </button>
</div>

@code {
    /// <summary>
    /// Gets or sets the label text displayed on the submit button. Defaults to "Submit".
    /// </summary>
    [Parameter] public string SubmitText { get; set; } = "Submit";

    /// <summary>
    /// Gets or sets the label text displayed on the cancel button. Defaults to "Cancel".
    /// </summary>
    [Parameter] public string? CancelText { get; set; } = "Cancel";

    /// <summary>
    /// Gets or sets the label text displayed on the submit button while a submission is in progress. Defaults to "Submitting...".
    /// </summary>
    [Parameter] public string SubmittingText { get; set; } = "Submitting...";

    /// <summary>
    /// Gets or sets whether the cancel button is visible. Defaults to <c>true</c>.
    /// </summary>
    [Parameter] public bool ShowCancel { get; set; } = true;

    /// <summary>
    /// Gets or sets whether a form submission is currently in progress. When <c>true</c>, the submit button shows a spinner and the <see cref="SubmittingText"/> label.
    /// </summary>
    [Parameter] public bool IsSubmitting { get; set; }

    /// <summary>
    /// Gets or sets whether both the submit and cancel buttons are disabled.
    /// </summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the cancel button is clicked.
    /// </summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-actions")
        .AddClass(Class)
        .Build();
}

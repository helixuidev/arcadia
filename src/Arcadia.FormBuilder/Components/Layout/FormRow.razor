@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<div class="@CssClass" style="@Style" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Gets or sets the child content rendered inside the grid row.
    /// </summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the number of equal-width columns in the grid layout. Defaults to 2.
    /// </summary>
    [Parameter] public int Columns { get; set; } = 2;

    /// <summary>
    /// Gets or sets the CSS gap value between grid cells. Defaults to the <c>--arcadia-spacing-md</c> design token.
    /// </summary>
    [Parameter] public string Gap { get; set; } = "var(--arcadia-spacing-md)";

    private new string? Style => Arcadia.Core.Utilities.StyleBuilder.Default()
        .AddStyle("display", "grid")
        .AddStyle("grid-template-columns", $"repeat({Columns}, 1fr)")
        .AddStyle("gap", Gap)
        .AddRaw(base.Style)
        .Build();

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-row")
        .AddClass(Class)
        .Build();
}

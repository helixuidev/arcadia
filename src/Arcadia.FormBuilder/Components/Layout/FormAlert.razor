@namespace Arcadia.FormBuilder.Components.Layout
@inherits Arcadia.Core.Base.HelixComponentBase

<div class="@CssClass" role="@(Level == "error" ? "alert" : "status")" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Title))
    {
        <strong class="arcadia-form-alert__title">@Title</strong>
    }
    <div class="arcadia-form-alert__message">@ChildContent</div>
</div>

@code {
    /// <summary>
    /// Gets or sets the alert level: "info", "success", "warning", "error".
    /// </summary>
    [Parameter] public string Level { get; set; } = "info";

    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-form-alert")
        .AddClass($"arcadia-form-alert--{Level}")
        .AddClass(Class)
        .Build();
}

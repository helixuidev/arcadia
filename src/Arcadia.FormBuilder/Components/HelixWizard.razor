@namespace Arcadia.FormBuilder.Components
@inherits Arcadia.Core.Base.HelixComponentBase

<div class="@CssClass" @attributes="AdditionalAttributes">
    <nav class="arcadia-wizard__nav" role="tablist" aria-label="Form steps">
        @for (var i = 0; i < _steps.Count; i++)
        {
            var stepIndex = i;
            var step = _steps[i];
            var isCurrent = stepIndex == CurrentStep;
            var isCompleted = stepIndex < CurrentStep;
            var isAccessible = !Linear || stepIndex <= _highestReached;

            <button type="button"
                    class="arcadia-wizard__step-btn @(isCurrent ? "arcadia-wizard__step-btn--current" : "") @(isCompleted ? "arcadia-wizard__step-btn--completed" : "")"
                    role="tab"
                    aria-selected="@(isCurrent ? "true" : "false")"
                    aria-controls="@($"arcadia-wizard-panel-{stepIndex}")"
                    disabled="@(!isAccessible)"
                    @onclick="() => GoToStep(stepIndex)">
                <span class="arcadia-wizard__step-indicator">
                    @if (isCompleted) { <span aria-hidden="true">✓</span> }
                    else { @(stepIndex + 1) }
                </span>
                <span class="arcadia-wizard__step-title">@step.Title</span>
            </button>
        }
    </nav>

    @if (ShowProgress)
    {
        <div class="arcadia-wizard__progress" role="progressbar"
             aria-valuenow="@ProgressPercent" aria-valuemin="0" aria-valuemax="100"
             aria-label="@($"Step {CurrentStep + 1} of {_steps.Count}")">
            <div class="arcadia-wizard__progress-bar" style="width: @(ProgressPercent)%;"></div>
        </div>
    }

    <div class="arcadia-wizard__panel"
         id="@($"arcadia-wizard-panel-{CurrentStep}")"
         role="tabpanel">
        <CascadingValue Value="this" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </div>

    <div class="arcadia-wizard__actions">
        @if (CurrentStep > 0)
        {
            <button type="button" class="arcadia-wizard__btn arcadia-wizard__btn--prev" @onclick="Previous">
                @PreviousText
            </button>
        }
        <div class="arcadia-wizard__actions-spacer"></div>
        @if (CurrentStep < _steps.Count - 1)
        {
            <button type="button" class="arcadia-wizard__btn arcadia-wizard__btn--next" @onclick="Next">
                @NextText
            </button>
        }
        else
        {
            <button type="button" class="arcadia-wizard__btn arcadia-wizard__btn--complete" @onclick="Complete">
                @CompleteText
            </button>
        }
    </div>
</div>

@namespace Arcadia.DataGrid.Components
@typeparam TItem
@inherits Arcadia.Core.Base.ArcadiaComponentBase

@* Collect column definitions from child components *@
<CascadingValue Value="Collector" IsFixed="true">
    @ChildContent
</CascadingValue>

<div class="arcadia-grid @(Dense ? "arcadia-grid--dense" : "") @(Striped ? "arcadia-grid--striped" : "") @(Hoverable ? "arcadia-grid--hoverable" : "") @Class"
     style="@(Height is not null ? $"height:{Height};overflow:auto;" : "") @Style"
     @attributes="AdditionalAttributes"
     role="grid"
     tabindex="0"
     aria-busy="@(Loading ? "true" : "false")"
     aria-activedescendant="@GetActiveDescendant()"
     @onkeydown="HandleGridKeyDown"
     @onkeydown:preventDefault="@(_gridHasFocus)"
     @onfocus="@(() => _gridHasFocus = true)"
     @onblur="@(() => _gridHasFocus = false)">

    @* ARIA live region for screen reader announcements *@
    <div class="arcadia-sr-only" role="status" aria-live="polite" aria-atomic="true">@_liveAnnouncement</div>

    @if (Loading)
    {
        <div class="arcadia-grid__loading">
            @for (var r = 0; r < 5; r++)
            {
                <div class="arcadia-grid__skeleton-row"></div>
            }
        </div>
    }
    else if (_columnsCollected && Columns.Count > 0)
    {
        <div class="arcadia-grid__toolbar">
            @if (Filterable)
            {
                <button class="arcadia-grid__filter-toggle @(_showFilters ? "arcadia-grid__filter-toggle--active" : "")"
                        @onclick="ToggleFilters">Filter</button>
            }
            <button class="arcadia-grid__filter-toggle @(_showColumnPicker ? "arcadia-grid__filter-toggle--active" : "")"
                    @onclick="ToggleColumnPicker">Columns</button>
            <button class="arcadia-grid__filter-toggle" @onclick="ExportCsvDownload">Export CSV</button>
            @if (_selectedItems.Count > 0)
            {
                <span class="arcadia-grid__selection-count">@_selectedItems.Count selected</span>
            }
        </div>
        @if (_showColumnPicker)
        {
            <div class="arcadia-grid__column-picker">
                @foreach (var col in Columns)
                {
                    var localCol = col;
                    <label class="arcadia-grid__column-picker-item">
                        <input type="checkbox" checked="@localCol.IsVisible"
                               @onclick="@(() => ToggleColumnVisibility(localCol))" />
                        <span>@localCol.Title</span>
                    </label>
                }
            </div>
        }
        <table class="arcadia-grid__table" @ref="TableRef">
            <thead class="@(FixedHeader ? "arcadia-grid__thead--sticky" : "")">
                <tr role="row">
                    @if (ShowRowSelector)
                    {
                        <th class="arcadia-grid__th arcadia-grid__th--row-selector">#</th>
                    }
                    @if (DetailTemplate is not null)
                    {
                        <th class="arcadia-grid__th" style="width:36px;"></th>
                    }
                    @if (Selectable && MultiSelect)
                    {
                        <th class="arcadia-grid__th arcadia-grid__th--checkbox" style="width:40px;">
                            <input type="checkbox" checked="@IsAllSelected()" @onclick="ToggleSelectAll" />
                        </th>
                    }
                    @foreach (var col in Columns.Where(c => c.IsVisible))
                    {
                        var localCol = col;
                        var sortDir = GetSortDirection(localCol.Key);
                        var isSortable = localCol.Sortable ?? Sortable;
                        var ariaSort = sortDir switch
                        {
                            SortDirection.Ascending => "ascending",
                            SortDirection.Descending => "descending",
                            _ => "none"
                        };
                        <th role="columnheader"
                            aria-sort="@ariaSort"
                            aria-label="@GetSortAriaLabel(localCol)"
                            style="@(localCol.Width is not null ? $"width:{localCol.Width};" : "") text-align:@localCol.Align;"
                            class="arcadia-grid__th @(isSortable ? "arcadia-grid__th--sortable" : "")"
                            @onclick="@(() => HandleHeaderClick(localCol))">
                            @if (localCol.HeaderTemplate is not null)
                            {
                                @localCol.HeaderTemplate
                            }
                            else
                            {
                                <span>@localCol.Title</span>
                                @if (isSortable && localCol.Field is not null)
                                {
                                    <span class="arcadia-grid__sort-icon">
                                        @if (sortDir == SortDirection.Ascending) { <text>&#9650;</text> }
                                        else if (sortDir == SortDirection.Descending) { <text>&#9660;</text> }
                                        else { <text>&#8693;</text> }
                                    </span>
                                }
                            }
                            <div class="arcadia-grid__resize-handle"></div>
                        </th>
                    }
                </tr>
                @if (_showFilters && Filterable)
                {
                    <tr class="arcadia-grid__filter-row">
                        @if (ShowRowSelector) { <th class="arcadia-grid__th"></th> }
                        @if (DetailTemplate is not null) { <th class="arcadia-grid__th"></th> }
                        @if (Selectable && MultiSelect)
                        {
                            <th class="arcadia-grid__th"></th>
                        }
                        @foreach (var col in Columns.Where(c => c.IsVisible))
                        {
                            var fCol = col;
                            var isFilterable = fCol.Filterable ?? (fCol.Field is not null);
                            <th class="arcadia-grid__th arcadia-grid__th--filter">
                                @if (isFilterable)
                                {
                                    <input type="text" class="arcadia-grid__filter-input"
                                           placeholder="Filter..."
                                           value="@GetFilterValue(fCol.Key)"
                                           @oninput="@((ChangeEventArgs e) => SetFilter(fCol.Key, e.Value?.ToString() ?? ""))" />
                                }
                            </th>
                        }
                    </tr>
                }
            </thead>
            <tbody>
                @{ var rows = !string.IsNullOrEmpty(GroupBy) ? new List<TItem>() : GetPagedData().ToList();
                   var rowIdx = _pageIndex * PageSize;
                   var colSpan = Columns.Count(c => c.IsVisible) + (Selectable && MultiSelect ? 1 : 0) + (DetailTemplate is not null ? 1 : 0) + (ShowRowSelector ? 1 : 0); }

                @* Grouped rendering *@
                @if (!string.IsNullOrEmpty(GroupBy))
                {
                    var groups = GetGroupedData();
                    @foreach (var group in groups)
                    {
                        var gKey = group.Key;
                        <tr class="arcadia-grid__group-row" @onclick="@(() => ToggleGroup(gKey))">
                            <td colspan="@colSpan" class="arcadia-grid__group-cell">
                                <span class="arcadia-grid__expand-icon @(IsGroupExpanded(gKey) ? "arcadia-grid__expand-icon--open" : "")">&#9656;</span>
                                @group.Label
                                <span class="arcadia-grid__group-count">(@group.Items.Count)</span>
                            </td>
                        </tr>
                        @if (IsGroupExpanded(gKey))
                        {
                            @foreach (var item in group.Items)
                            {
                                rows.Add(item); @* track for footer *@
                                var localItem = item;
                                <tr role="row">
                                    @if (DetailTemplate is not null) { <td class="arcadia-grid__td"></td> }
                                    @if (Selectable && MultiSelect) { <td class="arcadia-grid__td"></td> }
                                    @foreach (var col in Columns.Where(c => c.IsVisible))
                                    {
                                        <td role="gridcell" style="text-align:@col.Align;" class="arcadia-grid__td">
                                            @if (col.Template is not null) { @col.Template(item) }
                                            else if (col.Field is not null) { @col.FormatValue(col.Field(item)) }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    }
                }
                else if (rows.Count == 0)
                {
                    <tr>
                        <td colspan="@colSpan" class="arcadia-grid__empty">
                            @EmptyMessage
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in rows)
                    {
                        var localItem = item;
                        var localRowIdx = ++rowIdx;
                        <tr role="row" class="@(IsSelected(localItem) ? "arcadia-grid__row--selected" : "") @(IsCurrent(localItem) ? "arcadia-grid__row--current" : "")"
                            @onclick="@(async () => { SetCurrentRow(localItem); if (Selectable) await ToggleSelection(localItem); else StateHasChanged(); })"
                            style="cursor:pointer;">
                            @if (ShowRowSelector)
                            {
                                var selectorGlyph = GetRowSelectorGlyph(localItem);
                                <td class="arcadia-grid__td arcadia-grid__td--row-selector" @onclick:stopPropagation="true"
                                    @onclick="@(async () => { SetCurrentRow(localItem); if (Selectable) await ToggleSelection(localItem); })">
                                    @if (!string.IsNullOrEmpty(selectorGlyph))
                                    {
                                        <span class="arcadia-grid__row-glyph">@selectorGlyph</span>
                                    }
                                    else if (ShowRowNumbers)
                                    {
                                        <span class="arcadia-grid__row-number">@localRowIdx</span>
                                    }
                                </td>
                            }
                            @if (DetailTemplate is not null)
                            {
                                <td class="arcadia-grid__td arcadia-grid__td--expand" @onclick:stopPropagation="true"
                                    @onclick="@(() => ToggleDetail(localItem))">
                                    <span class="arcadia-grid__expand-icon @(IsExpanded(localItem) ? "arcadia-grid__expand-icon--open" : "")">&#9656;</span>
                                </td>
                            }
                            @if (Selectable && MultiSelect)
                            {
                                <td class="arcadia-grid__td arcadia-grid__td--checkbox" @onclick:stopPropagation="true">
                                    <input type="checkbox" checked="@IsSelected(localItem)"
                                           @onclick="@(() => ToggleSelection(localItem))" />
                                </td>
                            }
                            @{ var bodyRowIdx = localRowIdx - 1; var bodyColIdx = 0; }
                            @foreach (var col in Columns.Where(c => c.IsVisible))
                            {
                                var editCol = col;
                                var cellClass = editCol.CellClass?.Invoke(item);
                                var isEditCell = editCol.Editable && IsEditingCell(localItem, editCol.Key);
                                var isFocused = IsFocusedCell(bodyRowIdx, bodyColIdx);
                                <td role="gridcell"
                                    id="@GetCellId(bodyRowIdx, bodyColIdx)"
                                    style="text-align:@editCol.Align;"
                                    class="arcadia-grid__td @cellClass @(isEditCell ? "arcadia-grid__td--editing" : "") @(isFocused ? "arcadia-grid__td--focused" : "")"
                                    @ondblclick="@(editCol.Editable ? () => StartEdit(localItem, editCol.Key) : (Action)(() => {}))">
                                    @if (isEditCell)
                                    {
                                        @if (editCol.EditTemplate is not null)
                                        {
                                            @editCol.EditTemplate(localItem)
                                        }
                                        else
                                        {
                                            <input class="arcadia-grid__edit-input"
                                                   value="@editCol.FormatValue(editCol.Field?.Invoke(localItem))"
                                                   @onkeydown="@(async (KeyboardEventArgs e) => { if (e.Key == "Enter") await CommitEdit(); else if (e.Key == "Escape") CancelEdit(); })"
                                                   @onblur="@(async () => await CommitEdit())" />
                                        }
                                    }
                                    else if (editCol.Template is not null)
                                    {
                                        @editCol.Template(item)
                                    }
                                    else if (editCol.Field is not null)
                                    {
                                        @editCol.FormatValue(editCol.Field(item))
                                    }
                                </td>
                                bodyColIdx++;
                            }
                        </tr>
                        @if (DetailTemplate is not null && IsExpanded(localItem))
                        {
                            <tr class="arcadia-grid__detail-row">
                                <td colspan="@(colSpan + 1)" class="arcadia-grid__detail-cell">
                                    @DetailTemplate(localItem)
                                </td>
                            </tr>
                        }
                    }
                }
            </tbody>
            @* Footer aggregates *@
            @if (Columns.Any(c => c.IsVisible && (c.Aggregate != Arcadia.DataGrid.Core.AggregateType.None || c.FooterTemplate is not null)))
            {
                <tfoot>
                    <tr class="arcadia-grid__footer-row">
                        @if (DetailTemplate is not null) { <td class="arcadia-grid__td"></td> }
                        @if (Selectable && MultiSelect) { <td class="arcadia-grid__td"></td> }
                        @foreach (var col in Columns.Where(c => c.IsVisible))
                        {
                            <td class="arcadia-grid__td arcadia-grid__td--footer" style="text-align:@col.Align;">
                                @if (col.FooterTemplate is not null)
                                {
                                    @col.FooterTemplate
                                }
                                else if (col.Aggregate != Arcadia.DataGrid.Core.AggregateType.None)
                                {
                                    var agg = ComputeAggregate(col, col.Aggregate);
                                    <span>@col.FormatValue(agg)</span>
                                }
                            </td>
                        }
                    </tr>
                </tfoot>
            }
        </table>

        @* Pagination — hidden in virtual scroll mode *@
        @if (!VirtualizeRows && PageSize > 0 && TotalCount > PageSize)
        {
            <div class="arcadia-grid__pagination" aria-label="Grid pagination">
                <span class="arcadia-grid__page-info">
                    @(_pageIndex * PageSize + 1)–@(Math.Min((_pageIndex + 1) * PageSize, TotalCount)) of @TotalCount
                </span>
                <div class="arcadia-grid__page-nav">
                    <button class="arcadia-grid__page-btn" disabled="@(_pageIndex == 0)"
                            @onclick="@(() => GoToPage(0))" aria-label="First page">&#171;</button>
                    <button class="arcadia-grid__page-btn" disabled="@(_pageIndex == 0)"
                            @onclick="@(() => GoToPage(_pageIndex - 1))" aria-label="Previous page">&#8249;</button>
                    <span class="arcadia-grid__page-current">Page @(_pageIndex + 1) of @PageCount</span>
                    <button class="arcadia-grid__page-btn" disabled="@(_pageIndex >= PageCount - 1)"
                            @onclick="@(() => GoToPage(_pageIndex + 1))" aria-label="Next page">&#8250;</button>
                    <button class="arcadia-grid__page-btn" disabled="@(_pageIndex >= PageCount - 1)"
                            @onclick="@(() => GoToPage(PageCount - 1))" aria-label="Last page">&#187;</button>
                </div>
                <select class="arcadia-grid__page-size" value="@PageSize"
                        @onchange="HandlePageSizeChange">
                    @foreach (var opt in PageSizeOptions)
                    {
                        <option value="@opt" selected="@(opt == PageSize)">@opt rows</option>
                    }
                </select>
            </div>
        }
    }

    <CommunityWatermark />
</div>

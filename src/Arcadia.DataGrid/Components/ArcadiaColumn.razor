@namespace Arcadia.DataGrid.Components
@typeparam TItem

@code {
    /// <summary>Value accessor lambda for this column. Use for computed values or projections. For simple property access, prefer <see cref="Property"/>.</summary>
    [Parameter] public Func<TItem, object>? Field { get; set; }

    /// <summary>Property name on TItem to display (e.g., "Salary"). Simpler alternative to Field — no boxing required for value types. Ignored when Field is set.</summary>
    /// <remarks>Simpler alternative to Field with no boxing for value types. Auto-generates Title from PascalCase name (e.g., "FirstName" becomes "First Name").</remarks>
    [Parameter] public string? Property { get; set; }

    /// <summary>Column header text.</summary>
    [Parameter] public string Title { get; set; } = "";

    /// <summary>Whether this column is sortable. Null inherits from grid.</summary>
    [Parameter] public bool? Sortable { get; set; }

    /// <summary>CSS width (e.g., "200px", "30%"). Null = auto.</summary>
    [Parameter] public string? Width { get; set; }

    /// <summary>Runtime-mutable width for resize and state restoration. Falls back to the Width parameter when not set.</summary>
    internal string? RuntimeWidth { get; set; }

    /// <summary>Effective width: RuntimeWidth if set by resize/restore, otherwise the original Width parameter.</summary>
    internal string? EffectiveWidth => RuntimeWidth ?? Width;

    /// <summary>Text alignment: left, center, right.</summary>
    [Parameter] public string Align { get; set; } = "left";

    /// <summary>.NET format string for cell values (e.g., "C2", "d", "N0").</summary>
    [Parameter] public string? Format { get; set; }

    /// <summary>Custom cell content template.</summary>
    [Parameter] public RenderFragment<TItem>? Template { get; set; }

    /// <summary>Custom header content template.</summary>
    [Parameter] public RenderFragment? HeaderTemplate { get; set; }

    /// <summary>Whether this column is filterable. Null inherits from grid.</summary>
    [Parameter] public bool? Filterable { get; set; }

    /// <summary>Whether this column is visible. Defaults to true.</summary>
    [Parameter] public bool Visible { get; set; } = true;

    /// <summary>Internal visibility state for column picker toggling.</summary>
    internal bool IsVisible { get; set; } = true;

    /// <summary>Toggle visibility (called by grid column picker).</summary>
    internal void ToggleVisible() { IsVisible = !IsVisible; }

    /// <summary>Pin this column to the left edge (stays visible on horizontal scroll). Requires Width to be set.</summary>
    [Parameter] public bool Frozen { get; set; }

    /// <summary>Position for frozen columns: "left" (default) or "right". Only applies when Frozen/IsFrozen is true.</summary>
    [Parameter] public string FrozenPosition { get; set; } = "left";

    /// <summary>Internal frozen state for runtime pin/unpin toggling.</summary>
    internal bool IsFrozen { get; set; }

    /// <summary>Whether this column supports inline editing.</summary>
    [Parameter] public bool Editable { get; set; }

    /// <summary>Custom edit template for inline editing.</summary>
    [Parameter] public RenderFragment<TItem>? EditTemplate { get; set; }

    /// <summary>Footer aggregate type: None, Sum, Average, Count, Min, Max.</summary>
    [Parameter] public Arcadia.DataGrid.Core.AggregateType Aggregate { get; set; } = Arcadia.DataGrid.Core.AggregateType.None;

    /// <summary>Custom footer template (overrides Aggregate when set).</summary>
    [Parameter] public RenderFragment? FooterTemplate { get; set; }

    /// <summary>Rich tooltip template shown on cell hover. Takes precedence over Tooltip text.</summary>
    [Parameter] public RenderFragment<TItem>? TooltipTemplate { get; set; }

    /// <summary>Simple text tooltip shown on cell hover (via title attribute). Ignored when TooltipTemplate is set.</summary>
    [Parameter] public string? Tooltip { get; set; }

    /// <summary>Dynamic CSS class for cells in this column.</summary>
    [Parameter] public Func<TItem, string?>? CellClass { get; set; }

    /// <summary>Conditional formatting preset: "DataBar", "RedGreenScale", or "IconSet". Applies visual formatting based on cell values relative to column min/max.</summary>
    [Parameter] public string? ConditionalFormat { get; set; }

    /// <summary>Computed minimum value for this column (used by ConditionalFormat). Set by the parent grid.</summary>
    internal double ColumnMin { get; set; }

    /// <summary>Computed maximum value for this column (used by ConditionalFormat). Set by the parent grid.</summary>
    internal double ColumnMax { get; set; }

    /// <summary>ColSpan function for cell merging. Returns the number of columns a cell should span. Adjacent columns are skipped.</summary>
    [Parameter] public Func<TItem, int>? ColSpan { get; set; }

    /// <summary>Validation function for inline cell editing. Receives the raw string value from the edit input. Returns null/empty for valid, or an error message string for invalid.</summary>
    [Parameter] public Func<string, string?>? Validator { get; set; }

    /// <summary>Current validation error message for this column's active edit cell. Set by the grid during editing.</summary>
    internal string? ValidationError { get; set; }

    /// <summary>Group name for stacked/grouped column headers. Columns with the same Group value share a spanning header row above them.</summary>
    [Parameter] public string? Group { get; set; }

    /// <summary>Unique key for this column. Auto-generated from Title when not set.</summary>
    [Parameter] public string? Key { get; set; }

    /// <summary>Resolved column key (user-provided or auto-generated).</summary>
    internal string ResolvedKey => Key ?? Property ?? (!string.IsNullOrEmpty(Title) ? Title : Field?.Method.Name ?? Guid.NewGuid().ToString());

    /// <summary>Resolved field accessor. Uses Field if set, otherwise builds one from Property via reflection.</summary>
    internal Func<TItem, object>? ResolvedField => Field ?? _propertyAccessor;

    private Func<TItem, object>? _propertyAccessor;

    /// <summary>Format a cell value using the column's Format string.</summary>
    public string FormatValue(object? value)
    {
        if (value is null) return "";
        if (Format is not null && value is IFormattable formattable)
            return formattable.ToString(Format, null);
        return value.ToString() ?? "";
    }

    /// <summary>Parent grid registers this column during rendering.</summary>
    [CascadingParameter] internal ArcadiaDataGridColumnCollector<TItem>? Collector { get; set; }

    /// <summary>Auto-detected data type of this column (String, Number, Boolean, Date). Used for typed filter rendering.</summary>
    internal ColumnDataType DetectedDataType { get; private set; } = ColumnDataType.String;

    protected override void OnInitialized()
    {
        IsVisible = Visible;
        IsFrozen = Frozen;
        BuildPropertyAccessor();
        DetectDataType();
        Collector?.AddColumn(this);
    }

    private void BuildPropertyAccessor()
    {
        if (Field is not null || string.IsNullOrEmpty(Property)) return;

        var prop = typeof(TItem).GetProperty(Property,
            System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.IgnoreCase);
        if (prop is null) return;

        _propertyAccessor = item => prop.GetValue(item)!;

        // Auto-generate title from property name if not set
        if (string.IsNullOrEmpty(Title))
            Title = System.Text.RegularExpressions.Regex.Replace(Property, "([a-z])([A-Z])", "$1 $2");
    }

    /// <summary>Get the conditional format CSS class for a cell value.</summary>
    internal string GetConditionalFormatClass()
    {
        return ConditionalFormat switch
        {
            "DataBar" => "arcadia-grid__cf-databar",
            "RedGreenScale" => "arcadia-grid__cf-redgreen",
            "IconSet" => "arcadia-grid__cf-iconset",
            _ => ""
        };
    }

    /// <summary>Get inline style for conditional formatting based on the cell's numeric value.</summary>
    internal string GetConditionalFormatStyle(object? rawValue)
    {
        if (string.IsNullOrEmpty(ConditionalFormat) || rawValue is null) return "";

        double val;
        switch (rawValue)
        {
            case double d: val = d; break;
            case int i: val = i; break;
            case long l: val = l; break;
            case decimal m: val = (double)m; break;
            case float f: val = f; break;
            default:
                if (!double.TryParse(rawValue.ToString(), out val)) return "";
                break;
        }

        var range = ColumnMax - ColumnMin;
        if (range <= 0) return "";
        var normalized = Math.Clamp((val - ColumnMin) / range, 0, 1);

        return ConditionalFormat switch
        {
            "DataBar" => $"--cf-pct:{normalized * 100:F1}%;",
            "RedGreenScale" =>
                $"background:color-mix(in srgb, rgba(220,38,38,0.18) {((1.0 - normalized) * 100):F0}%, rgba(22,163,74,0.18) {(normalized * 100):F0}%);",
            "IconSet" => "", // icon is rendered in markup, not via style
            _ => ""
        };
    }

    /// <summary>Get the icon for IconSet conditional formatting.</summary>
    internal string GetConditionalFormatIcon(object? rawValue)
    {
        if (ConditionalFormat != "IconSet" || rawValue is null) return "";

        double val;
        switch (rawValue)
        {
            case double d: val = d; break;
            case int i: val = i; break;
            case long l: val = l; break;
            case decimal m: val = (double)m; break;
            case float f: val = f; break;
            default:
                if (!double.TryParse(rawValue.ToString(), out val)) return "";
                break;
        }

        var range = ColumnMax - ColumnMin;
        if (range <= 0) return "\u2192"; // → neutral arrow
        var normalized = (val - ColumnMin) / range;

        if (normalized >= 0.67) return "\u2191"; // ↑ up
        if (normalized <= 0.33) return "\u2193"; // ↓ down
        return "\u2192"; // → neutral
    }

    private void DetectDataType()
    {
        Type? valueType = null;

        if (!string.IsNullOrEmpty(Property))
        {
            var prop = typeof(TItem).GetProperty(Property,
                System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.IgnoreCase);
            valueType = prop?.PropertyType;
        }

        if (valueType is null) return;

        // Unwrap Nullable<T>
        valueType = Nullable.GetUnderlyingType(valueType) ?? valueType;

        if (valueType == typeof(bool))
            DetectedDataType = ColumnDataType.Boolean;
        else if (valueType == typeof(DateTime) || valueType == typeof(DateTimeOffset)
#if NET6_0_OR_GREATER
            || valueType == typeof(DateOnly)
#endif
        )
            DetectedDataType = ColumnDataType.Date;
        else if (valueType == typeof(int) || valueType == typeof(long) || valueType == typeof(double)
            || valueType == typeof(float) || valueType == typeof(decimal) || valueType == typeof(short))
            DetectedDataType = ColumnDataType.Number;
    }
}

@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<label class="@CssClass"
       style="@Style"
       @attributes="AdditionalAttributes">

    <input type="checkbox"
           class="arcadia-switch__input"
           checked="@Value"
           disabled="@Disabled"
           role="switch"
           aria-checked="@(Value ? "true" : "false")"
           aria-label="@Label"
           @onchange="OnToggleAsync" />

    <span class="arcadia-switch__track">
        @if (!string.IsNullOrEmpty(OnLabel) || !string.IsNullOrEmpty(OffLabel))
        {
            <span class="arcadia-switch__on-label">@OnLabel</span>
            <span class="arcadia-switch__off-label">@OffLabel</span>
        }
        <span class="arcadia-switch__thumb"></span>
    </span>

    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="arcadia-switch__label">@Label</span>
    }
</label>

@code {
    /// <summary>
    /// Gets or sets whether the switch is on. Supports two-way binding via <see cref="ValueChanged"/>.
    /// </summary>
    [Parameter]
    public bool Value { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when <see cref="Value"/> changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the label text displayed next to the switch.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets the text displayed inside the switch when it is on.
    /// </summary>
    [Parameter]
    public string? OnLabel { get; set; }

    /// <summary>
    /// Gets or sets the text displayed inside the switch when it is off.
    /// </summary>
    [Parameter]
    public string? OffLabel { get; set; }

    /// <summary>
    /// Gets or sets whether the switch is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the size of the switch. Valid values: "sm", "md", "lg". Default is "md".
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    /// <summary>
    /// Gets or sets the color theme of the switch. Valid values: "primary", "success", "warning", "danger". Default is "primary".
    /// </summary>
    [Parameter]
    public string Color { get; set; } = "primary";

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-switch")
        .AddClass($"arcadia-switch--{Size}", !string.IsNullOrEmpty(Size))
        .AddClass($"arcadia-switch--{Color}", !string.IsNullOrEmpty(Color))
        .AddClass("arcadia-switch--checked", Value)
        .AddClass("arcadia-switch--disabled", Disabled)
        .AddClass(Class)
        .Build();

    private async Task OnToggleAsync(ChangeEventArgs args)
    {
        if (Disabled) return;

        Value = !Value;
        await ValueChanged.InvokeAsync(Value);
    }
}

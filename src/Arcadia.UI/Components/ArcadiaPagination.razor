@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase

<nav class="@CssClass"
     style="@Style"
     aria-label="Pagination"
     role="navigation"
     @attributes="AdditionalAttributes">
    @if (ShowFirstLast)
    {
        <button type="button"
                class="arcadia-pagination__btn arcadia-pagination__btn--first"
                aria-label="Go to first page"
                disabled="@(CurrentPage <= 1)"
                @onclick="() => GoTo(1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arcadia-pagination__icon">
                <polyline points="11 17 6 12 11 7" /><polyline points="18 17 13 12 18 7" />
            </svg>
        </button>
    }

    @if (ShowPreviousNext)
    {
        <button type="button"
                class="arcadia-pagination__btn arcadia-pagination__btn--prev"
                aria-label="Go to previous page"
                disabled="@(CurrentPage <= 1)"
                @onclick="() => GoTo(CurrentPage - 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arcadia-pagination__icon">
                <polyline points="15 18 9 12 15 6" />
            </svg>
        </button>
    }

    @foreach (var page in GetPageNumbers())
    {
        @if (page == -1)
        {
            <span class="arcadia-pagination__ellipsis" aria-hidden="true">&hellip;</span>
        }
        else
        {
            <button type="button"
                    class="arcadia-pagination__btn arcadia-pagination__btn--page @(page == CurrentPage ? "arcadia-pagination__btn--active" : "")"
                    aria-label="@($"Page {page}")"
                    aria-current="@(page == CurrentPage ? "page" : null)"
                    @onclick="() => GoTo(page)">
                @(page)
            </button>
        }
    }

    @if (ShowPreviousNext)
    {
        <button type="button"
                class="arcadia-pagination__btn arcadia-pagination__btn--next"
                aria-label="Go to next page"
                disabled="@(CurrentPage >= TotalPages)"
                @onclick="() => GoTo(CurrentPage + 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arcadia-pagination__icon">
                <polyline points="9 18 15 12 9 6" />
            </svg>
        </button>
    }

    @if (ShowFirstLast)
    {
        <button type="button"
                class="arcadia-pagination__btn arcadia-pagination__btn--last"
                aria-label="Go to last page"
                disabled="@(CurrentPage >= TotalPages)"
                @onclick="() => GoTo(TotalPages)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="arcadia-pagination__icon">
                <polyline points="13 17 18 12 13 7" /><polyline points="6 17 11 12 6 7" />
            </svg>
        </button>
    }
</nav>

@code {
    /// <summary>
    /// Gets or sets the current page number (1-based).
    /// </summary>
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Callback invoked when the current page changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> CurrentPageChanged { get; set; }

    /// <summary>
    /// Gets or sets the total number of pages.
    /// </summary>
    [Parameter]
    public int TotalPages { get; set; }

    /// <summary>
    /// Gets or sets the number of sibling pages shown around the current page. Default is 1.
    /// </summary>
    [Parameter]
    public int SiblingCount { get; set; } = 1;

    /// <summary>
    /// Gets or sets whether first/last page buttons are shown. Default is true.
    /// </summary>
    [Parameter]
    public bool ShowFirstLast { get; set; } = true;

    /// <summary>
    /// Gets or sets whether previous/next page buttons are shown. Default is true.
    /// </summary>
    [Parameter]
    public bool ShowPreviousNext { get; set; } = true;

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-pagination")
        .AddClass(Class)
        .Build();

    private async Task GoTo(int page)
    {
        if (page < 1 || page > TotalPages || page == CurrentPage) return;
        CurrentPage = page;
        await CurrentPageChanged.InvokeAsync(CurrentPage);
    }

    private List<int> GetPageNumbers()
    {
        var pages = new List<int>();
        if (TotalPages <= 0) return pages;

        var start = Math.Max(2, CurrentPage - SiblingCount);
        var end = Math.Min(TotalPages - 1, CurrentPage + SiblingCount);

        // Always include page 1
        pages.Add(1);

        // Left ellipsis
        if (start > 2)
        {
            pages.Add(-1); // -1 represents ellipsis
        }

        // Sibling pages
        for (var i = start; i <= end; i++)
        {
            pages.Add(i);
        }

        // Right ellipsis
        if (end < TotalPages - 1)
        {
            pages.Add(-1);
        }

        // Always include last page (if more than 1 page)
        if (TotalPages > 1)
        {
            pages.Add(TotalPages);
        }

        return pages;
    }
}

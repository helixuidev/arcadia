@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase

@if (Open)
{
    <div class="arcadia-command-palette-overlay"
         @onclick="CloseAsync"
         @onkeydown="HandleKeyDownAsync"
         @onkeydown:preventDefault="_preventKeyDefault">
        <div class="@CssClass"
             style="@Style"
             role="dialog"
             aria-label="Command palette"
             aria-modal="true"
             @onclick:stopPropagation="true"
             @attributes="AdditionalAttributes">
            <div class="arcadia-command-palette__search">
                <svg class="arcadia-command-palette__search-icon" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input class="arcadia-command-palette__input"
                       type="text"
                       placeholder="@Placeholder"
                       value="@SearchText"
                       @oninput="OnInputChangedAsync"
                       @ref="_inputRef"
                       role="combobox"
                       aria-expanded="true"
                       aria-controls="@ListId"
                       aria-activedescendant="@ActiveDescendantId"
                       aria-autocomplete="list"
                       autocomplete="off" />
            </div>
            <CascadingValue Value="this" IsFixed="true">
                <div class="arcadia-command-palette__list" id="@ListId" role="listbox">
                    @ChildContent
                </div>
            </CascadingValue>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets whether the command palette is open.
    /// </summary>
    /// <example>
    /// <code>
    /// &lt;ArcadiaCommandPalette @bind-Open="showPalette" OnSearch="HandleSearch"&gt;
    ///     &lt;ArcadiaCommandItem Label="New File" Shortcut="Ctrl+N" /&gt;
    /// &lt;/ArcadiaCommandPalette&gt;
    /// </code>
    /// </example>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when <see cref="Open"/> changes. Supports two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the placeholder text for the search input. Defaults to "Search commands...".
    /// </summary>
    [Parameter]
    public string Placeholder { get; set; } = "Search commands...";

    /// <summary>
    /// Gets or sets the command items content rendered inside the palette list.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the search input value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSearch { get; set; }

    /// <summary>
    /// Gets or sets the current search text value.
    /// </summary>
    [Parameter]
    public string SearchText { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the callback invoked when <see cref="SearchText"/> changes. Supports two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<string> SearchTextChanged { get; set; }

    private ElementReference _inputRef;
    private readonly List<ArcadiaCommandItem> _items = new();
    private int _activeIndex = -1;
    private bool _preventKeyDefault;
    private string ListId => $"{ElementId}-list";

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-command-palette")
        .AddClass(Class)
        .Build();

    private string? ActiveDescendantId => _activeIndex >= 0 && _activeIndex < _items.Count
        ? _items[_activeIndex].ItemId
        : null;

    /// <summary>
    /// Registers a child <see cref="ArcadiaCommandItem"/> with this palette.
    /// Called internally by child items.
    /// </summary>
    internal void AddItem(ArcadiaCommandItem item)
    {
        item.Index = _items.Count;
        _items.Add(item);
        UpdateItemStates();
        StateHasChanged();
    }

    /// <summary>
    /// Removes a child <see cref="ArcadiaCommandItem"/> from this palette.
    /// Called internally by child items on disposal.
    /// </summary>
    internal void RemoveItem(ArcadiaCommandItem item)
    {
        _items.Remove(item);
        for (var i = 0; i < _items.Count; i++)
        {
            _items[i].Index = i;
        }

        if (_activeIndex >= _items.Count)
        {
            _activeIndex = _items.Count - 1;
        }

        UpdateItemStates();
        StateHasChanged();
    }

    private void UpdateItemStates()
    {
        for (var i = 0; i < _items.Count; i++)
        {
            _items[i].IsActive = i == _activeIndex;
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open)
        {
            try
            {
                await _inputRef.FocusAsync();
            }
            catch
            {
                // Element may not be rendered yet
            }
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (!Open)
        {
            _activeIndex = -1;
            UpdateItemStates();
        }
    }

    private async Task CloseAsync()
    {
        Open = false;
        _activeIndex = -1;
        UpdateItemStates();
        await OpenChanged.InvokeAsync(false);
    }

    private async Task HandleKeyDownAsync(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        _preventKeyDefault = false;

        if (args.Key == "Escape")
        {
            await CloseAsync();
            return;
        }

        if (args.Key == "Enter" && _activeIndex >= 0 && _activeIndex < _items.Count)
        {
            var item = _items[_activeIndex];
            if (!item.Disabled)
            {
                await item.SelectAsync();
            }
            return;
        }

        var direction = Arcadia.Core.Accessibility.KeyboardNavigation.MapVerticalKey(args.Key);
        if (direction is null)
            return;

        _preventKeyDefault = true;

        var startIndex = _activeIndex < 0
            ? (direction.Value == NavigationDirection.Previous ? 0 : _items.Count - 1)
            : _activeIndex;

        var nextIndex = Arcadia.Core.Accessibility.KeyboardNavigation.GetNextEnabledIndex(
            startIndex,
            _items.Count,
            direction.Value,
            i => _items[i].Disabled);

        _activeIndex = nextIndex;
        UpdateItemStates();
    }

    private async Task OnInputChangedAsync(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString() ?? string.Empty;
        _activeIndex = -1;
        UpdateItemStates();
        await SearchTextChanged.InvokeAsync(SearchText);
        await OnSearch.InvokeAsync(SearchText);
    }
}

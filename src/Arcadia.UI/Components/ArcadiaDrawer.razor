@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase

@if (Visible)
{
    @if (ShowOverlay)
    {
        <div class="arcadia-drawer-overlay"
             @onclick="CloseAsync"></div>
    }
    <div class="@CssClass"
         style="@ComputedStyle"
         role="dialog"
         aria-modal="true"
         aria-labelledby="@TitleId"
         tabindex="-1"
         @onkeydown="OnKeyDownAsync"
         @attributes="AdditionalAttributes">
        <div class="arcadia-drawer__header">
            @if (!string.IsNullOrEmpty(Title))
            {
                <h2 id="@TitleId" class="arcadia-drawer__title">@Title</h2>
            }
            <button class="arcadia-drawer__close"
                    type="button"
                    aria-label="Close drawer"
                    @onclick="CloseAsync">
                <svg class="arcadia-drawer__close-icon" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round"
                     stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <div class="arcadia-drawer__body">
            @ChildContent
        </div>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets whether the drawer is visible.
    /// </summary>
    [Parameter]
    public bool Visible { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when <see cref="Visible"/> changes. Supports two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>
    /// Gets or sets the slide-in position. Valid values: "left", "right", "bottom". Defaults to "right".
    /// </summary>
    [Parameter]
    public string Position { get; set; } = "right";

    /// <summary>
    /// Gets or sets the drawer width for left/right positions. Defaults to "320px".
    /// </summary>
    [Parameter]
    public string Width { get; set; } = "320px";

    /// <summary>
    /// Gets or sets the drawer height for bottom position. Defaults to "50vh".
    /// </summary>
    [Parameter]
    public string Height { get; set; } = "50vh";

    /// <summary>
    /// Gets or sets whether the overlay backdrop is shown. Defaults to true.
    /// </summary>
    [Parameter]
    public bool ShowOverlay { get; set; } = true;

    /// <summary>
    /// Gets or sets the drawer title displayed in the header.
    /// </summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Gets or sets the drawer body content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string TitleId => $"{ElementId}-title";

    private bool IsBottom => string.Equals(Position, "bottom", StringComparison.OrdinalIgnoreCase);

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-drawer")
        .AddClass($"arcadia-drawer--{Position.ToLowerInvariant()}")
        .AddClass(Class)
        .Build();

    private string? ComputedStyle => Arcadia.Core.Utilities.StyleBuilder.Default(Style)
        .AddStyle("--arcadia-drawer-width", Width, !IsBottom)
        .AddStyle("--arcadia-drawer-height", Height, IsBottom)
        .Build();

    private async Task CloseAsync()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task OnKeyDownAsync(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            await CloseAsync();
        }
    }
}

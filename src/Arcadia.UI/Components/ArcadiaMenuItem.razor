@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase
@implements IDisposable

@if (Divider)
{
    <div class="arcadia-menu-item__divider" role="separator"></div>
}
else
{
    <button class="@CssClass"
            style="@Style"
            role="menuitem"
            tabindex="@(IsActive ? 0 : -1)"
            disabled="@Disabled"
            @onclick="OnClickHandler"
            @attributes="AdditionalAttributes">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <span class="arcadia-menu-item__icon" aria-hidden="true">@Icon</span>
        }
        <span class="arcadia-menu-item__text">@Text</span>
    </button>
}

@code {
    /// <summary>
    /// Gets or sets the menu item display text.
    /// </summary>
    [Parameter]
    public string Text { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the optional icon for the menu item.
    /// </summary>
    [Parameter]
    public string? Icon { get; set; }

    /// <summary>
    /// Gets or sets whether the menu item is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the menu item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>
    /// Gets or sets whether this item renders as a divider separator line.
    /// </summary>
    [Parameter]
    public bool Divider { get; set; }

    [CascadingParameter]
    private ArcadiaContextMenu? _contextMenu { get; set; }

    /// <summary>
    /// The index of this item within the parent context menu. Set internally by the parent.
    /// </summary>
    internal int MenuIndex { get; set; }

    /// <summary>
    /// Whether this item is currently the active (highlighted) item. Set internally by the parent.
    /// </summary>
    internal bool IsActive { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-menu-item")
        .AddClass("arcadia-menu-item--active", IsActive)
        .AddClass("arcadia-menu-item--disabled", Disabled)
        .AddClass(Class)
        .Build();

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (!Divider)
        {
            _contextMenu?.AddMenuItem(this);
        }
    }

    /// <summary>
    /// Invokes the <see cref="OnClick"/> callback. Called internally by the parent context menu on Enter key.
    /// </summary>
    internal async Task ActivateAsync()
    {
        if (!Disabled)
        {
            await OnClick.InvokeAsync();
        }
    }

    private async Task OnClickHandler()
    {
        if (!Disabled)
        {
            await OnClick.InvokeAsync();
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (!Divider)
        {
            _contextMenu?.RemoveMenuItem(this);
        }
    }
}

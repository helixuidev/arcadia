@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase

@if (Divider)
{
    <div class="arcadia-menu-item__divider" role="separator"></div>
}
else
{
    <button class="@CssClass"
            style="@Style"
            role="menuitem"
            disabled="@Disabled"
            @onclick="OnClickHandler"
            @attributes="AdditionalAttributes">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <span class="arcadia-menu-item__icon" aria-hidden="true">@Icon</span>
        }
        <span class="arcadia-menu-item__text">@Text</span>
    </button>
}

@code {
    /// <summary>
    /// Gets or sets the menu item display text.
    /// </summary>
    [Parameter]
    public string Text { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the optional icon for the menu item.
    /// </summary>
    [Parameter]
    public string? Icon { get; set; }

    /// <summary>
    /// Gets or sets whether the menu item is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the menu item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnClick { get; set; }

    /// <summary>
    /// Gets or sets whether this item renders as a divider separator line.
    /// </summary>
    [Parameter]
    public bool Divider { get; set; }

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-menu-item")
        .AddClass("arcadia-menu-item--disabled", Disabled)
        .AddClass(Class)
        .Build();

    private async Task OnClickHandler()
    {
        if (!Disabled)
        {
            await OnClick.InvokeAsync();
        }
    }
}

@namespace Arcadia.UI.Components
@inherits Arcadia.Core.Base.ArcadiaComponentBase
@implements IDisposable

@if (IsActive)
{
    <div class="@CssClass"
         id="@PanelId"
         role="tabpanel"
         aria-labelledby="@TabId"
         tabindex="0"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@code {
    /// <summary>
    /// Gets or sets the tab header text.
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets an optional icon CSS class or name for the tab header.
    /// </summary>
    [Parameter]
    public string? Icon { get; set; }

    /// <summary>
    /// Gets or sets whether this tab is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the panel body content.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// The parent <see cref="ArcadiaTabs"/> component, received via cascading parameter.
    /// </summary>
    [CascadingParameter]
    private ArcadiaTabs? ParentTabs { get; set; }

    /// <summary>
    /// The index of this panel within the parent <see cref="ArcadiaTabs"/> component.
    /// Set internally by the parent.
    /// </summary>
    internal int Index { get; set; }

    /// <summary>
    /// Whether this panel is the currently active (visible) panel.
    /// Set internally by the parent.
    /// </summary>
    internal bool IsActive { get; set; }

    /// <summary>
    /// The unique ID for the tab button, used for aria-labelledby linking.
    /// </summary>
    internal string TabId => $"{ElementId}-tab";

    /// <summary>
    /// The unique ID for the tab panel, used for aria-controls linking.
    /// </summary>
    internal string PanelId => $"{ElementId}-panel";

    private string? CssClass => Arcadia.Core.Utilities.CssBuilder.Default("arcadia-tab-panel")
        .AddClass("arcadia-tab-panel--active", IsActive)
        .AddClass(Class)
        .Build();

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        ParentTabs?.AddPanel(this);
    }

    /// <inheritdoc />
    public void Dispose()
    {
        ParentTabs?.RemovePanel(this);
    }
}
